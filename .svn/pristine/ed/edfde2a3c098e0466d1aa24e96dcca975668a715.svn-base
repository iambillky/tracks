<!--
File: templates/ipam/index.html
Purpose: Main IPAM dashboard template with IP address listing and statistics
Version: 1.1.0
Author: DCMS Team
Date: 2025-01-16

Revision History:
- v1.0.0: Initial creation with IP listing, filtering, and basic statistics
- v1.1.0: Added network-wide availability statistics for public/private/colocation IPs
-->

{% extends "base.html" %}

{% block title %}IP Address Management - DCMS{% endblock %}

{% block content %}
<style>
    /* ========== IPAM SPECIFIC STYLES ========== */
    .ipam-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 30px;
        border-radius: 12px;
        margin-bottom: 30px;
        color: white;
    }
    
    /* ========== NETWORK AVAILABILITY CARDS - NEW v1.1.0 ========== */
    .network-availability {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .network-card {
        background: #1a1a24;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 20px;
        position: relative;
        overflow: hidden;
    }
    
    .network-card.public {
        border-color: rgba(239, 68, 68, 0.3);
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.05), transparent);
    }
    
    .network-card.private {
        border-color: rgba(34, 197, 94, 0.3);
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.05), transparent);
    }
    
    .network-card.colocation {
        border-color: rgba(168, 85, 247, 0.3);
        background: linear-gradient(135deg, rgba(168, 85, 247, 0.05), transparent);
    }
    
    .network-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }
    
    .network-title {
        color: #e5e7eb;
        font-size: 1.1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .network-icon {
        font-size: 1.3rem;
    }
    
    .network-utilization {
        font-size: 0.9rem;
        padding: 4px 10px;
        border-radius: 12px;
        font-weight: 600;
    }
    
    .utilization-low {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
    }
    
    .utilization-medium {
        background: rgba(251, 191, 36, 0.2);
        color: #fbbf24;
    }
    
    .utilization-high {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }
    
    .network-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 15px;
    }
    
    .network-stat {
        text-align: center;
    }
    
    .network-stat-value {
        font-size: 1.8rem;
        font-weight: bold;
        color: #60a5fa;
        display: block;
    }
    
    .network-stat-label {
        color: #8b92a5;
        font-size: 0.85rem;
        text-transform: uppercase;
        margin-top: 5px;
    }
    
    .network-bar {
        width: 100%;
        height: 10px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 5px;
        overflow: hidden;
        margin-top: 10px;
    }
    
    .network-bar-fill {
        height: 100%;
        transition: width 0.3s ease;
    }
    
    .network-bar-fill.public {
        background: linear-gradient(90deg, #ef4444, #dc2626);
    }
    
    .network-bar-fill.private {
        background: linear-gradient(90deg, #22c55e, #16a34a);
    }
    
    .network-bar-fill.colocation {
        background: linear-gradient(90deg, #a855f7, #9333ea);
    }
    
    /* ========== EXISTING STYLES ========== */
    .ipam-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .stat-card {
        background: #1a1a24;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
    }
    
    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        color: #60a5fa;
        margin-bottom: 5px;
    }
    
    .stat-label {
        color: #8b92a5;
        font-size: 0.9rem;
    }
    
    .filter-bar {
        background: #1a1a24;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
    }
    
    .filter-row {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        align-items: end;
    }
    
    .filter-group {
        flex: 1;
        min-width: 150px;
    }
    
    .filter-group label {
        display: block;
        color: #8b92a5;
        font-size: 0.85rem;
        margin-bottom: 5px;
    }
    
    .ip-table {
        background: #1a1a24;
        border-radius: 8px;
        overflow: hidden;
    }
    
    .ip-table table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .ip-table th {
        background: rgba(96, 165, 250, 0.1);
        color: #60a5fa;
        padding: 12px;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid rgba(96, 165, 250, 0.2);
    }
    
    .ip-table td {
        padding: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: #e5e7eb;
    }
    
    .ip-table tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }
    
    .ip-address {
        font-family: 'Monaco', 'Courier New', monospace;
        font-size: 0.95rem;
        color: #93bbfc;
    }
    
    .ip-type-badge {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
    }
    
    .ip-type-management { background: rgba(167, 139, 250, 0.2); color: #a78bfa; }
    .ip-type-primary { background: rgba(96, 165, 250, 0.2); color: #60a5fa; }
    .ip-type-addon { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .ip-type-virtual { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
    .ip-type-gateway { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
    
    .network-badge {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
    }
    
    .network-public { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
    .network-private { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .network-management { background: rgba(167, 139, 250, 0.2); color: #a78bfa; }
    
    .status-indicator {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    
    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }
    
    .status-available .status-dot { background: #22c55e; }
    .status-assigned .status-dot { background: #60a5fa; }
    .status-reserved .status-dot { background: #fbbf24; }
    .status-deprecated .status-dot { background: #6b7280; }
    
    .action-buttons {
        display: flex;
        gap: 5px;
    }
    
    .btn-sm {
        padding: 4px 8px;
        font-size: 0.85rem;
        border-radius: 4px;
    }
    
    .utilization-bar {
        width: 100%;
        height: 8px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        overflow: hidden;
        margin-top: 10px;
    }
    
    .utilization-fill {
        height: 100%;
        background: linear-gradient(90deg, #22c55e, #60a5fa);
        transition: width 0.3s ease;
    }
</style>

<div class="page-container">
    <!-- ========== HEADER ========== -->
    <div class="ipam-header">
        <h1 style="margin: 0; font-size: 2rem;">🌐 IP Address Management</h1>
        <p style="margin: 10px 0 20px 0; opacity: 0.9;">Centralized IP tracking and management</p>
        
        <!-- Quick Stats -->
        <div style="display: flex; gap: 30px; flex-wrap: wrap;">
            <div>
                <div style="font-size: 1.5rem; font-weight: bold;">{{ total_ips }}</div>
                <div style="font-size: 0.9rem; opacity: 0.8;">Total IPs Tracked</div>
            </div>
            <div>
                <div style="font-size: 1.5rem; font-weight: bold;">{{ utilization }}%</div>
                <div style="font-size: 0.9rem; opacity: 0.8;">Overall Utilization</div>
            </div>
            <div>
                <div style="font-size: 1.5rem; font-weight: bold;">{{ available_ips }}</div>
                <div style="font-size: 0.9rem; opacity: 0.8;">Available IPs</div>
            </div>
        </div>
        
        <div class="utilization-bar">
            <div class="utilization-fill" style="width: {{ utilization }}%"></div>
        </div>
    </div>
    
    <!-- ========== NETWORK-WIDE AVAILABILITY (CHANGED v1.1.0) ========== -->
    <div class="network-availability">
        <!-- Public Network Card -->
        <div class="network-card public">
            <div class="network-header">
                <div class="network-title">
                    <span class="network-icon">🌍</span>
                    Public Network
                </div>
                <div class="network-utilization 
                           {% if public_utilization < 60 %}utilization-low
                           {% elif public_utilization < 80 %}utilization-medium
                           {% else %}utilization-high{% endif %}">
                    {{ public_utilization }}% Used
                </div>
            </div>
            <div class="network-stats">
                <div class="network-stat">
                    <span class="network-stat-value">{{ public_available }}</span>
                    <span class="network-stat-label">Available</span>
                </div>
                <div class="network-stat">
                    <span class="network-stat-value">{{ total_public_ips }}</span>
                    <span class="network-stat-label">Total Capacity</span>
                </div>
            </div>
            <div class="network-bar">
                <div class="network-bar-fill public" style="width: {{ public_utilization }}%"></div>
            </div>
        </div>
        
        <!-- Private Network Card -->
        <div class="network-card private">
            <div class="network-header">
                <div class="network-title">
                    <span class="network-icon">🔒</span>
                    Private Network (10.x)
                </div>
                <div class="network-utilization 
                           {% if private_utilization < 60 %}utilization-low
                           {% elif private_utilization < 80 %}utilization-medium
                           {% else %}utilization-high{% endif %}">
                    {{ private_utilization }}% Used
                </div>
            </div>
            <div class="network-stats">
                <div class="network-stat">
                    <span class="network-stat-value">{{ private_available }}</span>
                    <span class="network-stat-label">Available</span>
                </div>
                <div class="network-stat">
                    <span class="network-stat-value">{{ total_private_ips }}</span>
                    <span class="network-stat-label">Total Capacity</span>
                </div>
            </div>
            <div class="network-bar">
                <div class="network-bar-fill private" style="width: {{ private_utilization }}%"></div>
            </div>
        </div>
        
        <!-- Colocation Network Card -->
        <div class="network-card colocation">
            <div class="network-header">
                <div class="network-title">
                    <span class="network-icon">🏢</span>
                    Colocation (66.x)
                </div>
                <div class="network-utilization 
                           {% if colocation_utilization < 60 %}utilization-low
                           {% elif colocation_utilization < 80 %}utilization-medium
                           {% else %}utilization-high{% endif %}">
                    {{ colocation_utilization }}% Used
                </div>
            </div>
            <div class="network-stats">
                <div class="network-stat">
                    <span class="network-stat-value">{{ colocation_available }}</span>
                    <span class="network-stat-label">Available</span>
                </div>
                <div class="network-stat">
                    <span class="network-stat-value">{{ total_colocation_ips }}</span>
                    <span class="network-stat-label">Total Capacity</span>
                </div>
            </div>
            <div class="network-bar">
                <div class="network-bar-fill colocation" style="width: {{ colocation_utilization }}%"></div>
            </div>
        </div>
    </div>
    
    <!-- ========== TRADITIONAL STATISTICS ========== -->
    <div class="ipam-stats">
        <div class="stat-card">
            <div class="stat-value">{{ assigned_ips }}</div>
            <div class="stat-label">Assigned IPs</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">{{ available_ips }}</div>
            <div class="stat-label">Available IPs</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">{{ reserved_ips }}</div>
            <div class="stat-label">Reserved IPs</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">{{ ranges|length }}</div>
            <div class="stat-label">IP Ranges</div>
        </div>
    </div>
    
    <!-- ========== ACTION BUTTONS ========== -->
    <div style="margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap;">
        <a href="{{ url_for('ipam.add_ip') }}" class="btn btn-primary">
            <span>➕</span> Add IP
        </a>
        <a href="{{ url_for('ipam.bulk_import') }}" class="btn btn-secondary">
            <span>📥</span> Bulk Import
        </a>
        <a href="{{ url_for('ipam.ranges') }}" class="btn btn-secondary">
            <span>📊</span> Manage Ranges
        </a>
        <button onclick="quickAddIP()" class="btn btn-secondary">
            <span>⚡</span> Quick Add
        </button>
    </div>
    
    <!-- ========== FILTERS ========== -->
    <div class="filter-bar">
        <form method="GET" action="{{ url_for('ipam.index') }}">
            <div class="filter-row">
                <div class="filter-group" style="flex: 2;">
                    <label>Search</label>
                    <input type="text" name="search" class="form-control" 
                           placeholder="IP, hostname, or description..." 
                           value="{{ current_filters.search }}">
                </div>
                
                <div class="filter-group">
                    <label>Network</label>
                    <select name="network_type" class="form-control">
                        <option value="all">All Networks</option>
                        <option value="public" {% if current_filters.network_type == 'public' %}selected{% endif %}>Public</option>
                        <option value="private" {% if current_filters.network_type == 'private' %}selected{% endif %}>Private</option>
                        <option value="management" {% if current_filters.network_type == 'management' %}selected{% endif %}>Management</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label>Type</label>
                    <select name="ip_type" class="form-control">
                        <option value="all">All Types</option>
                        <option value="management" {% if current_filters.ip_type == 'management' %}selected{% endif %}>Management</option>
                        <option value="primary" {% if current_filters.ip_type == 'primary' %}selected{% endif %}>Primary</option>
                        <option value="addon" {% if current_filters.ip_type == 'addon' %}selected{% endif %}>Add-on</option>
                        <option value="virtual" {% if current_filters.ip_type == 'virtual' %}selected{% endif %}>Virtual</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label>Status</label>
                    <select name="status" class="form-control">
                        <option value="all">All Status</option>
                        <option value="available" {% if current_filters.status == 'available' %}selected{% endif %}>Available</option>
                        <option value="assigned" {% if current_filters.status == 'assigned' %}selected{% endif %}>Assigned</option>
                        <option value="reserved" {% if current_filters.status == 'reserved' %}selected{% endif %}>Reserved</option>
                        <option value="deprecated" {% if current_filters.status == 'deprecated' %}selected{% endif %}>Deprecated</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label>Data Center</label>
                    <select name="datacenter_id" class="form-control">
                        <option value="all">All DCs</option>
                        {% for dc in datacenters %}
                        <option value="{{ dc.id }}" {% if current_filters.datacenter_id|string == dc.id|string %}selected{% endif %}>
                            {{ dc.code }} - {{ dc.name }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="filter-group">
                    <button type="submit" class="btn btn-primary">Apply Filters</button>
                </div>
            </div>
        </form>
    </div>
    
    <!-- ========== IP TABLE ========== -->
    <div class="ip-table">
        <table>
            <thead>
                <tr>
                    <th width="15%">IP Address</th>
                    <th width="10%">Type</th>
                    <th width="10%">Network</th>
                    <th width="10%">Status</th>
                    <th width="20%">Assignment</th>
                    <th width="20%">Description</th>
                    <th width="5%">VLAN</th>
                    <th width="10%">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for ip in ips %}
                <tr>
                    <td>
                        <span class="ip-address">{{ ip.ip_address }}</span>
                    </td>
                    <td>
                        <span class="ip-type-badge ip-type-{{ ip.ip_type }}">
                            {{ ip.ip_type }}
                        </span>
                    </td>
                    <td>
                        <span class="network-badge network-{{ ip.network_type }}">
                            {{ ip.network_type }}
                        </span>
                    </td>
                    <td>
                        <div class="status-indicator status-{{ ip.status }}">
                            <span class="status-dot"></span>
                            <span>{{ ip.status|title }}</span>
                        </div>
                    </td>
                    <td>
                        {% if ip.is_assigned %}
                            <strong>{{ ip.assigned_device_name }}</strong>
                        {% else %}
                            <span style="color: #6b7280;">Unassigned</span>
                        {% endif %}
                    </td>
                    <td>
                        {{ ip.description or '-' }}
                    </td>
                    <td>
                        {% if ip.vlan_id %}
                            <span style="color: #60a5fa;">{{ ip.vlan_id }}</span>
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        <div class="action-buttons">
                            <a href="{{ url_for('ipam.edit_ip', ip_id=ip.id) }}" class="btn btn-sm btn-secondary">Edit</a>
                            {% if not ip.is_assigned %}
                            <form method="POST" action="{{ url_for('ipam.delete_ip', ip_id=ip.id) }}" style="display: inline;"
                                  onsubmit="return confirm('Delete IP {{ ip.ip_address }}?')">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" style="text-align: center; padding: 40px; color: #6b7280;">
                        No IP addresses found matching your filters
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <!-- ========== PAGINATION ========== -->
    {% if pagination.pages > 1 %}
    <div style="margin-top: 20px; display: flex; justify-content: center; gap: 5px;">
        {% if pagination.has_prev %}
        <a href="{{ url_for('ipam.index', page=pagination.prev_num, **current_filters) }}" 
           class="btn btn-sm btn-secondary">← Previous</a>
        {% endif %}
        
        <span style="padding: 8px 12px; color: #8b92a5;">
            Page {{ pagination.page }} of {{ pagination.pages }}
        </span>
        
        {% if pagination.has_next %}
        <a href="{{ url_for('ipam.index', page=pagination.next_num, **current_filters) }}" 
           class="btn btn-sm btn-secondary">Next →</a>
        {% endif %}
    </div>
    {% endif %}
</div>

<script>
function quickAddIP() {
    // This would open a modal for quick IP addition
    alert('Quick Add modal would open here - implement with your preferred modal library');
}

// Auto-submit filter form on select change
document.querySelectorAll('.filter-bar select').forEach(select => {
    select.addEventListener('change', function() {
        this.closest('form').submit();
    });
});
</script>
{% endblock %}