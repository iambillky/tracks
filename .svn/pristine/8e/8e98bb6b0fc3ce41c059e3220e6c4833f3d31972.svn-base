"""
File: app.py
Purpose: Main Flask application entry point for DCMS
Version: 1.6.0
Author: DCMS Team

Revision History:
- v1.0.0: Initial Flask app setup with dark theme
- v1.0.1: Added SQLAlchemy database initialization
- v1.0.2: Integrated data center blueprint
- v1.1.0: Added network devices blueprint
- v1.2.0: Added PDU management and power profiles
- v1.3.0: Added SwitchPort model for port tracking
- v1.4.0: Added SwitchModel equipment library for automated port creation
- v1.5.0: Added IPAM models and blueprint integration
- v1.6.0: CHANGED: Added VLAN models and blueprint for Phase 1 IPAM
"""

from flask import Flask, render_template, jsonify
from flask_sqlalchemy import SQLAlchemy
from datetime import datetime
import os

# ========== APPLICATION INITIALIZATION ==========

# Initialize Flask application
app = Flask(__name__)

# ========== CONFIGURATION ==========

# Configuration
app.config['SECRET_KEY'] = 'dev-key-change-this-in-production'
app.config['DEBUG'] = True
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///dcms.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

# ========== DATABASE SETUP ==========

# Initialize database
from models.datacenter import db
db.init_app(app)

# ========== BLUEPRINT REGISTRATION ==========

# Register blueprints
from routes.datacenters import datacenters_bp
from routes.network_devices import network_devices_bp
from routes.pdus import pdus_bp

app.register_blueprint(datacenters_bp)
app.register_blueprint(network_devices_bp)
app.register_blueprint(pdus_bp)

# Register IPAM blueprint if it exists
try:
    from routes.ipam import ipam_bp
    app.register_blueprint(ipam_bp)
    ipam_enabled = True
    print("✓ IPAM blueprint registered")
except ImportError:
    ipam_enabled = False
    print("⚠ IPAM blueprint not found - skipping")

# CHANGED v1.6.0: Register VLAN blueprint for Phase 1
vlans_enabled = False
try:
    from routes.vlans import vlans_bp
    app.register_blueprint(vlans_bp)
    vlans_enabled = True
    print("✓ VLAN blueprint registered")
except ImportError:
    print("⚠ VLAN blueprint not found - skipping")

# ========== DATABASE TABLE CREATION AND INITIALIZATION ==========

# Create tables
with app.app_context():
    # Import all models to ensure they're registered with SQLAlchemy
    # IMPORTANT: The order matters for foreign key relationships!
    
    # Import IPAM models FIRST (since PDU now references ip_addresses table)
    try:
        from models.ipam import IPAddress, IPRange
        print("✓ IPAM models imported")
    except ImportError:
        print("⚠ IPAM models not found - PDU IP management will be limited")
        # If IPAM doesn't exist, we need to temporarily fix the PDU model
        # This would require removing the foreign key reference
        pass
    
    # CHANGED v1.6.0: Import VLAN models for Phase 1
    try:
        from models.vlan import VLAN, VLANSubnet
        print("✓ VLAN models imported")
    except ImportError:
        print("⚠ VLAN models not found - Phase 1 IPAM features limited")
        pass
    
    # Import core datacenter models
    from models.datacenter import DataCenter, Floor, Rack, PDU
    from models.power_profiles import PowerProfile, init_default_profiles
    from models.switch_model import SwitchModel, init_default_switch_models  # Must come before NetworkDevice
    from models.network_device import NetworkDevice  # References switch_model
    from models.switch_port import SwitchPort  # References network_device
    
    # Create all tables
    db.create_all()
    print("✓ Database tables created successfully")
    
    # Initialize default power profiles for TCH equipment
    existing_profiles = PowerProfile.query.count()
    if existing_profiles == 0:
        init_default_profiles(db.session)
        print("✓ Initialized TCH power profiles")
    else:
        print(f"✓ Power profiles already exist ({existing_profiles} profiles)")
    
    # Initialize switch equipment library with your 6 models
    existing_models = SwitchModel.query.count()
    if existing_models == 0:
        init_default_switch_models(db.session)
        print("✓ Initialized 6 switch models in equipment library")
    else:
        print(f"✓ Switch models already exist ({existing_models} models)")
    
    # Check for existing switches without ports and create them
    existing_switches = NetworkDevice.query.filter(
        NetworkDevice.device_type.in_(['Switch', 'Core'])
    ).all()
    
    if existing_switches:
        print(f"Checking {len(existing_switches)} existing switches for port creation...")
        
        for switch in existing_switches:
            # Check if this switch has ports defined
            existing_ports = SwitchPort.query.filter_by(switch_id=switch.id).count()
            
            if existing_ports == 0:
                # Create default ports for switches without them
                port_count = switch.port_count or 48  # Default to 48 if not specified
                print(f"  Creating {port_count} ports for {switch.identifier}...")
                
                from models.switch_port import create_port_range
                ports = create_port_range(switch.id, 1, port_count)
                
                for port in ports:
                    db.session.add(port)
                
                db.session.commit()
                print(f"  ✓ Created {port_count} ports for {switch.identifier}")
            else:
                print(f"  ✓ {switch.identifier} already has {existing_ports} ports")

# ========== ROUTE HANDLERS ==========

@app.route('/')
def index():
    """Home page - Dashboard"""
    # Get summary data for dashboard
    from models.datacenter import DataCenter, Rack, PDU
    from models.network_device import NetworkDevice
    from models.switch_port import SwitchPort
    
    dc_count = DataCenter.query.count()
    rack_count = Rack.query.count()
    network_device_count = NetworkDevice.query.count()
    pdu_count = PDU.query.count()
    
    # Count switches specifically
    switch_count = NetworkDevice.query.filter(
        NetworkDevice.device_type.in_(['Switch', 'Core'])
    ).count()
    
    # Count total ports
    port_count = SwitchPort.query.count()
    
    # Count connected ports
    connected_ports = SwitchPort.query.filter(
        SwitchPort.connected_device_type.isnot(None)
    ).count()
    
    # Calculate total IPs if IPAM is enabled
    ip_count = 0
    if ipam_enabled:
        try:
            from models.ipam import IPAddress
            ip_count = IPAddress.query.count()
        except:
            pass
    
    # CHANGED v1.6.0: Count VLANs if enabled
    vlan_count = 0
    if vlans_enabled:
        try:
            from models.vlan import VLAN
            vlan_count = VLAN.query.count()
        except:
            pass
    
    return render_template('index.html', 
                         title='Data Center Management System',
                         current_date=datetime.now().strftime('%B %d, %Y'),
                         current_year=datetime.now().year,
                         dc_count=dc_count,
                         rack_count=rack_count,
                         network_device_count=network_device_count,
                         pdu_count=pdu_count,
                         switch_count=switch_count,
                         port_count=port_count,
                         connected_ports=connected_ports,
                         ip_count=ip_count,
                         vlan_count=vlan_count,  # CHANGED v1.6.0
                         ipam_enabled=ipam_enabled,
                         vlans_enabled=vlans_enabled)  # CHANGED v1.6.0

# ========== API ENDPOINTS ==========

@app.route('/api/stats')
def api_stats():
    """API endpoint for dashboard statistics"""
    from models.datacenter import DataCenter, Rack, PDU
    from models.network_device import NetworkDevice
    from models.switch_port import SwitchPort
    from models.switch_model import SwitchModel
    
    stats = {
        'datacenters': DataCenter.query.count(),
        'racks': Rack.query.count(),
        'network_devices': NetworkDevice.query.count(),
        'switches': NetworkDevice.query.filter(
            NetworkDevice.device_type.in_(['Switch', 'Core'])
        ).count(),
        'pdus': PDU.query.count(),
        'switch_models': SwitchModel.query.count(),
        'total_ports': SwitchPort.query.count(),
        'connected_ports': SwitchPort.query.filter(
            SwitchPort.connected_device_type.isnot(None)
        ).count(),
        'ips': 0,  # Will be populated if IPAM is enabled
        'vlans': 0  # CHANGED v1.6.0: Will be populated if VLANs enabled
    }
    
    # Add IP count if IPAM is available
    if ipam_enabled:
        try:
            from models.ipam import IPAddress
            stats['ips'] = IPAddress.query.count()
            stats['assigned_ips'] = IPAddress.query.filter(
                IPAddress.assigned_to_type.isnot(None)
            ).count()
        except:
            pass
    
    # CHANGED v1.6.0: Add VLAN count if available
    if vlans_enabled:
        try:
            from models.vlan import VLAN, VLANSubnet
            stats['vlans'] = VLAN.query.count()
            stats['subnets'] = VLANSubnet.query.count()
        except:
            pass
    
    return jsonify(stats)

@app.route('/api/switch-models')
def api_switch_models():
    """API endpoint to get switch models for forms"""
    from models.switch_model import SwitchModel
    
    models = SwitchModel.query.order_by(
        SwitchModel.manufacturer,
        SwitchModel.model_number
    ).all()
    
    result = []
    for model in models:
        result.append({
            'id': model.id,
            'manufacturer': model.manufacturer,
            'model': model.model_number,
            'display_name': model.display_name,
            'ports': model.total_ports,
            'power': model.power_consumption_typical,
            'is_legacy': model.is_legacy
        })
    
    return jsonify(result)

@app.route('/api/switch/<int:switch_id>/port/<int:port_number>/check')
def check_switch_port(switch_id, port_number):
    """
    Check if a switch port is available for use
    Returns JSON with availability status and current device if occupied
    """
    from models.switch_port import SwitchPort
    
    # Find the switch
    switch = NetworkDevice.query.get(switch_id)
    if not switch:
        return jsonify({'error': 'Switch not found'}), 404
    
    # Find the port
    port = SwitchPort.query.filter_by(
        switch_id=switch_id,
        port_number=port_number
    ).first()
    
    if not port:
        # Port doesn't exist in database yet - it's available
        return jsonify({
            'available': True,
            'port_exists': False,
            'message': f'Port {port_number} is available'
        })
    
    # Check if port is occupied
    if port.connected_device_type:
        device_name = "Unknown"
        
        if port.connected_device_type == 'network_device':
            device = NetworkDevice.query.get(port.connected_device_id)
            if device:
                device_name = f"Switch {device.identifier}"
        elif port.connected_device_type == 'pdu':
            pdu = PDU.query.get(port.connected_device_id)
            if pdu:
                device_name = f"PDU {pdu.identifier}"
        elif port.connected_device_type == 'server':
            device_name = f"Server #{port.connected_device_id}"
        else:
            device_name = port.description or f"{port.connected_device_type} #{port.connected_device_id}"
        
        return jsonify({
            'available': False,
            'port_exists': True,
            'device_type': port.connected_device_type,
            'device_name': device_name,
            'port_type': port.port_type,
            'status': port.status,
            'message': f'Port {port_number} is in use by {device_name}'
        })
    
    # Port exists but is not connected to anything
    return jsonify({
        'available': True,
        'port_exists': True,
        'port_type': port.port_type,
        'status': port.status,
        'message': f'Port {port_number} is available'
    })


@app.route('/api/switch/<int:switch_id>/available-ports')
def get_available_ports(switch_id):
    """
    Get all available ports for a switch
    Useful for dropdown population
    """
    from models.switch_port import get_available_ports
    
    switch = NetworkDevice.query.get(switch_id)
    if not switch:
        return jsonify({'error': 'Switch not found'}), 404
    
    available_ports = get_available_ports(switch_id)
    
    return jsonify({
        'switch': switch.identifier,
        'total_ports': switch.port_count or len(switch.ports),
        'available_count': len(available_ports),
        'available_ports': [
            {
                'number': port.port_number,
                'name': port.port_name,
                'type': port.port_type
            } for port in available_ports
        ]
    })

# ========== UTILITY ROUTES ==========

@app.route('/health')
def health_check():
    """Health check endpoint"""
    return jsonify({
        'status': 'healthy',
        'timestamp': datetime.now().isoformat(),
