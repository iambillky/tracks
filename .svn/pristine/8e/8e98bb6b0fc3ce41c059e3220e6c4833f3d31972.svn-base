    print(f"VLANs: {'Enabled' if vlans_enabled else 'Disabled'}")  # CHANGED v1.6.0
    print(f"URL: http://localhost:5000")
    print("\nPress CTRL+C to stop the server")
    print("="*50 + "\n")
    
    app.run(host='0.0.0.0', port=5000, debug=True)