"""
DCMS - Data Center Management System
Main Application File
Version: 0.2.0
"""

from flask import Flask, render_template
from flask_sqlalchemy import SQLAlchemy

# Initialize Flask app
app = Flask(__name__)

# Basic config
app.config['SECRET_KEY'] = 'dev-key-change-this'
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///dcms.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

# Initialize database
db = SQLAlchemy(app)

# ============================================
# MAIN ROUTES
# ============================================

@app.route('/')
def index():
    """Main dashboard page"""
    return render_template('index.html')

# ============================================
# INFRASTRUCTURE MODULE ROUTES (Placeholders)
# ============================================

@app.route('/datacenters')
def datacenters_list():
    """List all data centers"""
    return render_template('placeholder.html', module='Data Centers', emoji='🏢')

@app.route('/datacenters/add')
def datacenters_add():
    """Add new data center"""
    return render_template('placeholder.html', module='Add Data Center', emoji='🏢')

@app.route('/floors')
def floors_list():
    """List all floors"""
    return render_template('placeholder.html', module='Floors', emoji='🏗️')

@app.route('/racks')
def racks_list():
    """List all racks"""
    return render_template('placeholder.html', module='Racks', emoji='🗄️')

@app.route('/racks/add')
def racks_add():
    """Add new rack"""
    return render_template('placeholder.html', module='Add Rack', emoji='🗄️')

