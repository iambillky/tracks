    ('infrastructure', 'Infrastructure')
]

MANUFACTURERS = [
    ('Dell', 'Dell'),
    ('HP', 'HP/HPE'),
    ('Supermicro', 'Supermicro'),
    ('IBM', 'IBM/Lenovo'),
    ('Cisco', 'Cisco UCS'),
    ('Custom', 'Custom Build'),
    ('Other', 'Other')
]

SERVER_STATUS = [
    ('active', 'Active'),
    ('maintenance', 'Maintenance'),
    ('provisioning', 'Provisioning'),
    ('decommissioned', 'Decommissioned'),
    ('failed', 'Failed'),
    ('reserved', 'Reserved')
]

IPMI_TYPES = [
