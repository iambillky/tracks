"""
File: models/server.py
Purpose: Server management model for DCMS
Version: 1.0.3
Author: DCMS Team
Date: 2025-01-18

This is the core Server model implementing the "Modified All In" approach.
Includes complete tracking for servers with IP management, network connections,
IPMI, and power - replacing the broken legacy system where everything was a "server".

Revision History:
- v1.0.0: Initial creation with complete server tracking
         Fixes legacy system issues: proper equipment typing, complete IP tracking,
         multiple network connections, IPMI management
- v1.0.1: BACKWARD COMPATIBILITY + POLISH
         - Safe aliases/properties so older routes/templates continue to work
         - ipmi_password write-through property (stores into ipmi_password_encrypted)
         - Fixed __repr__ on ServerNetworkConnection
- v1.0.2: ZERO-MIGRATION COMPAT FIX
         - Removed accidental new columns (switch_port, speed, is_active)
         - Added converters/aliases so assigning switch_port=<int> works by resolving SwitchPort
           using (switch_id, port_number) without schema changes

- v1.0.3: Added IPMI switch connectivity tracking
         - Added ipmi_switch_id and ipmi_switch_port_id fields
         - Added relationships for tracking IPMI network connections

"""

from datetime import datetime
from models.datacenter import db, Rack
from sqlalchemy import UniqueConstraint, CheckConstraint
from sqlalchemy.orm import validates
import re

# ========== CONSTANTS ==========

EQUIPMENT_TYPES = [
    ('physical_server', 'Physical Server'),
    ('blade_server', 'Blade Server'),
