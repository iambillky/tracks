POWER_CONFIGS = [
    ('single_450', 'Single 450W'),
    ('single_550', 'Single 550W'),
    ('single_750', 'Single 750W'),
    ('redundant_450', 'Redundant 450W'),
    ('redundant_550', 'Redundant 550W'),
