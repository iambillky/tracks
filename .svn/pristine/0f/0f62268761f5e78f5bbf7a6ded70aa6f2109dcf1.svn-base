        db.session.rollback()
        flash(f'Error deleting customer: {str(e)}', 'error')
    
    return redirect(url_for('servers.customers'))

# ========== API ENDPOINTS ==========

@servers_bp.route('/api/validate-id')
def validate_server_id():
    """API endpoint to validate server ID format and uniqueness"""
    server_id = request.args.get('id', '').upper()
    
    if not server_id:
        return jsonify({'is_valid': False, 'error': 'Server ID required'})
    
    # Check format
    is_valid = False
    server_type = None
    
    if server_id.startswith('COLO'):
        if re.match(r'^COLO(TCH)?\d+$', server_id):
            is_valid = True
            server_type = 'colocation'
    else:
        if re.match(r'^[A-Z]{3}-[A-Z]{3}-[A-Z]\d+$', server_id):
            is_valid = True
            server_type = 'dedicated'
    
    # Check uniqueness
    exists = Server.query.filter_by(server_id=server_id).first() is not None
    
    return jsonify({
        'server_id': server_id,
        'is_valid': is_valid,
        'exists': exists,
        'server_type': server_type,
        'available': is_valid and not exists
    })

# CHANGED v1.0.1: Added missing API endpoints for dynamic dropdowns

@servers_bp.route('/api/switches')
def api_get_switches():
    """API to get all available switches for network connections"""
    switches = NetworkDevice.query.filter_by(
        device_type='Switch',
        status='active'
    ).order_by(NetworkDevice.identifier).all()
    
    return jsonify([{
        'id': switch.id,
        'identifier': switch.identifier,
        'hostname': switch.hostname,
        'network_type': switch.network_type
    } for switch in switches])

@servers_bp.route('/api/racks/<int:datacenter_id>')
def api_get_racks(datacenter_id):
    """API to get racks for a specific datacenter"""
    racks = Rack.query.join(Floor).filter(
        Floor.datacenter_id == datacenter_id
    ).order_by(Rack.rack_id).all()
    
    return jsonify([{
        'id': rack.id,
        'rack_id': rack.rack_id,
        'u_height': rack.u_height
    } for rack in racks])

@servers_bp.route('/api/rack/<int:rack_id>/pdus')
def api_get_rack_pdus(rack_id):
    """API to get PDUs for a specific rack"""
    pdus = PDU.query.filter_by(rack_id=rack_id).all()
    
    return jsonify([{
        'id': pdu.id,
        'identifier': pdu.identifier,
        'model': pdu.model,
        'available_outlets': pdu.total_outlets - pdu.used_outlets if hasattr(pdu, 'used_outlets') else 24
    } for pdu in pdus])

@servers_bp.route('/api/rack/<int:rack_id>/space')
def api_get_rack_space(rack_id):
    """API to get available space in rack"""
    rack = Rack.query.get_or_404(rack_id)
    
    # Get all devices in rack
    servers = Server.query.filter_by(rack_id=rack_id).all()
    devices = NetworkDevice.query.filter_by(rack_id=rack_id).all()
    
    # Build occupied space map
    occupied = []
    for server in servers:
        for u in range(server.start_u, server.start_u + server.size_u):
            occupied.append(u)
    
    for device in devices:
        for u in range(device.start_u, device.start_u + device.size_u):
            occupied.append(u)
    
    # Find available positions
    available = []
    for u in range(1, rack.u_height + 1):
        if u not in occupied:
            available.append(u)
    
    return jsonify({
        'rack_id': rack.rack_id,
        'total_u': rack.u_height,
        'occupied_u': sorted(list(set(occupied))),
        'available_u': available,
        'utilization': len(set(occupied)) / rack.u_height * 100
    })

@servers_bp.route('/api/customers/active')
def api_get_active_customers():
    """API to get active customers for dropdowns"""
    customers = Customer.query.filter_by(billing_status='active').order_by(Customer.customer_name).all()
    
    return jsonify([{
        'id': customer.id,
        'name': customer.customer_name,
        'code': customer.customer_code,
        'server_count': Server.query.filter_by(customer_id=customer.id).count()
    } for customer in customers])

@servers_bp.route('/api/ips/available')
def api_get_available_ips():
    """API to get available IPs for quick assignment"""
    network_type = request.args.get('type', 'public')
    limit = request.args.get('limit', 10, type=int)
    
    ips = IPAddress.query.filter_by(
        status='available',
        network_type=network_type
    ).limit(limit).all()
    
    return jsonify([{
        'id': ip.id,
        'ip_address': ip.ip_address,
        'network_type': ip.network_type,
        'vlan': ip.vlan.vlan_id if ip.vlan else None
    } for ip in ips])

@servers_bp.route('/api/search')
def api_search():
    """Quick search API for servers"""
    query = request.args.get('q', '').strip()
    
    if not query or len(query) < 2:
        return jsonify([])
    
    search_pattern = f'%{query}%'
    servers = Server.query.filter(
        or_(
            Server.server_id.like(search_pattern),
            Server.server_name.like(search_pattern),
            Server.hostname.like(search_pattern)
        )
    ).limit(10).all()
    
    return jsonify([{
        'id': server.id,
        'server_id': server.server_id,
        'server_name': server.server_name,
        'status': server.status,
        'rack': server.rack.rack_id if server.rack else 'N/A'
    } for server in servers])

@servers_bp.route('/api/detect-vlan')
def api_detect_vlan():
    """
    API endpoint to detect VLAN from IP address
    Checks which VLAN subnet contains the given IP
    
    This endpoint exists in both servers and IPAM blueprints for convenience
    
    Returns:
        JSON with vlan_id, vlan_number, vlan_name if found
    """
    ip = request.args.get('ip', '').strip()
    
    if not ip:
        return jsonify({'error': 'No IP provided'}), 400
    
    # Validate IP format using simple regex
    import re
    ip_pattern = r'^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$'
    if not re.match(ip_pattern, ip):
        return jsonify({'error': 'Invalid IP address format'}), 400
    
    # Import ipaddress module for IP checking
    import ipaddress
    
    try:
        ip_obj = ipaddress.ip_address(ip)
        
        # Import VLAN models
        from models.vlan import VLAN, VLANSubnet
        
        # Check all VLAN subnets to find which one contains this IP
        all_subnets = VLANSubnet.query.join(VLAN).filter(
            VLAN.status == 'active'
        ).all()
        
        for subnet in all_subnets:
            # Parse the subnet CIDR
            if '/' in subnet.subnet:
                network = ipaddress.ip_network(subnet.subnet, strict=False)
                
                # Check if IP is in this subnet
                if ip_obj in network:
                    # Found the matching VLAN
                    return jsonify({
                        'found': True,
                        'vlan_id': subnet.vlan.id,  # Database ID for form value
                        'vlan_number': subnet.vlan.vlan_id,  # Actual VLAN number
                        'vlan_name': subnet.vlan.name,
                        'vlan_description': subnet.vlan.description,
                        'subnet': subnet.subnet,
                        'gateway': subnet.gateway,
                        'is_primary': subnet.is_primary
                    })
        
        # No matching VLAN found
        return jsonify({
            'found': False,
            'message': 'No VLAN found for this IP address'
        })
        
    except ValueError as e:
        return jsonify({'error': f'Invalid IP address: {str(e)}'}), 400
    except ImportError:
        # VLAN module not available
        return jsonify({
            'found': False,
            'message': 'VLAN detection not available - VLAN module not installed'
        })
    except Exception as e:
        return jsonify({'error': f'Error detecting VLAN: {str(e)}'}), 500
    
@servers_bp.route('/api/ip/check-availability')
def api_check_ip_availability():
    """
    API endpoint to check if an IP address is available
    Returns availability status and assignment info if taken
    
    CHANGED v2.0.8: Enhanced to check for IPs in add-on IPs and secondary assignments
    CHANGED v2.0.7: Added IP availability checking endpoint
    CHANGED v2.0.9: Added TCH IP validation - IP must be in VLAN subnets
    """
    ip = request.args.get('ip', '').strip()
    exclude_server_id = request.args.get('exclude_server_id')
    
    if not ip:
        return jsonify({'error': 'No IP provided'}), 400
    
    # First validate IP format
    import re
    ip_pattern = r'^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$'
    if not re.match(ip_pattern, ip):
        return jsonify({'error': 'Invalid IP address format'}), 400
    
    # NEW: Check if IP is in our VLAN subnets (TCH IP check)
    import ipaddress
    from models.vlan import VLAN, VLANSubnet
    
    try:
        ip_obj = ipaddress.ip_address(ip)
        
        # Check all VLAN subnets to see if this IP belongs to TCH
        all_subnets = VLANSubnet.query.join(VLAN).filter(
            VLAN.status == 'active'
        ).all()
        
        ip_found_in_vlan = False
        for subnet in all_subnets:
            if '/' in subnet.subnet:
                network = ipaddress.ip_network(subnet.subnet, strict=False)
                if ip_obj in network:
                    ip_found_in_vlan = True
                    break
        
        # If IP is not in any of our VLANs, reject it
        if not ip_found_in_vlan:
            return jsonify({
                'available': False,
                'error': 'to another fucking provider, moron!',
                'device_info': 'to another fucking provider, moron!'
            })
            
    except Exception as e:
        # If there's any error checking, log it but continue
        print(f"Error checking VLAN for IP {ip}: {e}")
    
    # Continue with original code - check IPAM
    from models.ipam import IPAddress
    
    # Check if IP exists in the IPAddress table
    existing_ip = IPAddress.query.filter_by(ip_address=ip).first()
    
    # First check: IP exists and is directly assigned to something
    if existing_ip and existing_ip.is_assigned:
        # If exclude_server_id is provided, check if this IP is assigned to that server
        if exclude_server_id and str(existing_ip.assigned_to_id) == str(exclude_server_id) and existing_ip.assigned_to_type == 'server':
            # This IP is assigned to the current server being edited, so it's available for this server
            return jsonify({
                'available': True,
                'message': 'IP is available (currently assigned to this server)',
                'assigned_to_self': True
            })
        
        # [Rest of the original function continues here...]
        
        # IP is assigned to something else
        return jsonify({
            'available': False,
            'assigned_to': existing_ip.assigned_device_name,
            'device_type': existing_ip.assigned_to_type,
            'device_info': f"{existing_ip.assigned_to_type}: {existing_ip.assigned_device_name}"
        })
    
    # Second check: IP might be in add-on IPs of a server
    # Even if the IP doesn't exist in the IPAddress table yet, we should check
    # if it exists as an add-on IP in any server
    
    # Query the server_ip_assignments table for this IP
    addon_assignment = db.session.query(Server) \
        .join(server_ip_assignments) \
        .join(IPAddress, IPAddress.id == server_ip_assignments.c.ip_address_id) \
        .filter(IPAddress.ip_address == ip) \
        .first()
    
    if addon_assignment:
        # If exclude_server_id is provided, check if this IP is assigned to that server
        if exclude_server_id and str(addon_assignment.id) == str(exclude_server_id):
            # This IP is an add-on for the current server being edited
            return jsonify({
                'available': True,
                'message': 'IP is available (currently an add-on for this server)',
                'assigned_to_self': True
            })
        
        # IP is an add-on for another server
        return jsonify({
            'available': False,
            'assigned_to': f"Server {addon_assignment.server_id}",
            'device_type': 'server',
            'device_info': f"Server: {addon_assignment.server_id} (add-on IP)"
        })
    
    # Third check: Primary IPs in servers might not be in the IPAddress table yet
    # Check primary_public_ip, primary_private_ip, and ipmi_ip directly in servers
    primary_ip_server = Server.query.filter(
        or_(
            db.and_(Server.primary_public_ip.has(ip_address=ip)),
            db.and_(Server.primary_private_ip.has(ip_address=ip)),
            db.and_(Server.ipmi_ip.has(ip_address=ip))
        )
    ).first()
    
    if primary_ip_server:
        # If exclude_server_id is provided, check if this IP is assigned to that server
        if exclude_server_id and str(primary_ip_server.id) == str(exclude_server_id):
            # This IP is a primary IP for the current server being edited
            return jsonify({
                'available': True,
                'message': 'IP is available (currently a primary IP for this server)',
                'assigned_to_self': True
            })
        
        # IP is a primary IP for another server
        return jsonify({
            'available': False,
            'assigned_to': f"Server {primary_ip_server.server_id}",
            'device_type': 'server',
            'device_info': f"Server: {primary_ip_server.server_id} (primary IP)"
        })
    
    # If we get here, the IP is available
    if existing_ip:
        # IP exists but not assigned
        return jsonify({
            'available': True,
            'message': 'IP is available',
            'status': existing_ip.status
        })
    else:
        # IP not in system yet
        return jsonify({
            'available': True,
            'message': 'IP is available'
        })

@servers_bp.route('/api/rack/<int:rack_id>/availability')
def api_rack_availability(rack_id):
    """API to get rack space availability for real-time checking"""
    rack = Rack.query.get_or_404(rack_id)
    
    # Get all servers in this rack
    servers = Server.query.filter_by(rack_id=rack_id).order_by(Server.start_u).all()
    
    # Get all network devices in this rack
    devices = NetworkDevice.query.filter_by(rack_id=rack_id).order_by(NetworkDevice.start_u).all()
    
    # Build usage map for each U position
    usage = {}
    for u in range(1, rack.u_height + 1):
        usage[u] = None
    
    # Mark positions used by servers
    for server in servers:
        for u in range(server.start_u, server.start_u + server.size_u):
            if u <= rack.u_height:
                usage[u] = {
                    'type': 'server',
                    'server_id': server.server_id,
                    'server_name': server.server_name
                }
    
    # Mark positions used by network devices
    for device in devices:
        if device.start_u and device.size_u:
            for u in range(device.start_u, device.start_u + device.size_u):
                if u <= rack.u_height:
                    usage[u] = {
                        'type': 'device',
                        'device_id': device.identifier,
                        'device_name': device.hostname or device.identifier
                    }
    
    # Calculate available space
    available_u = sum(1 for v in usage.values() if v is None)
    
    return jsonify({
        'rack_id': rack.rack_id,
        'total_u': rack.u_height,
        'usage': usage,
        'available_u': available_u,
        'utilization_percent': round((rack.u_height - available_u) / rack.u_height * 100, 1)
    })

@servers_bp.route('/api/switch/<int:switch_id>/port/<int:port_number>/availability')
def api_check_port_availability(switch_id, port_number):
    """
    API endpoint to check if a specific switch port is available
    
    CHANGED v1.0.3: Added missing endpoint for port availability checking
    Fixed to use correct SwitchPort model attributes
    """
    # Check if the port exists
    port = SwitchPort.query.filter_by(
        switch_id=switch_id,
        port_number=port_number
    ).first()
    
    if not port:
        return jsonify({
            'error': f'Port {port_number} does not exist on this switch'
        }), 404
    
    # Check if port is already connected (using connected_device_type, not is_connected)
    if port.connected_device_type:
        device_info = port.connected_device_name or f"{port.connected_device_type} #{port.connected_device_id}"
        return jsonify({
            'available': False,
            'used_by': port.connected_device_name,
            'device_info': device_info,
            'device_type': port.connected_device_type
        })
    
    # Check if port is disabled
    if port.status == 'disabled':
        return jsonify({
            'available': False,
            'device_info': 'Port is disabled',
            'status': 'disabled'
        })
    
    return jsonify({
        'available': True,
        'port_type': port.port_type,
        'speed': port.port_speed
    })

@servers_bp.route('/api/pdu/<int:pdu_id>/outlet/<int:outlet>/availability')
def api_check_outlet_availability(pdu_id, outlet):
    """
    API endpoint to check if a specific PDU outlet is available
    
    CHANGED v1.0.3: Added missing endpoint for PDU outlet availability checking
    """
    pdu = PDU.query.get(pdu_id)
    
    if not pdu:
        return jsonify({'error': 'PDU not found'}), 404
    
    # Check if outlet number is valid
    if outlet < 1 or outlet > pdu.total_outlets:
        return jsonify({
            'error': f'Outlet {outlet} is invalid. PDU has outlets 1-{pdu.total_outlets}'
        })
    
    # Check if outlet is already assigned to a server
    existing_server = Server.query.filter(
        or_(
            and_(Server.pdu_1_id == pdu_id, Server.pdu_1_outlet == outlet),
            and_(Server.pdu_2_id == pdu_id, Server.pdu_2_outlet == outlet)
        )
    ).first()
    
    if existing_server:
        return jsonify({
            'available': False,
            'device_info': f"Server {existing_server.server_id}",
            'device_type': 'server'
        })
    
    # Check if outlet is assigned to a network device
    from models.network_device import NetworkDevice
    existing_device = NetworkDevice.query.filter(
        or_(
            and_(NetworkDevice.pdu_1_id == pdu_id, NetworkDevice.pdu_1_outlet == outlet),
            and_(NetworkDevice.pdu_2_id == pdu_id, NetworkDevice.pdu_2_outlet == outlet)
        )
    ).first()
    
    if existing_device:
        return jsonify({
            'available': False,
            'device_info': f"Network Device {existing_device.identifier}",
            'device_type': 'network_device'
        })
    
    return jsonify({
        'available': True,
        'pdu_identifier': pdu.identifier,
        'outlet': outlet
    })