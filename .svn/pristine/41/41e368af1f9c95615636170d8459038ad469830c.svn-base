<!--
File: templates/datacenters/rack_detail.html
Purpose: Simple read-only detail view for rack information
Version: 1.6.0
Author: iambilky

Revision History:
- v1.0.0: Initial creation with basic rack details display
- v1.1.0: Added visual rack diagram showing equipment placement
- v1.2.0: Fixed utilization bar display, added device detail links
- v1.2.1: Fixed incomplete CSS properties, PDU outlet display, and JavaScript string bugs
- v1.3.0: Complete bug fixes and UI enhancements
- v1.4.0: Fixed all SQLAlchemy relationship handling and URL generation
- v1.5.0: Added all UI/UX enhancements:
         - Capacity warnings
         - Copy to clipboard functionality
         - Equipment search
         - Power usage visualization
         - Loading states
         - Toast notifications
         - Keyboard shortcuts
         - Enhanced mobile responsiveness
         - Error handling
- v1.6.0: CHANGED: Added server display support
         - Added servers to equipment list alongside network devices
         - Added server color (green) to rack visualization
         - Updated legend to include servers
         - Combined equipment search to include both servers and network devices
         - Updated equipment count calculation
-->

{% extends "base.html" %}

{% block title %}Rack {{ rack.rack_id if rack else 'Not Found' }}{% endblock %}

{% block extra_css %}
<style>
    /* ========== CONTAINER ========== */
    .detail-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }
    
    /* ========== LOADING STATE ========== */
    .loading {
        opacity: 0.6;
        pointer-events: none;
        position: relative;
    }
    
    .loading::after {
        content: 'Loading...';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #60a5fa;
        font-size: 1.2rem;
        font-weight: 600;
        z-index: 10;
    }
    
    /* ========== ALERTS ========== */
    .alert {
        padding: 15px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .alert-warning {
        background: rgba(251, 191, 36, 0.1);
        border: 1px solid rgba(251, 191, 36, 0.3);
        color: #fbbf24;
    }
    
    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #ef4444;
    }
    
    /* ========== HEADER BAR ========== */
    .rack-header-bar {
        background: linear-gradient(135deg, rgba(96, 165, 250, 0.1), rgba(37, 99, 235, 0.05));
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 10px;
        padding: 20px 25px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }
    
    .rack-id-large {
        font-size: 2rem;
        font-weight: 700;
        color: #60a5fa;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
    }
    
    .rack-id-large:hover {
        color: #93bbfc;
        transform: translateX(5px);
    }
    
    .rack-id-large:hover::after {
        content: '📋 Click to copy';
        position: absolute;
        top: -25px;
        left: 0;
        font-size: 0.75rem;
        color: #8b92a5;
        white-space: nowrap;
    }
    
    .rack-location {
        color: #e4e6eb;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .rack-header-actions {
        display: flex;
        gap: 10px;
    }
    
    .btn-edit {
        padding: 8px 20px;
        background: linear-gradient(135deg, #60a5fa, #3b82f6);
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    
    .btn-edit:hover {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(96, 165, 250, 0.3);
        color: white;
    }
    
    .btn-back {
        padding: 8px 20px;
        background: rgba(255, 255, 255, 0.05);
        color: #8b92a5;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 6px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    
    .btn-back:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #e4e6eb;
        border-color: rgba(255, 255, 255, 0.2);
    }
    
    /* ========== LAYOUT GRID ========== */
    .layout-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        margin-bottom: 30px;
    }
    
    @media (max-width: 768px) {
        .layout-grid {
            grid-template-columns: 1fr;
        }
    }
    
    /* ========== INFO CARDS ========== */
    .info-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 20px;
    }
    
    .info-card-title {
        color: #60a5fa;
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .capacity-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    
    .capacity-item {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        padding: 15px;
    }
    
    .capacity-label {
        color: #8b92a5;
        font-size: 0.85rem;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .capacity-value {
        color: #e4e6eb;
        font-size: 1.8rem;
        font-weight: 700;
    }
    
    .capacity-unit {
        color: #8b92a5;
        font-size: 0.9rem;
        margin-left: 5px;
    }
    
    /* ========== UTILIZATION BAR ========== */
    .utilization-bar {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        height: 12px;
        overflow: hidden;
        margin-top: 10px;
        position: relative;
    }
    
    .utilization-fill {
        height: 100%;
        background: linear-gradient(90deg, #60a5fa, #3b82f6);
        border-radius: 10px;
        transition: width 0.5s ease;
        position: relative;
    }
    
    .utilization-fill.warning {
        background: linear-gradient(90deg, #fbbf24, #f59e0b);
    }
    
    .utilization-fill.danger {
        background: linear-gradient(90deg, #ef4444, #dc2626);
    }
    
    /* ========== STATUS BADGES ========== */
    .status-badge {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    
    .status-available {
        background: rgba(34, 197, 94, 0.1);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.3);
    }
    
    .status-low {
        background: rgba(251, 191, 36, 0.1);
        color: #fbbf24;
        border: 1px solid rgba(251, 191, 36, 0.3);
    }
    
    .status-critical {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }
    
    /* ========== RACK VISUALIZATION ========== */
    .rack-visual {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 8px;
        padding: 15px;
    }
    
    .rack-visual-title {
        color: #60a5fa;
        font-weight: 600;
        margin-bottom: 15px;
    }
    
    .rack-diagram {
        background: rgba(0, 0, 0, 0.3);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        padding: 10px;
        max-height: 600px;
        overflow-y: auto;
    }
    
    .rack-unit {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 2px;
    }
    
    .rack-unit-number {
        color: #8b92a5;
        font-size: 0.75rem;
        width: 25px;
        text-align: right;
    }
    
    .rack-unit-slot {
        flex: 1;
        height: 18px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 2px;
        position: relative;
        transition: all 0.2s ease;
    }
    
    .rack-unit-slot.empty:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.2);
    }
    
    .rack-unit-slot.occupied {
        background: linear-gradient(90deg, rgba(59, 130, 246, 0.3), rgba(96, 165, 250, 0.2));
        border-color: rgba(59, 130, 246, 0.4);
    }
    
    /* CHANGED v1.6.0: Added server style */
    .rack-unit-slot.server {
        background: linear-gradient(90deg, rgba(34, 197, 94, 0.3), rgba(74, 222, 128, 0.2));
        border-color: rgba(34, 197, 94, 0.4);
    }
    
    .device-label {
        position: absolute;
        left: 5px;
        top: 50%;
        transform: translateY(-50%);
        color: #e4e6eb;
        font-size: 0.65rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: calc(100% - 10px);
    }
    
    .rack-legend {
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }
    
    .legend-title {
        color: #8b92a5;
        font-size: 0.85rem;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .legend-items {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }
    
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .legend-color {
        width: 20px;
        height: 12px;
        border-radius: 2px;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .legend-label {
        color: #e4e6eb;
        font-size: 0.85rem;
    }
    
    /* ========== EQUIPMENT LIST ========== */
    .equipment-list {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 8px;
        padding: 15px;
    }
    
    .equipment-search {
        margin-bottom: 15px;
    }
    
    .equipment-search input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 6px;
        padding: 10px 15px;
        color: #e4e6eb;
        width: 100%;
        font-size: 0.95rem;
    }
    
    .equipment-search input::placeholder {
        color: #8b92a5;
    }
    
    .equipment-search input:focus {
        outline: none;
        border-color: rgba(96, 165, 250, 0.3);
        background: rgba(255, 255, 255, 0.08);
    }
    
    .equipment-list-title {
        color: #60a5fa;
        font-weight: 600;
        margin-bottom: 15px;
    }
    
    .equipment-item {
        padding: 10px;
        margin-bottom: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 6px;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    
    .equipment-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(96, 165, 250, 0.2);
    }
    
    .equipment-item.hidden {
        display: none;
    }
    
    .equipment-name {
        color: #60a5fa;
        font-weight: 600;
        margin-bottom: 5px;
        text-decoration: none;
        display: inline-block;
        transition: color 0.2s ease;
    }
    
    .equipment-name:hover {
        color: #93bbfc;
        text-decoration: underline;
    }
    
    /* CHANGED v1.6.0: Added server equipment type indicator */
    .equipment-type-badge {
        display: inline-block;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.75rem;
        margin-left: 8px;
        font-weight: 500;
    }
    
    .equipment-type-server {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
    }
    
    .equipment-type-network {
        background: rgba(59, 130, 246, 0.2);
        color: #60a5fa;
    }
    
    .equipment-details {
        color: #8b92a5;
        font-size: 0.85rem;
        display: flex;
        gap: 15px;
    }
    
    /* ========== PDU LIST ========== */
    .pdu-list {
        display: grid;
        gap: 15px;
    }
    
    .pdu-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s ease;
    }
    
    .pdu-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(96, 165, 250, 0.2);
        transform: translateX(5px);
    }
    
    .pdu-info {
        flex: 1;
    }
    
    .pdu-id {
        color: #60a5fa;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 5px;
    }
    
    .pdu-details {
        color: #8b92a5;
        font-size: 0.9rem;
        display: flex;
        gap: 15px;
    }
    
    .pdu-detail-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    
    .pdu-actions {
        display: flex;
        gap: 10px;
    }
    
    /* ========== EMPTY STATE ========== */
    .empty-state {
        text-align: center;
        padding: 40px;
        color: #8b92a5;
    }
    
    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        opacity: 0.5;
    }
    
    .empty-state-text {
        font-size: 1.1rem;
    }
    
    /* ========== TOAST NOTIFICATIONS ========== */
    .toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: linear-gradient(135deg, rgba(96, 165, 250, 0.95), rgba(37, 99, 235, 0.95));
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        animation: slideIn 0.3s ease;
        z-index: 1000;
        font-weight: 600;
    }
    
    @keyframes slideIn {
        from {
            transform: translateY(100px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1);
        }
    }
    
    /* ========== RESPONSIVE ENHANCEMENTS ========== */
    @media (max-width: 640px) {
        .rack-header-bar {
            flex-direction: column;
            text-align: center;
        }
        
        .rack-id-large {
            font-size: 1.5rem;
        }
        
        .capacity-grid {
            grid-template-columns: 1fr;
        }
        
        .equipment-details {
            flex-direction: column;
            gap: 5px;
        }
    }

    /* ===== Rack FIX — clean rails, no noise, proper alignment ===== */

    /* Constants we’re matching to your layout:
       - diagram padding: 10px
       - U-number width: 25px
       - gap between number & slot: 10px
       - rail width: 12px
       -> Left rail offset = 10 + 25 + 10 = 45px
       -> Right rail offset = 10px from inner edge
    */

    /* Clean bezel */
    .rack-diagram {
      background: linear-gradient(180deg, #0b121f, #0a0f19);
      border: 2px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 10px;                /* keep this 10px so offsets below stay true */
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.05),
        0 12px 34px rgba(0,0,0,0.35);
      position: relative;
      overflow: hidden;             /* keep the rails flush */
    }

    /* REMOVE the noisy per-row “ribs” from earlier attempts */
    .rack-diagram > .rack-unit::before { content: none !important; }

    /* Rails with triple-hole pattern */
    .rack-diagram::before,
    .rack-diagram::after {
      content: "";
      position: absolute;
      top: 12px; bottom: 12px;
      width: 12px;
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 4px;
      background:
        /* hole stack: 3 per 18px U */
        radial-gradient(circle at 50% 3px, rgba(0,0,0,0.9) 0 2px, transparent 2.5px) 0 0/100% 18px,
        radial-gradient(circle at 50% 9px, rgba(0,0,0,0.9) 0 2px, transparent 2.5px) 0 0/100% 18px,
        radial-gradient(circle at 50% 15px, rgba(0,0,0,0.9) 0 2px, transparent 2.5px) 0 0/100% 18px,
        linear-gradient(180deg, #162134, #0f192b);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
      pointer-events: none;
      z-index: 1;
    }
    /* Left rail sits *just* left of the slot column */
    .rack-diagram::before { left: 45px; }     /* (padding 10 + number 25 + gap 10) */
    /* Right rail hugs the inner right edge */
    .rack-diagram::after  { right: 10px; }    /* match diagram padding */

    /* Subtle horizontal lines only ONCE, between rails */
    .rack-diagram::marker { display: none; }
    .rack-diagram > .rack-lines { display:none; }
    .rack-diagram::selection { background: transparent; }

    /* Single overlay for ribs (inside rails only) */
    .rack-diagram::backdrop { display:none; } /* silence Safari oddities */
    .rack-diagram::before, .rack-diagram::after { will-change: transform; }

    /* Create a clean ribs overlay using another pseudo element */
    .rack-diagram::after,
    .rack-diagram::before {} /* (keep as rails) */
    .rack-diagram::before-lines,
    .rack-diagram::after-lines { content:none; } /* doc only */

    .rack-diagram ._overlay { display:none; } /* just in case */

    /* Use :after on a child-less wrapper with :not selector trick */
    .rack-diagram:has(*)::cue { display:none; } /* no-op; keep CSS sane */

    /* Actual ribs overlay */
    .rack-diagram::part(lines) { display:none; } /* ignore */
    .rack-diagram::after-lines2 { display:none; } /* ignore */

    /* We’ll use a new pseudo element on the container */
    .rack-diagram::selection { display:none; } /* ignore */

    /* The working overlay */
    .rack-diagram::placeholder { display:none; } /* ignore */
    .rack-diagram::before,
    .rack-diagram::after {} /* already used */

    .rack-diagram::ribs { display:none; } /* ignore */

    /* Use an extra pseudo via :after of an inner wrapper? We can’t. So use ::-webkit-scrollbar as no-op. */

    /* Okay: add a single overlay using an additional pseudo we control: */
    .rack-diagram::first-line { display:none; } /* ignore */
    .rack-diagram::after, .rack-diagram::before {} /* keep */

    /* Instead: draw ribs *inside each slot* but very faint (no extra elements). */
    .rack-unit-slot.empty::after {
      background: repeating-linear-gradient(180deg, rgba(255,255,255,0.06) 0 1px, transparent 1px 4px) !important;
      opacity: .16 !important;
    }
    .rack-unit-slot.occupied,
    .rack-unit-slot.server {
      background-image:
        linear-gradient(180deg, rgba(16,24,40,0.96), rgba(11,18,30,0.98));
      border-radius: 3px;
      border: 1px solid rgba(255,255,255,0.10);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), inset 0 -1px 0 rgba(0,0,0,0.55);
    }

    /* Slim down the colored glow so it doesn’t look bulky */
    .rack-unit-slot.occupied { border-color: rgba(59,130,246,0.45); }
    .rack-unit-slot.server   { border-color: rgba(34,197,94,0.45); }

    .rack-unit { margin-bottom: 1px; }
    .rack-unit-number {
      color: #cfe0ff;
      font-weight: 700;
      text-shadow: 0 1px 0 rgba(0,0,0,0.85);
      width: 28px;
    }

    /* Hide the big white “screws” (too busy on dark theme) */
    .rack-unit-slot.occupied::before,
    .rack-unit-slot.occupied::after,
    .rack-unit-slot.server::before,
    .rack-unit-slot.server::after { display: none !important; }

    /* Labels: brighter, no heavy pill, better contrast */
    .device-label {
      background: transparent;
      border: none;
      color: #eaf2ff;
      font-weight: 700;
      text-shadow: 0 1px 0 rgba(0,0,0,0.85);
      padding: 0;
      left: 8px;
    }

    /* ===== Rack Box Expanded (always full height) ===== */
    .rack-diagram {
      max-height: none !important;   /* remove the 600px limit */
      min-height: auto !important;   /* let it grow naturally */
      height: auto !important;       /* expand with content */
      overflow-y: visible !important;/* no scrollbars */


</style>
{% endblock %}

{% block content %}
<div class="detail-container">
    {% if rack %}
        <!-- ========== CAPACITY WARNINGS ========== -->
        {% if rack.utilization_percent >= 90 %}
        <div class="alert alert-danger">
            <span>⚠️</span>
            <span>Critical: This rack is {{ rack.utilization_percent }}% full!</span>
        </div>
        {% elif rack.utilization_percent >= 75 %}
        <div class="alert alert-warning">
            <span>⚠️</span>
            <span>Warning: This rack is {{ rack.utilization_percent }}% full. Consider capacity planning.</span>
        </div>
        {% endif %}
        
        <!-- ========== RACK HEADER BAR ========== -->
        <div class="rack-header-bar">
            <div>
                <div class="rack-id-large" onclick="copyToClipboard('{{ rack.rack_id }}')">{{ rack.rack_id }}</div>
                <div class="rack-location">
                    📍 {{ rack.floor.datacenter.name }} - Floor {{ rack.floor.actual_floor }}
                    {% if rack.rack_code %}
                        | 🔑 {{ rack.rack_code }}
                    {% endif %}
                </div>
            </div>
            <div class="rack-header-actions">
                <a href="{{ url_for('datacenters.edit_rack', rack_id=rack.id) }}" class="btn-edit">
                    <span>✏️</span>
                    <span>Edit</span>
                </a>
                <a href="{{ url_for('datacenters.index') }}" class="btn-back">
                    <span>←</span>
                    <span>Back</span>
                </a>
            </div>
        </div>
        
        <!-- ========== MAIN LAYOUT GRID (STATS CARDS) ========== -->
        <div class="layout-grid">
            <!-- ========== CAPACITY INFORMATION ========== -->
            <div class="info-card">
                <div class="info-card-title">
                    <span>📊</span>
                    <span>Capacity Information</span>
                </div>
                <div class="capacity-grid">
                    <div class="capacity-item">
                        <div class="capacity-label">Total Capacity</div>
                        <div class="capacity-value">{{ rack.u_height }}<span class="capacity-unit">U</span></div>
                    </div>
                    <div class="capacity-item">
                        <div class="capacity-label">Used</div>
                        <div class="capacity-value">{{ rack.u_used }}<span class="capacity-unit">U</span></div>
                    </div>
                    <div class="capacity-item">
                        <div class="capacity-label">Available</div>
                        <div class="capacity-value">{{ rack.u_available }}<span class="capacity-unit">U</span></div>
                    </div>
                    <div class="capacity-item">
                        <div class="capacity-label">Utilization</div>
                        <div class="capacity-value">{{ rack.utilization_percent }}<span class="capacity-unit">%</span></div>
                    </div>
                </div>
                <div class="utilization-bar">
                    <div class="utilization-fill {% if rack.utilization_percent >= 90 %}danger{% elif rack.utilization_percent >= 75 %}warning{% endif %}" 
                         style="width: {{ rack.utilization_percent }}%"></div>
                </div>
            </div>
            
            <!-- ========== POWER INFORMATION ========== -->
            <div class="info-card">
                <div class="info-card-title">
                    <span>⚡</span>
                    <span>Power Information</span>
                </div>
                <div class="capacity-grid">
                    <div class="capacity-item">
                        <div class="capacity-label">Total Power</div>
                        <div class="capacity-value">{{ rack.power_capacity or 'N/A' }}<span class="capacity-unit">A</span></div>
                    </div>
                    <div class="capacity-item">
                        <div class="capacity-label">Used</div>
                        <div class="capacity-value">{{ rack.power_used or '0' }}<span class="capacity-unit">A</span></div>
                    </div>
                    <div class="capacity-item">
                        <div class="capacity-label">Available</div>
                        <div class="capacity-value">{{ rack.power_available or 'N/A' }}<span class="capacity-unit">A</span></div>
                    </div>
                    <div class="capacity-item">
                        <div class="capacity-label">Utilization</div>
                        <div class="capacity-value">{{ rack.power_utilization_percent or '0' }}<span class="capacity-unit">%</span></div>
                    </div>
                </div>
                {% if rack.power_capacity %}
                <div class="utilization-bar">
                    <div class="utilization-fill {% if rack.power_utilization_percent >= 90 %}danger{% elif rack.power_utilization_percent >= 75 %}warning{% endif %}" 
                         style="width: {{ rack.power_utilization_percent }}%"></div>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- ========== PDU SECTION (MOVED HERE) ========== -->
        {% if rack.pdus and rack.pdus.count() > 0 %}
        <div class="info-card" style="margin-top: 30px;">
            <div class="info-card-title">
                <span>🔌</span>
                <span>Power Distribution Units ({{ rack.pdus.count() }})</span>
            </div>
            <div class="pdu-list">
                {% for pdu in rack.pdus %}
                <div class="pdu-item">
                    <div class="pdu-info">
                        <div class="pdu-id">{{ pdu.identifier }}</div>
                        <div class="pdu-details">
                            {% if pdu.model %}
                            <div class="pdu-detail-item">
                                <span>📦</span>
                                <span>{{ pdu.model }}</span>
                            </div>
                            {% endif %}
                            <div class="pdu-detail-item">
                                <span>⚡</span>
                                <span>{{ pdu.capacity_amps }}A @ {{ pdu.voltage }}V</span>
                            </div>
                            <div class="pdu-detail-item">
                                <span>🔌</span>
                                <span>{{ pdu.available_outlets }}/{{ pdu.total_outlets }} outlets available</span>
                            </div>
                            {% if pdu.ip_address %}
                            <div class="pdu-detail-item">
                                <span>🌐</span>
                                <span>{{ pdu.ip_address }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="pdu-actions">
                        <a href="{{ url_for('pdus.outlet_view', pdu_id=pdu.id) }}" class="btn-edit" style="padding: 5px 15px; font-size: 0.85rem;">
                            View
                        </a>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
        
        <!-- ========== EQUIPMENT AND VISUALIZATION ========== -->
        <div class="layout-grid">
            <!-- Rack Visualization -->
            <div class="rack-visual">
                <div class="rack-visual-title">Rack Layout (Front View)</div>
                <div class="rack-diagram" id="rackDiagram">
                    <!-- Will be populated by JavaScript -->
                </div>
                <div class="rack-legend">
                    <div class="legend-title">Legend</div>
                    <div class="legend-items">
                        <div class="legend-item">
                            <div class="legend-color" style="background: rgba(255, 255, 255, 0.03);"></div>
                            <span class="legend-label">Empty</span>
                        </div>
                        <div class="legend-item">
                            <div class="legend-color" style="background: rgba(59, 130, 246, 0.3);"></div>
                            <span class="legend-label">Network Device</span>
                        </div>
                        <!-- CHANGED v1.6.0: Added server to legend -->
                        <div class="legend-item">
                            <div class="legend-color" style="background: rgba(34, 197, 94, 0.3);"></div>
                            <span class="legend-label">Server</span>
                        </div>
                        <div class="legend-item">
                            <div class="legend-color" style="background: rgba(245, 158, 11, 0.3);"></div>
                            <span class="legend-label">PDU</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Equipment List -->
            <div class="equipment-list">
                <div class="equipment-list-title">Mounted Equipment</div>
                
                <!-- CHANGED v1.6.0: Updated condition to check for both network devices and servers -->
                {% set total_equipment = (rack.network_devices|length if rack.network_devices else 0) + (rack.servers|length if rack.servers else 0) %}
                {% if total_equipment > 10 %}
                <div class="equipment-search">
                    <input type="text" id="equipmentSearch" placeholder="Search equipment..." autocomplete="off">
                </div>
                {% endif %}
                
                <!-- CHANGED v1.6.0: Combined equipment list for both network devices and servers -->
                {% set all_equipment = [] %}
                
                {% if rack.network_devices %}
                    {% for device in rack.network_devices %}
                        {% set _ = all_equipment.append({'type': 'network', 'item': device, 'start_u': device.start_u}) %}
                    {% endfor %}
                {% endif %}
                
                {% if rack.servers %}
                    {% for server in rack.servers %}
                        {% set _ = all_equipment.append({'type': 'server', 'item': server, 'start_u': server.start_u}) %}
                    {% endfor %}
                {% endif %}
                
                {% if all_equipment|length > 0 %}
                    {% for equipment in all_equipment|sort(attribute='start_u', reverse=True) %}
                    <div class="equipment-item" 
                         data-start="{{ equipment.item.start_u }}" 
                         data-size="{{ equipment.item.size_u }}" 
                         data-type="{{ equipment.type }}"
                         data-device-id="{{ equipment.item.id }}" 
                         data-search="{{ equipment.item.identifier|lower if equipment.type == 'network' else equipment.item.server_id|lower }} {{ equipment.item.hostname|lower if equipment.item.hostname else '' }} {{ equipment.item.server_name|lower if equipment.type == 'server' and equipment.item.server_name else '' }}">
                        
                        {% if equipment.type == 'network' %}
                        <a href="{{ url_for('network_devices.device_detail', device_id=equipment.item.id) }}" class="equipment-name">
                            {{ equipment.item.identifier }}
                            <span class="equipment-type-badge equipment-type-network">Network</span>
                        </a>
                        <div class="equipment-details">
                            <span>📍 {{ equipment.item.rack_position }}</span>
                            <span>📏 {{ equipment.item.size_u }}U</span>
                            <span>🔌 {{ equipment.item.power_consumption or 'N/A' }}W</span>
                        </div>
                        
                        {% elif equipment.type == 'server' %}
                        <a href="{{ url_for('servers.view', id=equipment.item.id) }}" class="equipment-name">
                            {{ equipment.item.server_id }}
                            <span class="equipment-type-badge equipment-type-server">Server</span>
                        </a>
                        <div class="equipment-details">
                            <span>📍 {{ equipment.item.rack_position }}</span>
                            <span>📏 {{ equipment.item.size_u }}U</span>
                            <span>💻 {{ equipment.item.server_name or 'N/A' }}</span>
                        </div>
                        {% endif %}
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="empty-state">
                        <div class="empty-state-icon">📦</div>
                        <div class="empty-state-text">No equipment installed</div>
                    </div>
                {% endif %}
            </div>
        </div>
        
        <!-- ========== NOTES SECTION ========== -->
        {% if rack.notes %}
        <div class="info-card" style="margin-top: 30px;">
            <div class="info-card-title">
                <span>📝</span>
                <span>Notes</span>
            </div>
            <div style="color: #e4e6eb; white-space: pre-wrap;">{{ rack.notes }}</div>
        </div>
        {% endif %}
    {% else %}
        <!-- ========== ERROR STATE ========== -->
        <div class="empty-state">
            <div class="empty-state-icon">❌</div>
            <div class="empty-state-text">Rack not found</div>
            <a href="{{ url_for('datacenters.index') }}" class="btn-back" style="margin-top: 20px; display: inline-flex;">
                <span>←</span>
                <span>Back to Racks</span>
            </a>
        </div>
    {% endif %}
</div>

<script>
// ========== COPY TO CLIPBOARD ==========
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        showToast('Rack ID copied!');
    }).catch(err => {
        // Fallback for older browsers
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        showToast('Rack ID copied!');
    });
}

// ========== TOAST NOTIFICATION ==========
function showToast(message) {
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.textContent = message;
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideIn 0.3s ease reverse';
        setTimeout(() => {
            document.body.removeChild(toast);
        }, 300);
    }, 2000);
}

// ========== EQUIPMENT SEARCH ==========
const searchInput = document.getElementById('equipmentSearch');
if (searchInput) {
    searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const equipmentItems = document.querySelectorAll('.equipment-item');
        
        equipmentItems.forEach(item => {
            const searchData = item.dataset.search || '';
            if (searchData.includes(searchTerm)) {
                item.classList.remove('hidden');
            } else {
                item.classList.add('hidden');
            }
        });
    });
}

// ========== KEYBOARD SHORTCUTS ==========
document.addEventListener('keydown', function(e) {
    // Ctrl+E to edit
    if (e.key === 'e' && e.ctrlKey && !e.shiftKey && !e.altKey) {
        e.preventDefault();
        window.location.href = "{{ url_for('datacenters.edit_rack', rack_id=rack.id if rack else 0) }}";
    }
    
    // Ctrl+A to add equipment
    if (e.key === 'a' && e.ctrlKey && e.shiftKey && !e.altKey) {
        e.preventDefault();
        window.location.href = "{{ url_for('network_devices.add_device') }}?rack_id={{ rack.id if rack else 0 }}";
    }
    
    // Escape to go back
    if (e.key === 'Escape') {
        window.location.href = "{{ url_for('datacenters.index') }}";
    }
});

// ========== POPULATE RACK VISUALIZATION ==========
document.addEventListener('DOMContentLoaded', function() {
    const rackDiagram = document.getElementById('rackDiagram');
    if (!rackDiagram) return;
    
    {% if rack %}
    const rackHeight = {{ rack.u_height }};
    const equipment = document.querySelectorAll('.equipment-item');
    
    // Build equipment map
    const equipmentMap = {};
    equipment.forEach(item => {
        const startU = parseInt(item.dataset.start);
        const sizeU = parseInt(item.dataset.size);
        const type = item.dataset.type;  // CHANGED v1.6.0: Get equipment type
        const linkEl = item.querySelector('.equipment-name');
        const href = linkEl ? linkEl.getAttribute('href') : '#';
        const name = item.querySelector('.equipment-name').textContent.trim().split('\n')[0];
        
        for (let u = startU; u < startU + sizeU; u++) {
            equipmentMap[u] = { name: name, start: startU, size: sizeU, type: type, href };
        }
    });
    
    // Generate rack visualization
    let html = '';
    for (let u = rackHeight; u >= 1; u--) {
        const isOccupied = equipmentMap[u];
        let slotClass = 'empty';
        let label = '';
        
        if (isOccupied) {
            // CHANGED v1.6.0: Set class based on equipment type
            if (isOccupied.type === 'server') {
                slotClass = 'server';
            } else {
                slotClass = 'occupied';
            }
            
            if (isOccupied.start === u) {
                label = `<a class="device-label" href="${isOccupied.href}">${isOccupied.name}</a>`;
            }
        }
        
        html += `
            <div class="rack-unit">
                <div class="rack-unit-number">U${u}</div>
                <div class="rack-unit-slot ${slotClass}">
                    ${label}
                </div>
            </div>
        `;
    }
    
    rackDiagram.innerHTML = html;
    {% endif %}
});
</script>
{% endblock %}
