/* 
 * DCMS - Main Stylesheet
 * Version: 1.0.0
 */

/* Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    background-color: #0a0a0f;
    color: #e2e8f0;
    line-height: 1.6;
    display: flex;
    min-height: 100vh;
}

/* Layout Container */
.app-container {
    display: flex;
    width: 100%;
}

/* Sidebar Navigation */
.sidebar {
    width: 260px;
    background-color: #1a1a2e;
    border-right: 1px solid #2d2d3d;
    position: fixed;
    height: 100vh;
    overflow-y: auto;
}

.sidebar-header {
    padding: 1.5rem;
    border-bottom: 1px solid #2d2d3d;
}

.sidebar-header h1 {
    color: #60a5fa;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.nav-menu {
    padding: 1rem 0;
}

.nav-section {
    margin-bottom: 2rem;
}

.nav-section-title {
    padding: 0.5rem 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64748b;
    font-weight: 600;
}

.nav-menu ul {
    list-style: none;
}

.nav-menu a {
    color: #94a3b8;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: all 0.2s;
}

.nav-menu a:hover {
    color: #60a5fa;
    background-color: #16213e;
}

.nav-menu a.active {
    color: #60a5fa;
    background-color: #16213e;
    border-left: 3px solid #60a5fa;
}

.nav-icon {
    font-size: 1.25rem;
    width: 24px;
    text-align: center;
}

/* Main Content Area */
.main-content {
    margin-left: 260px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.top-header {
    background-color: #1a1a2e;
    border-bottom: 1px solid #2d2d3d;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.page-title {
    font-size: 1.25rem;
    color: #e2e8f0;
}

.header-actions {
    display: flex;
    gap: 1rem;
}

.content {
    padding: 2rem;
    flex: 1;
    overflow-y: auto;
}

/* Cards */
.card {
    background-color: #1a1a2e;
    border: 1px solid #2d2d3d;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.card h2 {
    color: #60a5fa;
    font-size: 1.25rem;
}

.card h3 {
    color: #e2e8f0;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
}

/* Buttons */
.btn {
    background-color: #60a5fa;
    color: #0a0a0f;
    border: none;
    padding: 0.5rem 1.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 500;
    transition: background-color 0.3s;
    text-decoration: none;
    display: inline-block;
}

.btn:hover {
    background-color: #3b82f6;
}

.btn-secondary {
    background-color: #374151;
    color: #e2e8f0;
}

.btn-secondary:hover {
    background-color: #4b5563;
}

.btn-danger {
    background-color: #ef4444;
    color: white;
}

.btn-danger:hover {
    background-color: #dc2626;
}

.btn-sm {
    padding: 0.25rem 0.75rem;
    font-size: 0.875rem;
}

/* Grid Layouts */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
}

.grid-4 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
}

/* Statistics */
.stat-box {
    background-color: #16213e;
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid #2d2d3d;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.stat-box .emoji {
    font-size: 2rem;
    margin-bottom: 0.5rem;
}

.stat-value {
    font-size: 2rem;
    font-weight: bold;
    color: #60a5fa;
}

.stat-label {
    color: #94a3b8;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.stat-change {
    font-size: 0.875rem;
    color: #10b981;
}

.stat-change.negative {
    color: #ef4444;
}

/* Tables */
.table-container {
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
}

th {
    background-color: #16213e;
    color: #94a3b8;
    text-align: left;
    padding: 0.75rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #2d2d3d;
}

td {
    padding: 0.75rem;
    border-bottom: 1px solid #2d2d3d;
    color: #e2e8f0;
}

tr:hover {
    background-color: #16213e;
}

/* Status Badges */
.badge {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
}

.badge-active {
    background-color: #10b98133;
    color: #10b981;
}

.badge-inactive {
    background-color: #ef444433;
    color: #ef4444;
}

.badge-maintenance {
    background-color: #f59e0b33;
    color: #f59e0b;
}

.badge-info {
    background-color: #60a5fa33;
    color: #60a5fa;
}

/* Forms */
.form-group {
    margin-bottom: 1.5rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: #94a3b8;
    font-size: 0.875rem;
    font-weight: 500;
}

.form-control {
    width: 100%;
    padding: 0.5rem 0.75rem;
    background-color: #16213e;
    border: 1px solid #2d2d3d;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 1rem;
    transition: border-color 0.3s;
}

.form-control:focus {
    outline: none;
    border-color: #60a5fa;
    background-color: #1a1a2e;
}

select.form-control {
    cursor: pointer;
}

/* Alerts */
.alert {
    padding: 1rem 1.25rem;
    border-radius: 6px;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.alert-success {
    background-color: #10b98133;
    color: #10b981;
    border: 1px solid #10b98144;
}

.alert-error {
    background-color: #ef444433;
    color: #ef4444;
    border: 1px solid #ef444444;
}

.alert-warning {
    background-color: #f59e0b33;
    color: #f59e0b;
    border: 1px solid #f59e0b44;
}

.alert-info {
    background-color: #60a5fa33;
    color: #60a5fa;
    border: 1px solid #60a5fa44;
}

/* Utility Classes */
.text-muted {
    color: #64748b;
}

.text-center {
    text-align: center;
}

.mt-1 { margin-top: 0.5rem; }
.mt-2 { margin-top: 1rem; }
.mt-3 { margin-top: 1.5rem; }
.mb-1 { margin-bottom: 0.5rem; }
.mb-2 { margin-bottom: 1rem; }
.mb-3 { margin-bottom: 1.5rem; }

/* Responsive */
@media (max-width: 768px) {
    .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s;
    }
    
    .sidebar.open {
        transform: translateX(0);
    }
    
    .main-content {
        margin-left: 0;
    }
    
    .grid {
        grid-template-columns: 1fr;
    }
}