"""
File: routes/servers.py
Purpose: Route handlers for server management in DCMS
Version: 1.0.2
Author: DCMS Team
Date: 2025-01-17

Implements the Server module with complete CRUD operations,
IP management, network connections, and customer assignment.
Follows the "Modified All In" approach for immediate value delivery.

Revision History:
- v1.0.0: Initial creation with comprehensive server management
         Includes IP tracking, network connections, IPMI, power management
- v1.0.1: CHANGED: Added missing API endpoints for dynamic dropdowns
         Added /api/switches, /api/racks/<dc_id>, /api/rack/<id>/pdus
         Added missing import re for server ID validation
- v1.0.2: CHANGED: Fixed rack space validation to check ALL equipment types
         Updated validate_server_placement to check servers, network devices, and PDUs
         Updated api_rack_availability to return all equipment in rack
"""

from flask import Blueprint, render_template, request, redirect, url_for, flash, jsonify
from models.datacenter import db, DataCenter, Floor, Rack, PDU
from models.server import Server, ServerNetworkConnection, Customer
from models.ipam import IPAddress
from models.vlan import VLAN
from models.network_device import NetworkDevice
from models.switch_port import SwitchPort
from forms.server_forms import (
    ServerForm, NetworkConnectionForm, IPAssignmentForm, 
    CustomerForm, ServerSearchForm
)
from sqlalchemy import or_, and_, func
from datetime import datetime
import re  # CHANGED v1.0.1: Added missing import for server ID validation

# ========== BLUEPRINT INITIALIZATION ==========

servers_bp = Blueprint('servers', __name__, url_prefix='/servers')

# ========== UTILITY FUNCTIONS ==========

def get_available_ips(network_type='public', count=5):
    """Get available IPs of specified type"""
    # This is simplified - in production would check IP ranges
    available = IPAddress.query.filter(
        IPAddress.status == 'available',
        IPAddress.network_type == network_type
    ).limit(count).all()
    return available

def validate_server_placement(rack_id, start_u, size_u, exclude_server_id=None):
    """
    Validate if server can fit in rack space
    CHANGED v1.0.2: Now checks ALL equipment types (servers, network devices, PDUs)
    """
    rack = Rack.query.get(rack_id)
    if not rack:
        return False, "Rack not found"
    
    # Check bounds
    if start_u < 1 or (start_u + size_u - 1) > rack.u_height:
        return False, f"Position must be between 1 and {rack.u_height}"
    
    # CHANGED v1.0.2: Check for conflicts with other SERVERS
    query = Server.query.filter(
        Server.rack_id == rack_id,
        Server.start_u < (start_u + size_u),
        (Server.start_u + Server.size_u) > start_u
    )
    
    if exclude_server_id:
        query = query.filter(Server.id != exclude_server_id)
    
    server_conflicts = query.all()
    if server_conflicts:
        conflicting = server_conflicts[0]
        return False, f"Conflicts with server {conflicting.server_id} at U{conflicting.start_u}-U{conflicting.start_u + conflicting.size_u - 1}"
    
    # CHANGED v1.0.2: Check for conflicts with NETWORK DEVICES
    network_query = NetworkDevice.query.filter(
        NetworkDevice.rack_id == rack_id,
        NetworkDevice.start_u < (start_u + size_u),
        (NetworkDevice.start_u + NetworkDevice.size_u) > start_u
    )
    
    network_conflicts = network_query.all()
    if network_conflicts:
        conflicting = network_conflicts[0]
        return False, f"Conflicts with network device {conflicting.identifier} ({conflicting.device_type}) at U{conflicting.start_u}-U{conflicting.start_u + conflicting.size_u - 1}"
    
    # CHANGED v1.0.2: Check for conflicts with PDUs (if they have rack positions)
    # Note: PDUs might be 0U (vertical mount) or have specific U positions
    # Check if your PDU model has start_u and size_u fields
    if hasattr(PDU, 'start_u') and hasattr(PDU, 'size_u'):
        pdu_query = PDU.query.filter(
            PDU.rack_id == rack_id,
            PDU.start_u != None,  # Only check PDUs with U positions
            PDU.start_u < (start_u + size_u),
            (PDU.start_u + PDU.size_u) > start_u
        )
        
        pdu_conflicts = pdu_query.all()
        if pdu_conflicts:
            conflicting = pdu_conflicts[0]
            return False, f"Conflicts with PDU {conflicting.identifier} at U{conflicting.start_u}-U{conflicting.start_u + conflicting.size_u - 1}"
    
    return True, "Space available"

def assign_ip_to_server(server, ip_address_str, ip_type):
    """Assign an IP address to a server"""
    # Check if IP exists in IPAM
    ip = IPAddress.query.filter_by(ip_address=ip_address_str).first()
    
    if not ip:
        # Create new IP entry
        ip = IPAddress(
            ip_address=ip_address_str,
            network_type='public' if 'public' in ip_type else 'private',
            status='assigned'
        )
        db.session.add(ip)
        db.session.flush()
    elif ip.status != 'available':
        raise ValueError(f"IP {ip_address_str} is not available")
    
    # Update IP status
    ip.status = 'assigned'
    ip.assigned_to = f"Server: {server.server_id}"
    ip.assigned_date = datetime.utcnow()
    
    # Link to server based on type
    if ip_type == 'primary_public':
        server.primary_public_ip_id = ip.id
    elif ip_type == 'primary_private':
        server.primary_private_ip_id = ip.id
    elif ip_type == 'ipmi':
        server.ipmi_ip_id = ip.id
    elif ip_type == 'addon_public':
        # This would need a many-to-many relationship
        pass
    
    return ip

# ========== MAIN ROUTES ==========

@servers_bp.route('/')
def index():
    """List all servers with filters"""
    # Get filter parameters
    search = request.args.get('search', '')
    status_filter = request.args.get('status', '')
    dc_filter = request.args.get('datacenter', '')
    service_filter = request.args.get('service_type', '')
    customer_filter = request.args.get('customer', '')
    has_ipmi_filter = request.args.get('has_ipmi', '')
    page = request.args.get('page', 1, type=int)
    per_page = 25
    
    # Base query
    query = Server.query
    
    # Apply filters
    if search:
        query = query.filter(or_(
            Server.server_id.ilike(f'%{search}%'),
            Server.server_name.ilike(f'%{search}%'),
            Server.hostname.ilike(f'%{search}%')
        ))
    
    if status_filter:
        query = query.filter_by(status=status_filter)
    
    if dc_filter:
        query = query.filter_by(datacenter_id=dc_filter)
    
    if service_filter:
        query = query.filter_by(service_type=service_filter)
    
    if customer_filter:
        query = query.filter_by(customer_id=customer_filter)
        
    if has_ipmi_filter == 'yes':
        query = query.filter(Server.ipmi_ip_id.isnot(None))
    elif has_ipmi_filter == 'no':
        query = query.filter(Server.ipmi_ip_id.is_(None))
    
    # Execute query with pagination
    pagination = query.order_by(Server.server_id).paginate(
        page=page, per_page=per_page, error_out=False
    )
    servers = pagination.items
    
    # Get filter options
    datacenters = DataCenter.query.all()
    customers = Customer.query.order_by(Customer.customer_name).all()
    
    # Calculate statistics - MUST match what template expects
    all_servers = Server.query.all()
    stats = {
        'total': Server.query.count(),
        'active': Server.query.filter_by(status='active').count(),
        'dedicated': Server.query.filter_by(service_type='dedicated').count(),
        'colocation': Server.query.filter(Server.server_id.like('COLO%')).count(),
        'with_ipmi': Server.query.filter(Server.ipmi_ip_id.isnot(None)).count()
    }
    
    # Create filters dictionary for template
    filters = {
        'search': search,
        'status': status_filter,
        'datacenter': dc_filter,
        'service_type': service_filter,
        'customer': customer_filter,
        'has_ipmi': has_ipmi_filter
    }
    
    # Check if we have a form object (if using WTForms for search)
    # If not, create a simple namespace for compatibility
    try:
        from forms.server_forms import ServerSearchForm
        form = ServerSearchForm(request.args)
        form.datacenter_id.choices = [('', 'All Data Centers')] + [
            (str(dc.id), f"{dc.code} - {dc.name}") for dc in datacenters
        ]
        form.customer_id.choices = [('', 'All Customers')] + [
            (str(c.id), c.customer_name) for c in customers
        ]
    except:
        # Fallback if form doesn't exist
        form = None
    
    return render_template('servers/index.html',
                         servers=servers,
                         pagination=pagination,
                         form=form,
                         stats=stats,
                         filters=filters,
                         datacenters=datacenters,
                         customers=customers,
                         search=search,
                         status_filter=status_filter,
                         dc_filter=dc_filter,
                         service_filter=service_filter,
                         customer_filter=customer_filter,
                         has_ipmi_filter=has_ipmi_filter)

@servers_bp.route('/add', methods=['GET', 'POST'])
def add():
    """Add new server"""
    form = ServerForm()
    
    # Populate choices
    datacenters = DataCenter.query.order_by(DataCenter.code).all()
    form.datacenter_id.choices = [(0, '-- Select Data Center --')] + [
        (dc.id, f"{dc.code} - {dc.name}") for dc in datacenters
    ]
    
    # Racks will be loaded dynamically based on datacenter
    form.rack_id.choices = [(0, '-- Select Data Center First --')]
    
    # Customers for colocation
    customers = Customer.query.order_by(Customer.customer_name).all()
    form.customer_id.choices = [(0, '-- No Customer --')] + [
        (c.id, c.customer_name) for c in customers
    ]
    
    # VLANs
    vlans = VLAN.query.filter_by(status='active').order_by(VLAN.vlan_id).all()
    form.primary_vlan_id.choices = [(0, '-- Auto-detect --')] + [
        (v.id, f"VLAN {v.vlan_id} - {v.description}") for v in vlans
    ]
    
    # PDUs will be loaded dynamically
    form.pdu_1_id.choices = [(0, '-- Select Rack First --')]
    form.pdu_2_id.choices = [(0, '-- Select Rack First --')]
    
    if form.validate_on_submit():
        try:
            # Create server instance
            server = Server(
                server_id=form.server_id_input.data.upper(),
                server_name=form.server_name.data,
                hostname=form.hostname.data,
                whmcs_user_id=form.whmcs_user_id.data,
                equipment_type=form.equipment_type.data,
                service_type=form.service_type.data,
                manufacturer=form.manufacturer.data,
                model=form.model.data,
                datacenter_id=form.datacenter_id.data,
                rack_id=form.rack_id.data,
                start_u=form.start_u.data,
                size_u=form.size_u.data,
                status=form.status.data,
                is_infrastructure=form.is_infrastructure.data,
                is_managed=form.is_managed.data,
                is_available=form.is_available.data,
                notes=form.notes.data
            )
            
            # Validate colocation requirements
            if server.is_colocation:
                if not form.customer_id.data:
                    flash('Colocation servers must be assigned to a customer', 'error')
                    return render_template('servers/add.html', form=form)
                server.customer_id = form.customer_id.data
            
            # CHANGED v1.0.2: Validate rack space with comprehensive check
            valid, message = validate_server_placement(
                server.rack_id, server.start_u, server.size_u
            )
            if not valid:
                flash(f'Rack placement error: {message}', 'error')
                return render_template('servers/add.html', form=form)
            
            # Add to session
            db.session.add(server)
            db.session.flush()  # Get server ID
            
            # Handle IP assignments
            if form.primary_public_ip.data:
                assign_ip_to_server(server, form.primary_public_ip.data, 'primary_public')
            
            if form.primary_private_ip.data:
                assign_ip_to_server(server, form.primary_private_ip.data, 'primary_private')
            
            if form.ipmi_ip.data:
                # Set IPMI fields
                server.ipmi_type = form.ipmi_type.data
                server.ipmi_version = form.ipmi_version.data
                server.ipmi_username = form.ipmi_username.data
                if form.ipmi_password.data:
                    # In production, encrypt this!
                    server.ipmi_password = form.ipmi_password.data
                server.ipmi_mac_address = form.ipmi_mac_address.data
                server.ipmi_web_port = form.ipmi_web_port.data
                server.ipmi_notes = form.ipmi_notes.data
                
                # Assign IPMI IP
                assign_ip_to_server(server, form.ipmi_ip.data, 'ipmi')
            
            # Handle PDU assignments
            if form.pdu_1_id.data:
                server.pdu_1_id = form.pdu_1_id.data
                server.pdu_1_outlet = form.pdu_1_outlet.data
                
                pdu = PDU.query.get(form.pdu_1_id.data)
                pdu.used_outlets += 1
            
            if form.pdu_2_id.data:
                server.pdu_2_id = form.pdu_2_id.data
                server.pdu_2_outlet = form.pdu_2_outlet.data
                
                pdu = PDU.query.get(form.pdu_2_id.data)
                pdu.used_outlets += 1
            
            # Set power configuration
            server.power_draw_watts = form.power_draw_watts.data
            server.power_supply_config = form.power_supply_config.data
            
            # Update rack usage
            rack = Rack.query.get(server.rack_id)
            rack.u_used += server.size_u
            
            # Handle network connections from form
            network_connections = request.form.get('network_connections')
            if network_connections:
                import json
                connections = json.loads(network_connections)
                for conn in connections:
                    connection = ServerNetworkConnection(
                        server_id=server.id,
                        switch_id=conn['switchId'],
                        switch_port=conn['port'],
                        port_speed=conn['speed'],
                        connection_type=conn['type'],
                        connection_name=f"{conn['type']}-{conn['port']}",
                        link_status='up',
                        is_enabled=True
                    )
                    db.session.add(connection)
            
            # Handle add-on IPs
            public_addon_ips = request.form.get('public_addon_ips', '').strip()
            if public_addon_ips:
                for ip_str in public_addon_ips.split('\n'):
                    ip_str = ip_str.strip()
                    if ip_str:
                        assign_ip_to_server(server, ip_str, 'addon_public')
            
            private_addon_ips = request.form.get('private_addon_ips', '').strip()
            if private_addon_ips:
                for ip_str in private_addon_ips.split('\n'):
                    ip_str = ip_str.strip()
                    if ip_str:
                        assign_ip_to_server(server, ip_str, 'addon_private')
            
            db.session.commit()
            flash(f'Server {server.server_id} created successfully', 'success')
            return redirect(url_for('servers.view', id=server.id))
            
        except Exception as e:
            db.session.rollback()
            flash(f'Error creating server: {str(e)}', 'error')
    
    return render_template('servers/add.html', form=form)

@servers_bp.route('/<int:id>')
def view(id):
    """View server details"""
    server = Server.query.get_or_404(id)
    
    # Get network connections
    connections = server.network_connections.order_by(
        ServerNetworkConnection.connection_type,
        ServerNetworkConnection.connection_name
    ).all()
    
    # Group connections by type
    connections_by_type = {}
    for conn in connections:
        if conn.connection_type not in connections_by_type:
            connections_by_type[conn.connection_type] = []
        connections_by_type[conn.connection_type].append(conn)
    
    # Get all IPs
    all_ips = {
        'primary_public': server.primary_public_ip,
        'primary_private': server.primary_private_ip,
        'ipmi': server.ipmi_ip,
        'addon_public': [],
        'addon_private': []
    }
    
    for ip in server.addon_ips:
        if ip.network_type == 'public':
            all_ips['addon_public'].append(ip)
        else:
            all_ips['addon_private'].append(ip)
    
    return render_template('servers/view.html',
                         server=server,
                         connections=connections,
                         connections_by_type=connections_by_type,
                         all_ips=all_ips)

@servers_bp.route('/<int:id>/edit', methods=['GET', 'POST'])
def edit(id):
    """
    Edit server
    FIXED: Excludes current server from validation checks
    """
    server = Server.query.get_or_404(id)
    form = ServerForm(obj=server)
    
    # Store original values
    original_rack_id = server.rack_id
    original_size_u = server.size_u
    original_server_id = server.server_id
    original_pdu_1_id = server.pdu_1_id
    original_pdu_1_outlet = server.pdu_1_outlet
    original_pdu_2_id = server.pdu_2_id
    original_pdu_2_outlet = server.pdu_2_outlet
    
    # Populate choices (same as add)
    datacenters = DataCenter.query.order_by(DataCenter.code).all()
    form.datacenter_id.choices = [(dc.id, f"{dc.code} - {dc.name}") for dc in datacenters]
    
    racks = Rack.query.join(Floor).filter(
        Floor.datacenter_id == server.datacenter_id
    ).order_by(Rack.rack_id).all()
    form.rack_id.choices = [(r.id, r.rack_id) for r in racks]
    
    customers = Customer.query.order_by(Customer.customer_name).all()
    form.customer_id.choices = [(0, '-- No Customer --')] + [
        (c.id, c.customer_name) for c in customers
    ]
    
    vlans = VLAN.query.filter_by(status='active').order_by(VLAN.vlan_id).all()
    form.primary_vlan_id.choices = [(0, '-- Auto-detect --')] + [
        (v.id, f"VLAN {v.vlan_id} - {v.description}") for v in vlans
    ]
    
    pdus = PDU.query.filter_by(rack_id=server.rack_id).all()
    pdu_choices = [(0, '-- No PDU --')] + [
        (p.id, f"{p.identifier} ({p.available_outlets} free)") for p in pdus
    ]
    form.pdu_1_id.choices = pdu_choices
    form.pdu_2_id.choices = pdu_choices
    
    # IMPORTANT: Set form data from server object
    if request.method == 'GET':
        # Populate form with existing data
        form.server_id_input.data = server.server_id
        form.server_name.data = server.server_name
        form.hostname.data = server.hostname
        form.whmcs_user_id.data = server.whmcs_user_id
        form.equipment_type.data = server.equipment_type
        form.service_type.data = server.service_type
        form.manufacturer.data = server.manufacturer
        form.model.data = server.model
        form.datacenter_id.data = server.datacenter_id
        form.rack_id.data = server.rack_id
        form.start_u.data = server.start_u
        form.size_u.data = server.size_u
        form.status.data = server.status
        form.is_infrastructure.data = server.is_infrastructure
        form.is_managed.data = server.is_managed
        form.is_available.data = server.is_available
        form.customer_id.data = server.customer_id if server.customer_id else 0
        form.notes.data = server.notes
        
        # Set IP addresses
        if server.primary_public_ip:
            form.primary_public_ip.data = server.primary_public_ip.ip_address
        if server.primary_private_ip:
            form.primary_private_ip.data = server.primary_private_ip.ip_address
        if server.ipmi_ip:
            form.ipmi_ip.data = server.ipmi_ip.ip_address
            
        # Set IPMI fields
        form.ipmi_type.data = server.ipmi_type
        form.ipmi_version.data = server.ipmi_version
        form.ipmi_username.data = server.ipmi_username
        form.ipmi_mac_address.data = server.ipmi_mac_address
        form.ipmi_web_port.data = server.ipmi_web_port
        form.ipmi_notes.data = server.ipmi_notes
        
        # Set PDU fields
        form.pdu_1_id.data = server.pdu_1_id if server.pdu_1_id else 0
        form.pdu_1_outlet.data = server.pdu_1_outlet
        form.pdu_2_id.data = server.pdu_2_id if server.pdu_2_id else 0
        form.pdu_2_outlet.data = server.pdu_2_outlet
        form.power_draw_watts.data = server.power_draw_watts
        form.power_supply_config.data = server.power_supply_config
    
    if form.validate_on_submit():
        try:
            # Check if server ID changed and validate uniqueness
            new_server_id = form.server_id_input.data.upper()
            if new_server_id != original_server_id:
                existing = Server.query.filter_by(server_id=new_server_id).first()
                if existing:
                    flash(f'Server ID {new_server_id} already exists', 'error')
                    return render_template('servers/edit.html', form=form, server=server)
            
            # Update server fields
            server.server_id = new_server_id
            server.server_name = form.server_name.data
            server.hostname = form.hostname.data
            server.whmcs_user_id = form.whmcs_user_id.data
            server.equipment_type = form.equipment_type.data
            server.service_type = form.service_type.data
            server.manufacturer = form.manufacturer.data
            server.model = form.model.data
            server.datacenter_id = form.datacenter_id.data
            server.rack_id = form.rack_id.data
            server.start_u = form.start_u.data
            server.size_u = form.size_u.data
            server.status = form.status.data
            server.is_infrastructure = form.is_infrastructure.data
            server.is_managed = form.is_managed.data
            server.is_available = form.is_available.data
            server.notes = form.notes.data
            
            # Update customer
            if server.is_colocation:
                server.customer_id = form.customer_id.data
            else:
                server.customer_id = None
            
            # FIXED: Validate rack space with comprehensive check, EXCLUDING current server
            valid, message = validate_server_placement(
                server.rack_id, server.start_u, server.size_u, server.id  # Pass server.id to exclude it
            )
            if not valid:
                flash(f'Rack placement error: {message}', 'error')
                return render_template('servers/edit.html', form=form, server=server)
            
            # Handle IPMI updates
            if form.ipmi_ip.data:
                server.ipmi_type = form.ipmi_type.data
                server.ipmi_version = form.ipmi_version.data
                server.ipmi_username = form.ipmi_username.data
                if form.ipmi_password.data:  # Only update password if provided
                    server.ipmi_password = form.ipmi_password.data
                server.ipmi_mac_address = form.ipmi_mac_address.data
                server.ipmi_web_port = form.ipmi_web_port.data
                server.ipmi_notes = form.ipmi_notes.data
                
                # Update or assign IPMI IP
                if not server.ipmi_ip or server.ipmi_ip.ip_address != form.ipmi_ip.data:
                    assign_ip_to_server(server, form.ipmi_ip.data, 'ipmi')
            elif server.ipmi_ip:
                # Remove IPMI IP if cleared
                server.release_ip('ipmi')
                server.ipmi_ip_id = None
            
            # Update IPs (simplified - production would handle changes better)
            if form.primary_public_ip.data:
                if not server.primary_public_ip or server.primary_public_ip.ip_address != form.primary_public_ip.data:
                    assign_ip_to_server(server, form.primary_public_ip.data, 'primary_public')
            elif server.primary_public_ip:
                server.release_ip('primary_public')
                server.primary_public_ip_id = None
            
            if form.primary_private_ip.data:
                if not server.primary_private_ip or server.primary_private_ip.ip_address != form.primary_private_ip.data:
                    assign_ip_to_server(server, form.primary_private_ip.data, 'primary_private')
            elif server.primary_private_ip:
                server.release_ip('primary_private')
                server.primary_private_ip_id = None
            
            # Update PDU assignments with validation
            # Check if PDU outlets changed
            pdu_changed = False
            
            # Handle Primary PDU
            if form.pdu_1_id.data != original_pdu_1_id or form.pdu_1_outlet.data != original_pdu_1_outlet:
                pdu_changed = True
                
                # Release old outlet
                if original_pdu_1_id:
                    old_pdu = PDU.query.get(original_pdu_1_id)
                    if old_pdu:
                        old_pdu.used_outlets = max(0, old_pdu.used_outlets - 1)
                
                # Assign new outlet
                if form.pdu_1_id.data and form.pdu_1_outlet.data:
                    # Check if outlet is available (excluding current server)
                    conflict = Server.query.filter(
                        Server.id != server.id,
                        or_(
                            and_(Server.pdu_1_id == form.pdu_1_id.data, Server.pdu_1_outlet == form.pdu_1_outlet.data),
                            and_(Server.pdu_2_id == form.pdu_1_id.data, Server.pdu_2_outlet == form.pdu_1_outlet.data)
                        )
                    ).first()
                    
                    if conflict:
                        flash(f'PDU outlet {form.pdu_1_outlet.data} is already in use by {conflict.server_id}', 'error')
                        return render_template('servers/edit.html', form=form, server=server)
                    
                    new_pdu = PDU.query.get(form.pdu_1_id.data)
                    if new_pdu:
                        new_pdu.used_outlets += 1
                
                server.pdu_1_id = form.pdu_1_id.data if form.pdu_1_id.data else None
                server.pdu_1_outlet = form.pdu_1_outlet.data if form.pdu_1_id.data else None
            
            # Handle Redundant PDU
            if form.pdu_2_id.data != original_pdu_2_id or form.pdu_2_outlet.data != original_pdu_2_outlet:
                pdu_changed = True
                
                # Release old outlet
                if original_pdu_2_id:
                    old_pdu = PDU.query.get(original_pdu_2_id)
                    if old_pdu:
                        old_pdu.used_outlets = max(0, old_pdu.used_outlets - 1)
                
                # Assign new outlet
                if form.pdu_2_id.data and form.pdu_2_outlet.data:
                    # Check if outlet is available (excluding current server)
                    conflict = Server.query.filter(
                        Server.id != server.id,
                        or_(
                            and_(Server.pdu_1_id == form.pdu_2_id.data, Server.pdu_1_outlet == form.pdu_2_outlet.data),
                            and_(Server.pdu_2_id == form.pdu_2_id.data, Server.pdu_2_outlet == form.pdu_2_outlet.data)
                        )
                    ).first()
                    
                    if conflict:
                        flash(f'PDU outlet {form.pdu_2_outlet.data} is already in use by {conflict.server_id}', 'error')
                        return render_template('servers/edit.html', form=form, server=server)
                    
                    new_pdu = PDU.query.get(form.pdu_2_id.data)
                    if new_pdu:
                        new_pdu.used_outlets += 1
                
                server.pdu_2_id = form.pdu_2_id.data if form.pdu_2_id.data else None
                server.pdu_2_outlet = form.pdu_2_outlet.data if form.pdu_2_id.data else None
            
            # Update power configuration
            server.power_draw_watts = form.power_draw_watts.data
            server.power_supply_config = form.power_supply_config.data
            
            # Update rack usage if changed
            if original_rack_id != server.rack_id or original_size_u != server.size_u:
                old_rack = Rack.query.get(original_rack_id)
                old_rack.u_used = max(0, old_rack.u_used - original_size_u)
                
                new_rack = Rack.query.get(server.rack_id)
                new_rack.u_used += server.size_u
            
            # Handle network connections from form
            removed_connections = request.form.getlist('removed_connections')
            if removed_connections:
                for conn_id in removed_connections:
                    conn = ServerNetworkConnection.query.get(int(conn_id))
                    if conn:
                        db.session.delete(conn)
            
            # Handle new network connections
            network_connections = request.form.get('network_connections')
            if network_connections:
                import json
                connections = json.loads(network_connections)
                for conn in connections:
                    # Check if port is available
                    existing = ServerNetworkConnection.query.filter_by(
                        switch_id=conn['switchId'],
                        switch_port=conn['port']
                    ).first()
                    
                    if not existing:
                        connection = ServerNetworkConnection(
                            server_id=server.id,
                            switch_id=conn['switchId'],
                            switch_port=conn['port'],
                            port_speed=conn['speed'],
                            connection_type=conn['type'],
                            connection_name=f"{conn['type']}-{conn['port']}",
                            link_status='up',
                            is_enabled=True
                        )
                        db.session.add(connection)
            
            # Handle add-on IPs
            public_addon_ips = request.form.get('public_addon_ips', '').strip()
            private_addon_ips = request.form.get('private_addon_ips', '').strip()
            
            # Clear existing addon IPs (simplified - production would be smarter)
            for ip in server.addon_ips:
                ip.status = 'available'
                ip.assigned_to = None
                ip.assigned_date = None
            
            # Add new addon IPs
            if public_addon_ips:
                for ip_str in public_addon_ips.split('\n'):
                    ip_str = ip_str.strip()
                    if ip_str:
                        assign_ip_to_server(server, ip_str, 'addon_public')
            
            if private_addon_ips:
                for ip_str in private_addon_ips.split('\n'):
                    ip_str = ip_str.strip()
                    if ip_str:
                        assign_ip_to_server(server, ip_str, 'addon_private')
            
            db.session.commit()
            flash(f'Server {server.server_id} updated successfully', 'success')
            return redirect(url_for('servers.view', id=server.id))
            
        except Exception as e:
            db.session.rollback()
            flash(f'Error updating server: {str(e)}', 'error')
            import traceback
            print(traceback.format_exc())
    
    return render_template('servers/edit.html', form=form, server=server)

# ========== CUSTOMER MANAGEMENT ==========

@servers_bp.route('/customers')
def customers():
    """List all customers"""
    customers = Customer.query.order_by(Customer.customer_name).all()
    
    # Get server counts
    for customer in customers:
        customer.server_count = Server.query.filter_by(customer_id=customer.id).count()
    
    return render_template('servers/customers.html', customers=customers)

@servers_bp.route('/customers/add', methods=['GET', 'POST'])
def add_customer():
    """Add new customer"""
    form = CustomerForm()
    
    if form.validate_on_submit():
        try:
            customer = Customer(
                customer_name=form.customer_name.data,
                customer_code=form.customer_code.data,
                contact_name=form.contact_name.data,
                contact_email=form.contact_email.data,
                contact_phone=form.contact_phone.data,
                whmcs_id=form.whmcs_id.data,
                billing_status=form.billing_status.data,
                notes=form.notes.data
            )
            
            db.session.add(customer)
            db.session.commit()
            
            flash(f'Customer {customer.customer_name} created successfully', 'success')
            return redirect(url_for('servers.customers'))
            
        except Exception as e:
            db.session.rollback()
            flash(f'Error creating customer: {str(e)}', 'error')
    
    return render_template('servers/add_customer.html', form=form)

@servers_bp.route('/customers/<int:id>')
def view_customer(id):
    """View customer details and their servers"""
    customer = Customer.query.get_or_404(id)
    servers = Server.query.filter_by(customer_id=customer.id).all()
    
    # Calculate statistics
    stats = {
        'total_servers': len(servers),
        'active_servers': len([s for s in servers if s.status == 'active']),
        'total_ips': sum(s.total_ip_count for s in servers),
        'racks_used': len(set(s.rack_id for s in servers))
    }
    
    return render_template('servers/view_customer.html',
                         customer=customer,
                         servers=servers,
                         stats=stats)

# ========== CONNECTION MANAGEMENT ==========

@servers_bp.route('/<int:id>/connections')
def connections(id):
    """Manage server network connections"""
    server = Server.query.get_or_404(id)
    connections = server.network_connections.all()
    
    # Group by connection type
    grouped = {}
    for conn in connections:
        if conn.connection_type not in grouped:
            grouped[conn.connection_type] = []
        grouped[conn.connection_type].append(conn)
    
    # Calculate bandwidth
    total_bandwidth = server.total_bandwidth
    
    return render_template('servers/connections.html',
                         server=server,
                         connections=connections,
                         grouped_connections=grouped,
                         total_bandwidth=total_bandwidth)

@servers_bp.route('/<int:id>/connections/add', methods=['GET', 'POST'])
def add_connection(id):
    """Add network connection to server"""
    server = Server.query.get_or_404(id)
    form = NetworkConnectionForm()
    
    # Populate switch choices
    switches = NetworkDevice.query.filter_by(device_type='Switch').order_by(NetworkDevice.identifier).all()
    form.switch_id.choices = [(0, '-- Select Switch --')] + [
        (s.id, f"{s.identifier} - {s.hostname}") for s in switches
    ]
    
    # VLAN choices
    vlans = VLAN.query.filter_by(status='active').order_by(VLAN.vlan_id).all()
    form.native_vlan_id.choices = [(0, '-- No VLAN --')] + [
        (v.id, f"VLAN {v.vlan_id} - {v.description}") for v in vlans
    ]
    
    if form.validate_on_submit():
        try:
            # Check port availability
            existing = ServerNetworkConnection.query.filter_by(
                switch_id=form.switch_id.data,
                switch_port=form.switch_port.data
            ).first()
            
            if existing:
                flash(f'Port already in use by {existing.server.server_id}', 'error')
                return render_template('servers/add_connection.html', form=form, server=server)
            
            # Create connection
            connection = ServerNetworkConnection(
                server_id=server.id,
                connection_name=form.connection_name.data or f"{form.connection_type.data}-{form.switch_port.data}",
                connection_type=form.connection_type.data,
                switch_id=form.switch_id.data,
                switch_port=form.switch_port.data,
                port_speed=form.port_speed.data,
                native_vlan_id=form.native_vlan_id.data if form.native_vlan_id.data else None,
                mac_address=form.mac_address.data,
                bond_group=form.bond_group.data,
                bond_mode=form.bond_mode.data,
                is_bond_primary=form.is_bond_primary.data,
                link_status=form.link_status.data,
                is_enabled=form.is_enabled.data,
                notes=form.notes.data
            )
            
            db.session.add(connection)
            db.session.commit()
            
            flash(f'Network connection added successfully', 'success')
            return redirect(url_for('servers.connections', id=server.id))
            
        except Exception as e:
            db.session.rollback()
            flash(f'Error adding connection: {str(e)}', 'error')
    
    return render_template('servers/add_connection.html', form=form, server=server)

