@servers_bp.route('/api/rack/<int:rack_id>/pdus')
def api_get_rack_pdus(rack_id):
    """API to get PDUs for a specific rack"""
    pdus = PDU.query.filter_by(rack_id=rack_id).all()
    
    return jsonify([{
        'id': pdu.id,
        'identifier': pdu.identifier,
        'model': pdu.model,
        'available_outlets': pdu.total_outlets - pdu.used_outlets
    } for pdu in pdus])

@servers_bp.route('/api/detect-vlan')
def api_detect_vlan():
    """API to auto-detect VLAN from IP address"""
    ip = request.args.get('ip', '')
    
    # Simple VLAN detection logic - customize based on your network
    vlan_id = None
    vlan_name = None
    
    if ip.startswith('208.76.80.'):
        vlan_id = 1
        vlan_name = 'Public Network'
    elif ip.startswith('66.'):
        vlan_id = 66
        vlan_name = 'Colocation Network'
    elif ip.startswith('10.10.'):
        vlan_id = 10
        vlan_name = 'Private Network'
    
    # Try to find the actual VLAN in database
    if vlan_id:
        vlan = VLAN.query.filter_by(vlan_id=vlan_id).first()
        if vlan:
            return jsonify({
                'vlan_id': vlan.id,
                'vlan_name': f"VLAN {vlan.vlan_id} - {vlan.description}"
            })
    
    return jsonify({
        'vlan_id': None,
        'vlan_name': None
    })

# Add this new API endpoint to your routes/servers.py file
# Place it with the other API endpoints (after the existing @servers_bp.route('/api/...) functions)

@servers_bp.route('/api/switch/<int:switch_id>/port/<int:port>/availability')
def api_check_switch_port(switch_id, port):
    """
    API to check if a switch port is available
    Checks across ALL device types: servers, PDUs, network devices, etc.
    Version: 1.0.0 - Added comprehensive port availability checking
    """
    # Check if switch exists
    switch = NetworkDevice.query.get(switch_id)
    if not switch:
        return jsonify({
            'error': 'Switch not found',
            'switch_id': switch_id,
            'port_number': port
        }), 404
    
    # Initialize response
    result = {
        'switch_id': switch_id,
        'switch_name': switch.identifier,
        'port_number': port,
        'available': True,
        'used_by': None,
        'device_type': None,
        'device_info': None
    }
    
    # Method 1: Check SwitchPort table if it exists
    try:
        from models.switch_port import SwitchPort
        switch_port = SwitchPort.query.filter_by(
            switch_id=switch_id,
            port_number=port
        ).first()
        
        if switch_port and switch_port.connected_device_type:
            result['available'] = False
            result['device_type'] = switch_port.connected_device_type
            result['device_info'] = switch_port.description or f"{switch_port.connected_device_type} device"
            return jsonify(result)
    except ImportError:
        # SwitchPort model doesn't exist, continue with other checks
        pass
    except Exception as e:
        print(f"Error checking SwitchPort: {e}")
    
    # Method 2: Check ServerNetworkConnection for servers using this port
    try:
        connections = ServerNetworkConnection.query.filter_by(
            switch_id=switch_id,
            switch_port=port
        ).all()
        
        if connections:
            conn = connections[0]
            result['available'] = False
            result['device_type'] = 'server'
            result['used_by'] = conn.server.server_id if conn.server else 'Unknown Server'
            result['device_info'] = f"Server: {conn.server.server_id} - {conn.server.server_name}" if conn.server else "Server connection"
            return jsonify(result)
    except Exception as e:
        print(f"Error checking ServerNetworkConnection: {e}")
    
    # Method 3: Check PDUs connected to this switch port
    try:
        pdus = PDU.query.filter_by(
            connected_switch_id=switch_id,
            connected_switch_port=port
        ).all()
        
        if pdus:
            pdu = pdus[0]
            result['available'] = False
            result['device_type'] = 'pdu'
            result['used_by'] = pdu.identifier
            result['device_info'] = f"PDU: {pdu.identifier} in rack {pdu.rack.rack_id}"
            return jsonify(result)
    except Exception as e:
        print(f"Error checking PDU connections: {e}")
    
    # Method 4: Check if network devices use this for management (if these fields exist)
    try:
        if hasattr(NetworkDevice, 'management_switch_id') and hasattr(NetworkDevice, 'management_switch_port'):
            devices = NetworkDevice.query.filter_by(
                management_switch_id=switch_id,
                management_switch_port=port
            ).all()
            
            if devices:
                device = devices[0]
                result['available'] = False
                result['device_type'] = 'network_device'
                result['used_by'] = device.identifier
                result['device_info'] = f"{device.device_type}: {device.identifier}"
                return jsonify(result)
    except Exception as e:
        print(f"Error checking NetworkDevice management ports: {e}")
    
    # Port is available
    return jsonify(result)

@servers_bp.route('/api/pdu/<int:pdu_id>/outlet/<int:outlet>/availability')
def api_check_pdu_outlet(pdu_id, outlet):
    """
    API to check if a PDU outlet is available
    Checks across ALL device types: servers, network devices, etc.
    Version: 1.0.0 - Added comprehensive outlet availability checking
    """
    # Check if PDU exists
    pdu = PDU.query.get(pdu_id)
    if not pdu:
        return jsonify({
            'error': 'PDU not found',
            'pdu_id': pdu_id,
            'outlet': outlet
        }), 404
    
    # Check outlet number is valid
    if outlet < 1 or outlet > pdu.total_outlets:
        return jsonify({
            'error': f'Invalid outlet number. PDU has {pdu.total_outlets} outlets',
            'pdu_id': pdu_id,
            'outlet': outlet,
            'max_outlets': pdu.total_outlets
        }), 400
    
    # Initialize response
    result = {
        'pdu_id': pdu_id,
        'pdu_name': pdu.identifier,
        'outlet': outlet,
        'available': True,
        'used_by': None,
        'device_type': None,
        'device_info': None
    }
    
    # Check servers using this PDU outlet (primary power)
    servers_primary = Server.query.filter_by(
        pdu_1_id=pdu_id,
        pdu_1_outlet=outlet
    ).all()
    
    if servers_primary:
        server = servers_primary[0]
        result['available'] = False
        result['device_type'] = 'server'
        result['used_by'] = server.server_id
        result['device_info'] = f"Server: {server.server_id} - {server.server_name} (Primary Power)"
        return jsonify(result)
    
    # Check servers using this PDU outlet (redundant power)
    servers_redundant = Server.query.filter_by(
        pdu_2_id=pdu_id,
        pdu_2_outlet=outlet
    ).all()
    
    if servers_redundant:
        server = servers_redundant[0]
        result['available'] = False
        result['device_type'] = 'server'
        result['used_by'] = server.server_id
        result['device_info'] = f"Server: {server.server_id} - {server.server_name} (Redundant Power)"
        return jsonify(result)
    
    # Check network devices using this PDU outlet (primary)
    network_devices_primary = NetworkDevice.query.filter_by(
        pdu_1_id=pdu_id,
        pdu_1_outlet=outlet
    ).all()
    
    if network_devices_primary:
        device = network_devices_primary[0]
        result['available'] = False
        result['device_type'] = 'network_device'
        result['used_by'] = device.identifier
        result['device_info'] = f"{device.device_type}: {device.identifier} - {device.hostname} (Primary Power)"
        return jsonify(result)
    
    # Check network devices using this PDU outlet (redundant)
    network_devices_redundant = NetworkDevice.query.filter_by(
        pdu_2_id=pdu_id,
        pdu_2_outlet=outlet
    ).all()
    
    if network_devices_redundant:
        device = network_devices_redundant[0]
        result['available'] = False
        result['device_type'] = 'network_device'
        result['used_by'] = device.identifier
        result['device_info'] = f"{device.device_type}: {device.identifier} - {device.hostname} (Redundant Power)"
        return jsonify(result)
    
    # Outlet is available
    return jsonify(result)


@servers_bp.route('/api/validate-pdu-assignment', methods=['POST'])
def api_validate_pdu_assignment():
    """
    Validate PDU assignments before saving
    Checks for conflicts and redundancy issues
    """
    data = request.get_json()
    
    pdu_1_id = data.get('pdu_1_id')
    pdu_1_outlet = data.get('pdu_1_outlet')
    pdu_2_id = data.get('pdu_2_id')
    pdu_2_outlet = data.get('pdu_2_outlet')
    exclude_server_id = data.get('exclude_server_id')  # For edit mode
    
    errors = []
    warnings = []
    
    # Check if same PDU is used for both primary and redundant
    if pdu_1_id and pdu_2_id and pdu_1_id == pdu_2_id:
        warnings.append("Primary and redundant power are on the same PDU - no redundancy!")
        
        # Check if same outlet on same PDU
        if pdu_1_outlet and pdu_2_outlet and pdu_1_outlet == pdu_2_outlet:
            errors.append("Cannot use the same outlet for primary and redundant power!")
    
    # Validate primary PDU outlet
    if pdu_1_id and pdu_1_outlet:
        # Check servers
        query = Server.query.filter(
            or_(
                and_(Server.pdu_1_id == pdu_1_id, Server.pdu_1_outlet == pdu_1_outlet),
                and_(Server.pdu_2_id == pdu_1_id, Server.pdu_2_outlet == pdu_1_outlet)
            )
        )
        if exclude_server_id:
            query = query.filter(Server.id != exclude_server_id)
        
        conflict_servers = query.all()
        if conflict_servers:
            server = conflict_servers[0]
            errors.append(f"Primary PDU outlet {pdu_1_outlet} is already used by server {server.server_id}")
        
        # Check network devices
        conflict_devices = NetworkDevice.query.filter(
            or_(
                and_(NetworkDevice.pdu_1_id == pdu_1_id, NetworkDevice.pdu_1_outlet == pdu_1_outlet),
                and_(NetworkDevice.pdu_2_id == pdu_1_id, NetworkDevice.pdu_2_outlet == pdu_1_outlet)
            )
        ).all()
        
        if conflict_devices:
            device = conflict_devices[0]
            errors.append(f"Primary PDU outlet {pdu_1_outlet} is already used by {device.device_type} {device.identifier}")
    
    # Validate redundant PDU outlet
    if pdu_2_id and pdu_2_outlet:
        # Check servers
        query = Server.query.filter(
            or_(
                and_(Server.pdu_1_id == pdu_2_id, Server.pdu_1_outlet == pdu_2_outlet),
                and_(Server.pdu_2_id == pdu_2_id, Server.pdu_2_outlet == pdu_2_outlet)
            )
        )
        if exclude_server_id:
            query = query.filter(Server.id != exclude_server_id)
        
        conflict_servers = query.all()
        if conflict_servers:
            server = conflict_servers[0]
            errors.append(f"Redundant PDU outlet {pdu_2_outlet} is already used by server {server.server_id}")
        
        # Check network devices
        conflict_devices = NetworkDevice.query.filter(
            or_(
                and_(NetworkDevice.pdu_1_id == pdu_2_id, NetworkDevice.pdu_1_outlet == pdu_2_outlet),
                and_(NetworkDevice.pdu_2_id == pdu_2_id, NetworkDevice.pdu_2_outlet == pdu_2_outlet)
            )
        ).all()
        
        if conflict_devices:
            device = conflict_devices[0]
            errors.append(f"Redundant PDU outlet {pdu_2_outlet} is already used by {device.device_type} {device.identifier}")
    
    return jsonify({
        'valid': len(errors) == 0,
        'errors': errors,
        'warnings': warnings
    })