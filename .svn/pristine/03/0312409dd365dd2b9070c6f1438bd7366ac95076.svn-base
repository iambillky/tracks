<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}DCMS{% endblock %}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/main.css') }}">
    {% block styles %}{% endblock %}
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <nav class="sidebar">
            <div class="sidebar-header">
                <h1>🏢 DCMS</h1>
            </div>
            
            <div class="nav-menu">
                <!-- Main Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <ul>
                        <li>
                            <a href="/" class="{% if request.endpoint == 'index' %}active{% endif %}">
                                <span class="nav-icon">📊</span>
                                <span>Dashboard</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                <!-- Infrastructure Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Infrastructure</div>
                    <ul>
                        <li>
                            <a href="/datacenters">
                                <span class="nav-icon">🏢</span>
                                <span>Data Centers</span>
                            </a>
                        </li>
                        <li>
                            <a href="/floors">
                                <span class="nav-icon">🏗️</span>
                                <span>Floors</span>
                            </a>
                        </li>
                        <li>
                            <a href="/racks">
                                <span class="nav-icon">🗄️</span>
                                <span>Racks</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                <!-- Power Management Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Power Management</div>
                    <ul>
                        <li>
                            <a href="/pdus">
                                <span class="nav-icon">⚡</span>
                                <span>PDUs</span>
                            </a>
                        </li>
                        <li>
                            <a href="/power-profiles">
                                <span class="nav-icon">📈</span>
                                <span>Power Profiles</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                <!-- Network Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Network</div>
                    <ul>
                        <li>
                            <a href="/network-devices">
                                <span class="nav-icon">🌐</span>
                                <span>Network Devices</span>
                            </a>
                        </li>
                        <li>
                            <a href="/ip-addresses">
                                <span class="nav-icon">📡</span>
                                <span>IP Addresses</span>
                            </a>
                        </li>
                        <li>
                            <a href="/connections">
                                <span class="nav-icon">🔌</span>
                                <span>Connections</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                <!-- Inventory Section -->
                <div class="nav-section">
                    <div class="nav-section-title">Inventory</div>
                    <ul>
                        <li>
                            <a href="/servers">
                                <span class="nav-icon">🖥️</span>
                                <span>Servers</span>
                            </a>
                        </li>
                        <li>
                            <a href="/storage">
                                <span class="nav-icon">💾</span>
                                <span>Storage</span>
                            </a>
                        </li>
                        <li>
                            <a href="/assets">
                                <span class="nav-icon">📦</span>
                                <span>Assets</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                <!-- System Section -->
                <div class="nav-section">
                    <div class="nav-section-title">System</div>
                    <ul>
                        <li>
                            <a href="/reports">
                                <span class="nav-icon">📋</span>
                                <span>Reports</span>
                            </a>
                        </li>
                        <li>
                            <a href="/settings">
                                <span class="nav-icon">⚙️</span>
                                <span>Settings</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        
        <!-- Main Content Area -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <h2 class="page-title">{% block page_title %}Dashboard{% endblock %}</h2>
                <div class="header-actions">
                    {% block header_actions %}{% endblock %}
                </div>
            </header>
            
            <!-- Page Content -->
            <main class="content">
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>
    
    {% block scripts %}{% endblock %}
</body>
</html>