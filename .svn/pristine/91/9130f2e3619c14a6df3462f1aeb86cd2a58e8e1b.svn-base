"""
File: models/datacenter.py
Purpose: Core data center infrastructure models with IPAM integration
Version: 1.3.0
Author: DCMS Team

Revision History:
- v1.0.0: Initial creation with DataCenter, Floor, Rack, PDU models
- v1.1.0 (2024-01-09): Added model field to PDU for tracking APC model numbers
- v1.2.0 (2025-01-15): Added switch connectivity fields to PDU
- v1.3.0 (2025-01-16): CHANGED: Integrated IPAM for PDU IP address management
                       Removed direct ip_address field from PDU
                       Added relationship to IPAddress model
"""

from datetime import datetime
from flask_sqlalchemy import SQLAlchemy

# ========== DATABASE INITIALIZATION ==========

db = SQLAlchemy()

# ========== MODEL DEFINITIONS ==========

class DataCenter(db.Model):
    """
    Data Center model
    Represents a physical data center location with its code and details
    Includes comprehensive contact management for sales, PM, and manager roles
    """
    __tablename__ = 'datacenters'
    
    # Primary key
    id = db.Column(db.Integer, primary_key=True)
    
    # Basic information
    code = db.Column(db.String(3), unique=True, nullable=False)  # SFJ, LAX, etc.
    name = db.Column(db.String(100), nullable=False)  # San Francisco Junction
    address = db.Column(db.String(200))
    
    # Primary contact information (existing fields)
    contact_phone = db.Column(db.String(20))
    contact_email = db.Column(db.String(100))
    
    # Sales Contact
    sales_name = db.Column(db.String(100))
    sales_email = db.Column(db.String(100))
    sales_phone = db.Column(db.String(20))
    sales_title = db.Column(db.String(100))
    
    # Project Manager Contact
    pm_name = db.Column(db.String(100))
    pm_email = db.Column(db.String(100))
    pm_phone = db.Column(db.String(20))
    pm_title = db.Column(db.String(100))
    
    # Manager Contact
    manager_name = db.Column(db.String(100))
    manager_email = db.Column(db.String(100))
    manager_phone = db.Column(db.String(20))
    manager_title = db.Column(db.String(100))
    
    # Additional information
    notes = db.Column(db.Text)
    
    # Timestamps
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    updated_at = db.Column(db.DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    
    # Relationships
    floors = db.relationship('Floor', backref='datacenter', lazy='dynamic', cascade='all, delete-orphan')
    
    def __repr__(self):
        return f'<DataCenter {self.code}>'
    
    @property
    def rack_count(self):
        """Get total rack count for this DC"""
        return sum(floor.racks.count() for floor in self.floors)
    
    @property
    def total_u_capacity(self):
        """Calculate total U capacity across all racks"""
        total = 0
        for floor in self.floors:
            for rack in floor.racks:
                total += rack.u_height
        return total
    
    @property
    def has_sales_contact(self):
        """Check if sales contact is configured"""
        return bool(self.sales_name or self.sales_email or self.sales_phone)
    
    @property
    def has_pm_contact(self):
        """Check if PM contact is configured"""
        return bool(self.pm_name or self.pm_email or self.pm_phone)
    
    @property
    def has_manager_contact(self):
        """Check if manager contact is configured"""
        return bool(self.manager_name or self.manager_email or self.manager_phone)


class Floor(db.Model):
    """
    Floor model for organizing racks within a data center
    Maps provider's weird designations to actual floor numbers
    """
    __tablename__ = 'floors'
    
    # Primary key
    id = db.Column(db.Integer, primary_key=True)
    
    # Foreign key to data center
    datacenter_id = db.Column(db.Integer, db.ForeignKey('datacenters.id'), nullable=False)
    
    # Floor information
    provider_designation = db.Column(db.String(10), nullable=False)  # G, A, B, etc.
    actual_floor = db.Column(db.String(20), nullable=False)  # 1st, 2nd, 3rd, 4th, Basement
    description = db.Column(db.String(100))
    
    # Timestamp
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    
    # Relationships
    racks = db.relationship('Rack', backref='floor', lazy='dynamic', cascade='all, delete-orphan')
    
    def __repr__(self):
        return f'<Floor {self.provider_designation} ({self.actual_floor})>'


class Rack(db.Model):
    """
    Rack model
    Represents a physical rack with location, size, power, and security information
    """
    __tablename__ = 'racks'
    
    # Primary key
    id = db.Column(db.Integer, primary_key=True)
    
    # Foreign key to floor
    floor_id = db.Column(db.Integer, db.ForeignKey('floors.id'), nullable=False)
    
    # Rack identification
    rack_id = db.Column(db.String(20), unique=True, nullable=False)  # Full ID like SFJ-G09.01
    row_number = db.Column(db.String(10), nullable=False)  # G09
    cabinet_number = db.Column(db.String(10), nullable=False)  # 01
    
    # Physical specifications
    u_height = db.Column(db.Integer, nullable=False, default=42)  # Total U height
    u_used = db.Column(db.Integer, default=0)  # Currently used U spaces
    
    # Power specifications
    power_capacity = db.Column(db.Float)  # Total power capacity in amps
    power_used = db.Column(db.Float, default=0)  # Currently used power
    
    # Security
    rack_code = db.Column(db.String(4))  # 4-digit code to unlock rack (e.g., "1234")
    
    # Additional information
    notes = db.Column(db.Text)
    
    # Timestamps
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    updated_at = db.Column(db.DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    
    # Relationships
    pdus = db.relationship('PDU', backref='rack', lazy='dynamic', cascade='all, delete-orphan')
    
    @property
    def u_available(self):
        """Calculate available U spaces"""
        return self.u_height - self.u_used
    
    @property
    def power_available(self):
        """Calculate available power"""
        if self.power_capacity:
            return self.power_capacity - self.power_used
        return None
    
    @property
    def utilization_percent(self):
        """Calculate space utilization percentage"""
        if self.u_height > 0:
            return round((self.u_used / self.u_height) * 100, 1)
        return 0
    
    @property
    def power_utilization_percent(self):
        """Calculate power utilization percentage"""
        if self.power_capacity and self.power_capacity > 0:
            return round((self.power_used / self.power_capacity) * 100, 1)
        return 0
    
    def __repr__(self):
        return f'<Rack {self.rack_id}>'


class PDU(db.Model):
    """
    Power Distribution Unit model
    Represents a PDU within a rack for power distribution
    Tracks model numbers for baseline power calculations
    Includes network switch connectivity for managed PDUs
    IPAM INTEGRATION: IP addresses now tracked through IPAM system
    
    Revision History:
    - v1.1.0 (2024-01-09): Added model field for tracking APC model numbers
    - v1.2.0 (2025-01-15): Added switch connectivity fields
    - v1.3.0 (2025-01-16): Integrated with IPAM for IP address management
    """
    __tablename__ = 'pdus'
    
    # Primary key
    id = db.Column(db.Integer, primary_key=True)
    
    # Foreign key to rack
    rack_id = db.Column(db.Integer, db.ForeignKey('racks.id'), nullable=False)
    
    # PDU identification
    identifier = db.Column(db.String(50), nullable=False)  # APC 1, APC 2, etc.
    model = db.Column(db.String(50))  # AP7932, AP8941, etc.
    circuit_id = db.Column(db.String(50))
    
    # Electrical specifications
    capacity_amps = db.Column(db.Float, nullable=False)
    voltage = db.Column(db.Integer, default=120)  # 120V or 208V
    phase = db.Column(db.String(20))  # Single, Three-Phase
    
    # Outlet information
    total_outlets = db.Column(db.Integer, nullable=False)
    used_outlets = db.Column(db.Integer, default=0)
    
    # ========== IPAM INTEGRATION - CHANGED v1.3.0 ==========
    # REMOVED: ip_address = db.Column(db.String(45))
    # NEW: Link to IPAM system for IP management
    management_ip_id = db.Column(db.Integer, db.ForeignKey('ip_addresses.id'))
    # This links to the IPAddress table in IPAM
    # The IP will be created/assigned when PDU is saved
    
    # ========== NETWORK CONNECTIVITY (v1.2.0) ==========
    # Which switch is this PDU connected to for management?
    connected_switch_id = db.Column(db.Integer, db.ForeignKey('network_devices.id'))
    connected_switch_port = db.Column(db.Integer)  # Port number on the switch
    
    # Additional information
    notes = db.Column(db.Text)
    
    # Timestamps
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    updated_at = db.Column(db.DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    
    # ========== RELATIONSHIPS ==========
    # Existing relationships
    connected_switch = db.relationship('NetworkDevice', 
                                      foreign_keys=[connected_switch_id],
                                      backref='connected_pdus')
    
    # CHANGED v1.3.0: New IPAM relationship
    management_ip = db.relationship('IPAddress', 
                                   foreign_keys=[management_ip_id],
                                   backref='assigned_pdu')
    
    # ========== PROPERTIES ==========
    @property
    def available_outlets(self):
        """Calculate available outlets"""
        return self.total_outlets - self.used_outlets
    
    @property
    def watts_capacity(self):
        """Calculate capacity in watts"""
        return self.capacity_amps * self.voltage
    
    @property
    def is_managed(self):
        """
        Check if PDU is managed (has IP and/or switch connection)
        CHANGED v1.3.0: Check IPAM relationship instead of direct IP field
        """
        return bool(self.management_ip_id or self.connected_switch_id)
    
    @property
    def ip_address(self):
        """
        Get the IP address from IPAM
        CHANGED v1.3.0: Property to maintain backward compatibility
        Returns the actual IP string from the IPAM relationship
        """
        if self.management_ip:
            return self.management_ip.ip_address
        return None
    
    @property
    def ip_details(self):
        """
        Get full IP details from IPAM
        NEW v1.3.0: Returns complete IP information including VLAN, network type, etc.
        """
        if self.management_ip:
            return {
                'ip_address': self.management_ip.ip_address,
                'vlan_id': self.management_ip.vlan_id,
                'network_type': self.management_ip.network_type,
                'dns_name': self.management_ip.dns_name,
                'status': self.management_ip.status,
                'datacenter': self.management_ip.datacenter.code if self.management_ip.datacenter else None
            }
        return None
    
    @property
    def network_connection_display(self):
        """Display network connection info"""
        if self.connected_switch:
            return f"{self.connected_switch.identifier} Port {self.connected_switch_port}"
        return "Not connected"
    
    def assign_ip(self, ip_address_str, vlan_id=None):
        """
        Helper method to assign an IP through IPAM
        NEW v1.3.0: Creates or updates IPAM entry when user enters an IP
        
        Args:
            ip_address_str: The IP address string (e.g., "10.10.5.100")
            vlan_id: Optional VLAN ID for the management network
        
        Returns:
            IPAddress object or raises ValueError if IP is already in use
        """
        from models.ipam import IPAddress
        
        # Check if IP already exists in IPAM
        existing_ip = IPAddress.query.filter_by(ip_address=ip_address_str).first()
        
        if existing_ip:
            if existing_ip.is_assigned and existing_ip.assigned_to_id != self.id:
                # IP is assigned to something else
                raise ValueError(f"IP {ip_address_str} is already assigned to {existing_ip.assigned_device_name}")
            
            # Update existing IP to assign to this PDU
            existing_ip.assigned_to_type = 'pdu'
            existing_ip.assigned_to_id = self.id
            existing_ip.status = 'assigned'
            existing_ip.ip_type = 'management'
            existing_ip.network_type = 'management'
            if vlan_id:
                existing_ip.vlan_id = vlan_id
            existing_ip.updated_at = datetime.utcnow()
            
            self.management_ip_id = existing_ip.id
            return existing_ip
        else:
            # Create new IP in IPAM
            new_ip = IPAddress(
                ip_address=ip_address_str,
                version=4,
                ip_type='management',
                network_type='management',
                vlan_id=vlan_id,
                status='assigned',
                assigned_to_type='pdu',
                assigned_to_id=self.id,
                datacenter_id=self.rack.floor.datacenter_id if self.rack else None,
                description=f"Management IP for PDU {self.identifier}"
            )
            
            db.session.add(new_ip)
            db.session.flush()  # Get the ID without committing
            
            self.management_ip_id = new_ip.id
            return new_ip
    
    def release_ip(self):
        """
        Helper method to release IP in IPAM
        NEW v1.3.0: Releases the IP assignment when PDU is deleted or IP is removed
        """
        if self.management_ip:
            self.management_ip.release()
            self.management_ip_id = None
    
    def __repr__(self):
        return f'<PDU {self.identifier} in Rack {self.rack.rack_id if self.rack else "Unknown"}>'