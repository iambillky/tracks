"""
File: app.py
Purpose: Main Flask application entry point for DCMS
Version: 1.7.0
Author: DCMS Team

Revision History:
- v1.0.0: Initial Flask app setup with dark theme
- v1.0.1: Added SQLAlchemy database initialization
- v1.0.2: Integrated data center blueprint
- v1.1.0: Added network devices blueprint
- v1.2.0: Added PDU management and power profiles
- v1.3.0: Added SwitchPort model for port tracking
- v1.4.0: Added SwitchModel equipment library for automated port creation
- v1.5.0: Added IPAM models and blueprint integration
- v1.6.0: Added VLAN models and blueprint for Phase 1 IPAM
- v1.7.0: CHANGED: Added Server models and blueprint for complete server management
         Includes Server, ServerNetworkConnection, and Customer models
"""

from flask import Flask, render_template, jsonify
from flask_sqlalchemy import SQLAlchemy
from datetime import datetime
import os

# ========== APPLICATION INITIALIZATION ==========

# Initialize Flask application
app = Flask(__name__)

# ========== CONFIGURATION ==========

# Configuration
app.config['SECRET_KEY'] = 'dev-key-change-this-in-production'
app.config['DEBUG'] = True
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///dcms.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

# ========== DATABASE SETUP ==========

# Initialize database
from models.datacenter import db
db.init_app(app)

# ========== BLUEPRINT REGISTRATION ==========

# Register blueprints
from routes.datacenters import datacenters_bp
from routes.network_devices import network_devices_bp
from routes.pdus import pdus_bp

app.register_blueprint(datacenters_bp)
app.register_blueprint(network_devices_bp)
app.register_blueprint(pdus_bp)

# Register IPAM blueprint if it exists
try:
    from routes.ipam import ipam_bp
    app.register_blueprint(ipam_bp)
    ipam_enabled = True
    print("✓ IPAM blueprint registered")
except ImportError:
    ipam_enabled = False
    print("⚠ IPAM blueprint not found - skipping")

# Register VLAN blueprint for Phase 1
vlans_enabled = False
try:
    from routes.vlans import vlans_bp
    app.register_blueprint(vlans_bp)
    vlans_enabled = True
    print("✓ VLAN blueprint registered")
except ImportError:
    print("⚠ VLAN blueprint not found - skipping")

# CHANGED v1.7.0: Register Server blueprint
servers_enabled = False
try:
    from routes.servers import servers_bp
    app.register_blueprint(servers_bp)
    servers_enabled = True
    print("✓ Server blueprint registered")
except ImportError:
    print("⚠ Server blueprint not found - will create it next")

# ========== DATABASE TABLE CREATION AND INITIALIZATION ==========

# Create tables
with app.app_context():
    # Import all models to ensure they're registered with SQLAlchemy
    # IMPORTANT: The order matters for foreign key relationships!
    
    # Import IPAM models FIRST (since PDU now references ip_addresses table)
    try:
        from models.ipam import IPAddress, IPRange
        print("✓ IPAM models imported")
    except ImportError:
        print("⚠ IPAM models not found - PDU IP management will be limited")
        # If IPAM doesn't exist, we need to temporarily fix the PDU model
        # This would require removing the foreign key reference
        pass
    
    # Import VLAN models for Phase 1
    try:
        from models.vlan import VLAN, VLANSubnet
        print("✓ VLAN models imported")
    except ImportError:
        print("⚠ VLAN models not found - Phase 1 IPAM features limited")
        pass
    
    # Import core datacenter models
    from models.datacenter import DataCenter, Floor, Rack, PDU
    from models.power_profiles import PowerProfile, init_default_profiles
    from models.switch_model import SwitchModel, init_default_switch_models  # Must come before NetworkDevice
    from models.network_device import NetworkDevice  # References switch_model
    from models.switch_port import SwitchPort  # References network_device
    
    # CHANGED v1.7.0: Import Server models (after IPAM and datacenter models)
    try:
        from models.server import Server, ServerNetworkConnection, Customer
        print("✓ Server models imported (Server, ServerNetworkConnection, Customer)")
        servers_models_loaded = True
    except ImportError as e:
        print(f"⚠ Server models not found - {e}")
        servers_models_loaded = False
    
    # Create all tables
    db.create_all()
    print("✓ Database tables created successfully")
    
    # Initialize default power profiles for TCH equipment
    existing_profiles = PowerProfile.query.count()
    if existing_profiles == 0:
        init_default_profiles(db.session)
        print("✓ Initialized TCH power profiles")
    else:
        print(f"✓ Power profiles already exist ({existing_profiles} profiles)")
    
    # Initialize switch equipment library with your 6 models
    existing_models = SwitchModel.query.count()
    if existing_models == 0:
        init_default_switch_models(db.session)
        print("✓ Initialized 6 switch models in equipment library")
    else:
        print(f"✓ Switch models already exist ({existing_models} models)")
    
    # Check for existing switches without ports and create them
    existing_switches = NetworkDevice.query.filter(
        NetworkDevice.device_type.in_(['Switch', 'Core'])
    ).all()
    
    if existing_switches:
        switches_needing_ports = []
        for switch in existing_switches:
            if len(switch.ports) == 0:
                switches_needing_ports.append(switch)
        
        if switches_needing_ports:
            print(f"\nFound {len(switches_needing_ports)} switches without ports:")
            for switch in switches_needing_ports:
                # Try to match with a switch model
                if switch.model:
                    switch_model = SwitchModel.query.filter(
                        SwitchModel.model_number.ilike(f'%{switch.model}%')
                    ).first()
                    
                    if switch_model:
                        # Create ports based on model
                        for i in range(1, switch_model.port_count + 1):
                            port = SwitchPort(
                                switch_id=switch.id,
                                port_number=i,
                                port_type=switch_model.port_type,
                                speed_capability=switch_model.port_speed
                            )
                            db.session.add(port)
                        print(f"  ✓ Created {switch_model.port_count} {switch_model.port_type} ports for {switch.identifier}")
                    else:
                        # Default to 48-port 1G if no model match
                        for i in range(1, 49):
                            port = SwitchPort(
                                switch_id=switch.id,
                                port_number=i,
                                port_type='RJ45',
                                speed_capability='1000'
                            )
                            db.session.add(port)
                        print(f"  ✓ Created 48 default ports for {switch.identifier}")
                else:
                    # No model specified, use default
                    for i in range(1, 49):
                        port = SwitchPort(
                            switch_id=switch.id,
                            port_number=i,
                            port_type='RJ45',
                            speed_capability='1000'
                        )
                        db.session.add(port)
                    print(f"  ✓ Created 48 default ports for {switch.identifier}")
            
            db.session.commit()
            print("✓ Port creation complete")
        else:
            print("✓ All switches have ports configured")
    
    # CHANGED v1.7.0: Report on Server module status
    if servers_models_loaded:
        server_count = Server.query.count()
        customer_count = Customer.query.count()
        print(f"✓ Server module ready ({server_count} servers, {customer_count} customers)")

# ========== ROUTES ==========

@app.route('/')
def index():
    """Main dashboard"""
    dc_count = DataCenter.query.count()
    return render_template('index.html',
                         title='Dashboard',
                         dc_count=dc_count,
                         ipam_enabled=ipam_enabled,
                         vlans_enabled=vlans_enabled,
                         servers_enabled=servers_enabled)  # CHANGED v1.7.0

# ========== API ROUTES ==========

@app.route('/api/datacenters')
def api_datacenters():
    """API endpoint to get all datacenters"""
    dcs = DataCenter.query.all()
    return jsonify([
        {'id': dc.id, 'code': dc.code, 'name': dc.name}
        for dc in dcs
    ])

@app.route('/api/racks/<int:dc_id>')
def api_racks(dc_id):
    """API endpoint to get racks for a datacenter"""
    racks = Rack.query.join(Floor).filter(Floor.datacenter_id == dc_id).all()
    return jsonify([
        {'id': rack.id, 'rack_id': rack.rack_id}
        for rack in racks
    ])

@app.route('/api/switch/<int:switch_id>/available-ports')
def api_available_ports(switch_id):
    """API endpoint to get available ports for a switch"""
    from models.switch_port import SwitchPort
    
    available_ports = SwitchPort.query.filter_by(
        switch_id=switch_id,
        is_connected=False
    ).order_by(SwitchPort.port_number).all()
    
    return jsonify({
        'count': len(available_ports),
        'ports': [
            {
                'id': port.id,
                'port_number': port.port_number,
                'port_type': port.port_type
            } for port in available_ports
        ]
    })

# ========== UTILITY ROUTES ==========

@app.route('/health')
def health_check():
    """Health check endpoint"""
    return jsonify({
        'status': 'healthy',
        'timestamp': datetime.now().isoformat(),
        'ipam_enabled': ipam_enabled,
        'vlans_enabled': vlans_enabled,
        'servers_enabled': servers_enabled  # CHANGED v1.7.0
    })

@app.route('/about')
def about():
    """About page"""
    from models.switch_model import SwitchModel
    
    # Get counts for about page
    switch_models = SwitchModel.query.all()
    mikrotik_count = len([m for m in switch_models if m.manufacturer == 'MikroTik'])
    arista_count = len([m for m in switch_models if m.manufacturer == 'Arista'])
    
    # CHANGED v1.7.0: Add server statistics
    server_stats = {}
    if servers_models_loaded:
        server_stats = {
            'total_servers': Server.query.count(),
            'active_servers': Server.query.filter_by(status='active').count(),
            'colo_servers': Server.query.filter(Server.server_id.like('COLO%')).count(),
            'customers': Customer.query.count()
        }
    
    return render_template('about.html',
                         title='About DCMS',
                         version='1.7.0',  # CHANGED v1.7.0
                         mikrotik_count=mikrotik_count,
                         arista_count=arista_count,
                         current_year=datetime.now().year,
                         ipam_enabled=ipam_enabled,
                         vlans_enabled=vlans_enabled,
                         servers_enabled=servers_enabled,  # CHANGED v1.7.0
                         server_stats=server_stats)  # CHANGED v1.7.0

# ========== ERROR HANDLERS ==========

@app.errorhandler(404)
def not_found(error):
    """Handle 404 errors"""
    return render_template('404.html'), 404

@app.errorhandler(500)
def internal_error(error):
    """Handle 500 errors"""
    db.session.rollback()
    return render_template('500.html'), 500

# ========== MAIN EXECUTION ==========

if __name__ == '__main__':
    print("\n" + "="*50)
    print("Data Center Management System (DCMS)")
    print("Version 1.7.0")  # CHANGED v1.7.0
    print("="*50)
    print("\nStarting application...")
    print(f"Database: sqlite:///dcms.db")
    print(f"Debug mode: True")
    print(f"IPAM: {'Enabled' if ipam_enabled else 'Disabled'}")
    print(f"VLANs: {'Enabled' if vlans_enabled else 'Disabled'}")
    print(f"Servers: {'Enabled' if servers_enabled else 'Disabled'}")  # CHANGED v1.7.0
    print(f"URL: http://localhost:5000")
    print("\nPress CTRL+C to stop the server")
    print("="*50 + "\n")
    
    app.run(host='0.0.0.0', port=5000, debug=True)