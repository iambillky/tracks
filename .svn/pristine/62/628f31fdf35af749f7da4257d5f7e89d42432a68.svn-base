<!--
File: templates/vlans/view_vlan.html  
Purpose: Display VLAN details with all associated subnets
Version: 1.1.0
Author: DCMS Team
Date: 2025-01-16

Revision History:
- v1.0.0: Initial creation with VLAN details and subnet table
- v1.1.0: Added netmask display in subnet table
-->

{% extends "base.html" %}

{% block title %}VLAN {{ vlan.vlan_id }} - {{ vlan.name }}{% endblock %}

{% block extra_css %}
<style>
    /* ========== PAGE CONTAINER ========== */
    .page-container {
        width: 100%;
        padding: 20px;
    }
    
    /* ========== PAGE HEADER ========== */
    .page-header {
        background: linear-gradient(135deg, rgba(96, 165, 250, 0.1), rgba(96, 165, 250, 0.05));
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
    }
    
    .page-header h1 {
        color: #fff;
        font-size: 2rem;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .vlan-badge {
        background: linear-gradient(135deg, #60a5fa, #3b82f6);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-size: 1.5rem;
        font-weight: bold;
    }
    
    .page-header .description {
        color: #94a3b8;
        margin: 10px 0 0 0;
        font-size: 1.1rem;
    }
    
    /* ========== INFO GRID ========== */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .info-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 20px;
    }
    
    .info-card h3 {
        color: #60a5fa;
        font-size: 1rem;
        margin-bottom: 15px;
        text-transform: uppercase;
        font-weight: 600;
    }
    
    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .info-item:last-child {
        border-bottom: none;
    }
    
    .info-label {
        color: #94a3b8;
    }
    
    .info-value {
        color: #e2e8f0;
        font-weight: 500;
    }
    
    /* ========== PURPOSE BADGE ========== */
    .purpose-badge {
        display: inline-block;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
    }
    
    .purpose-infrastructure {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.3);
    }
    
    .purpose-colocation {
        background: rgba(168, 85, 247, 0.2);
        color: #a855f7;
        border: 1px solid rgba(168, 85, 247, 0.3);
    }
    
    .purpose-management {
        background: rgba(251, 146, 60, 0.2);
        color: #fb923c;
        border: 1px solid rgba(251, 146, 60, 0.3);
    }
    
    .purpose-private {
        background: rgba(96, 165, 250, 0.2);
        color: #60a5fa;
        border: 1px solid rgba(96, 165, 250, 0.3);
    }
    
    /* ========== SUBNETS SECTION ========== */
    .subnets-section {
        margin-bottom: 30px;
    }
    
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    
    .section-title {
        color: #fff;
        font-size: 1.5rem;
        font-weight: 600;
    }
    
    /* ========== SUBNET TABLE ========== */
    .subnet-table {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
    }
    
    .subnet-table th {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        font-weight: 600;
        padding: 15px;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .subnet-table td {
        color: #e2e8f0;
        padding: 12px 15px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }
    
    .subnet-table tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }
    
    .subnet-network {
        font-family: 'Courier New', monospace;
        font-size: 1.1rem;
        color: #60a5fa;
        font-weight: 600;
    }
    
    /* CHANGED: Added netmask styling */
    .subnet-netmask {
        font-family: 'Courier New', monospace;
        color: #94a3b8;
        font-size: 0.95rem;
    }
    
    .subnet-gateway {
        font-family: 'Courier New', monospace;
        color: #e2e8f0;
    }
    
    .subnet-type {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }
    
    .type-primary {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
        border: 1px solid rgba(34, 197, 94, 0.3);
    }
    
    .type-secondary {
        background: rgba(148, 163, 184, 0.2);
        color: #94a3b8;
        border: 1px solid rgba(148, 163, 184, 0.3);
    }
    
    /* ========== IP STATS ========== */
    .ip-stats {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    
    .ip-stat {
        display: flex;
        flex-direction: column;
    }
    
    .ip-stat-value {
        font-weight: 600;
        font-size: 1.1rem;
        color: #e2e8f0;
    }
    
    .ip-stat-label {
        font-size: 0.75rem;
        color: #64748b;
        text-transform: uppercase;
    }
    
    /* ========== UTILIZATION BAR ========== */
    .utilization-bar {
        width: 100%;
        height: 24px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        overflow: hidden;
        position: relative;
    }
    
    .utilization-fill {
        height: 100%;
        background: linear-gradient(90deg, #22c55e, #16a34a);
        transition: width 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .utilization-fill.warning {
        background: linear-gradient(90deg, #fb923c, #f97316);
    }
    
    .utilization-fill.danger {
        background: linear-gradient(90deg, #ef4444, #dc2626);
    }
    
    .utilization-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-weight: 600;
        font-size: 0.85rem;
    }
    
    /* ========== ACTION BAR ========== */
    .action-bar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 30px;
    }
    
    /* ========== BUTTONS ========== */
    .btn {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #60a5fa, #3b82f6);
        color: white;
    }
    
    .btn-primary:hover {
        box-shadow: 0 5px 20px rgba(96, 165, 250, 0.4);
        transform: translateY(-1px);
    }
    
    .btn-secondary {
        background: transparent;
        color: #94a3b8;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #e2e8f0;
    }
    
    .btn-danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        border: none;
    }
    
    .btn-danger:hover {
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        box-shadow: 0 5px 20px rgba(239, 68, 68, 0.4);
    }
    
    /* ========== NOTES SECTION ========== */
    .notes-section {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 20px;
        margin-top: 20px;
    }
    
    .notes-title {
        color: #94a3b8;
        font-size: 0.9rem;
        margin-bottom: 10px;
        text-transform: uppercase;
    }
    
    .notes-content {
        color: #e2e8f0;
        line-height: 1.6;
    }
    
    /* ========== EMPTY STATE ========== */
    .empty-state {
        text-align: center;
        padding: 40px;
        color: #64748b;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 8px;
    }
</style>
{% endblock %}

{% block content %}
<div class="page-container">
    <!-- ========== PAGE HEADER ========== -->
    <div class="page-header">
        <h1>
            <span class="vlan-badge">VLAN {{ vlan.vlan_id }}</span>
            {{ vlan.name }}
        </h1>
        {% if vlan.description %}
        <p class="description">{{ vlan.description }}</p>
        {% endif %}
    </div>
    
    <!-- ========== ACTION BAR ========== -->
    <div class="action-bar">
        <div style="display: flex; gap: 10px;">
            <a href="{{ url_for('vlans.index') }}" class="btn btn-secondary">
                ← Back to VLANs
            </a>
            <a href="{{ url_for('vlans.add_subnet', vlan_id=vlan.id) }}" class="btn btn-primary">
                ➕ Add Subnet
            </a>
        </div>
        
        <!-- Delete button with confirmation -->
        <form method="POST" action="{{ url_for('vlans.delete_vlan', vlan_id=vlan.id) }}" 
              style="display: inline;" 
              onsubmit="return confirm('Are you sure you want to delete VLAN {{ vlan.vlan_id }} ({{ vlan.name }})?\n\nThis will also delete {{ vlan.subnet_count }} subnet(s) and cannot be undone.');">
            <button type="submit" class="btn btn-danger">
                🗑️ Delete VLAN
            </button>
        </form>
    </div>
    
    <!-- ========== INFO GRID ========== -->
    <div class="info-grid">
        <div class="info-card">
            <h3>Configuration</h3>
            <div class="info-item">
                <span class="info-label">Purpose:</span>
                <span class="info-value">
                    <span class="purpose-badge purpose-{{ vlan.purpose }}">
                        {{ vlan.purpose }}
                    </span>
                </span>
            </div>
            <div class="info-item">
                <span class="info-label">Status:</span>
                <span class="info-value">{{ vlan.status|title }}</span>
            </div>
            <div class="info-item">
                <span class="info-label">Data Center:</span>
                <span class="info-value">
                    {% if vlan.datacenter %}
                        {{ vlan.datacenter.code }} - {{ vlan.datacenter.name }}
                    {% else %}
                        Not Assigned
                    {% endif %}
                </span>
            </div>
        </div>
        
        <div class="info-card">
            <h3>Statistics</h3>
            <div class="info-item">
                <span class="info-label">Total Subnets:</span>
                <span class="info-value">{{ vlan.subnet_count }}</span>
            </div>
            <div class="info-item">
                <span class="info-label">Primary Subnets:</span>
                <span class="info-value">{{ vlan.subnets|selectattr('is_primary', 'equalto', True)|list|length }}</span>
            </div>
            <div class="info-item">
                <span class="info-label">Secondary Subnets:</span>
                <span class="info-value">{{ vlan.subnets|selectattr('is_primary', 'equalto', False)|list|length }}</span>
            </div>
            <div class="info-item">
                <span class="info-label">Total IP Count:</span>
                <span class="info-value" style="font-size: 1.2rem; color: #60a5fa;">
                    {{ vlan.total_ip_count }}
                </span>
            </div>
        </div>
    </div>
    
    <!-- ========== SUBNETS SECTION ========== -->
    <div class="subnets-section">
        <div class="section-header">
            <h2 class="section-title">Subnets</h2>
        </div>
        
        {% if vlan.subnets %}
        <table class="subnet-table">
            <thead>
                <tr>
                    <th width="20%">Subnet</th>
                    <th width="15%">Netmask</th> <!-- CHANGED: Added Netmask column -->
                    <th width="15%">Gateway</th>
                    <th width="10%">Type</th>
                    <th width="12%">Total IPs</th>
                    <th width="13%">Available</th>
                    <th width="15%">Utilization</th>
                </tr>
            </thead>
            <tbody>
                {% for subnet in vlan.subnets %}
                <tr>
                    <td>
                        <span class="subnet-network">{{ subnet.subnet }}</span>
                    </td>
                    <td>
                        <!-- CHANGED: Calculate and display netmask from CIDR -->
                        <span class="subnet-netmask">
                            {% if subnet.cidr %}
                                {% if subnet.cidr == 8 %}255.0.0.0
                                {% elif subnet.cidr == 9 %}255.128.0.0
                                {% elif subnet.cidr == 10 %}255.192.0.0
                                {% elif subnet.cidr == 11 %}255.224.0.0
                                {% elif subnet.cidr == 12 %}255.240.0.0
                                {% elif subnet.cidr == 13 %}255.248.0.0
                                {% elif subnet.cidr == 14 %}255.252.0.0
                                {% elif subnet.cidr == 15 %}255.254.0.0
                                {% elif subnet.cidr == 16 %}255.255.0.0
                                {% elif subnet.cidr == 17 %}255.255.128.0
                                {% elif subnet.cidr == 18 %}255.255.192.0
                                {% elif subnet.cidr == 19 %}255.255.224.0
                                {% elif subnet.cidr == 20 %}255.255.240.0
                                {% elif subnet.cidr == 21 %}255.255.248.0
                                {% elif subnet.cidr == 22 %}255.255.252.0
                                {% elif subnet.cidr == 23 %}255.255.254.0
                                {% elif subnet.cidr == 24 %}255.255.255.0
                                {% elif subnet.cidr == 25 %}255.255.255.128
                                {% elif subnet.cidr == 26 %}255.255.255.192
                                {% elif subnet.cidr == 27 %}255.255.255.224
                                {% elif subnet.cidr == 28 %}255.255.255.240
                                {% elif subnet.cidr == 29 %}255.255.255.248
                                {% elif subnet.cidr == 30 %}255.255.255.252
                                {% elif subnet.cidr == 31 %}255.255.255.254
                                {% elif subnet.cidr == 32 %}255.255.255.255
                                {% else %}-
                                {% endif %}
                            {% else %}
                                -
                            {% endif %}
                        </span>
                    </td>
                    <td>
                        <span class="subnet-gateway">{{ subnet.gateway }}</span>
                    </td>
                    <td>
                        <span class="subnet-type {% if subnet.is_primary %}type-primary{% else %}type-secondary{% endif %}">
                            {% if subnet.is_primary %}Primary{% else %}Secondary{% endif %}
                        </span>
                    </td>
                    <td>
                        <div class="ip-stats">
                            <div class="ip-stat">
                                <span class="ip-stat-value">{{ subnet.total_ips }}</span>
                                <span class="ip-stat-label">Total</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="ip-stats">
                            <div class="ip-stat">
                                <span class="ip-stat-value">{{ subnet.available_count }}</span>
                                <span class="ip-stat-label">Available</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="utilization-bar">
                            {% set util_percent = subnet.utilization_percent %}
                            <div class="utilization-fill 
                                       {% if util_percent >= 90 %}danger
                                       {% elif util_percent >= 75 %}warning
                                       {% endif %}" 
                                 style="width: {{ util_percent }}%">
                            </div>
                            <span class="utilization-text">{{ util_percent }}%</span>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty-state">
            <p>No subnets configured for this VLAN</p>
            <a href="{{ url_for('vlans.add_subnet', vlan_id=vlan.id) }}" class="btn btn-primary">
                Add First Subnet
            </a>
        </div>
        {% endif %}
    </div>
    
    <!-- ========== NOTES SECTION ========== -->
    {% if vlan.notes %}
    <div class="notes-section">
        <div class="notes-title">Notes</div>
        <div class="notes-content">{{ vlan.notes }}</div>
    </div>
    {% endif %}
</div>
{% endblock %}