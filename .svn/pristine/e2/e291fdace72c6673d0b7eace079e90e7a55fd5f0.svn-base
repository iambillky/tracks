<!--
File: templates/network_devices/add_device.html
Purpose: Form template for adding new network devices
Version: 1.1.0
Author: iambilky

Revision History:
- v1.0.0: Initial creation with form layout and validation
- v1.1.0: Added PDU outlet error display blocks for better UX
-->

{% extends "base.html" %}

{% block title %}Add Network Device{% endblock %}

{% block extra_css %}
<style>
    /* ========== FORM CONTAINER ========== */
    .form-container {
        max-width: 1000px;
        margin: 0 auto;
    }
    
    .form-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 30px;
    }
    
    /* ========== FORM SECTIONS ========== */
    .form-section {
        margin-bottom: 35px;
    }
    
    .form-section-title {
        color: #60a5fa;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    /* ========== FORM GROUPS ========== */
    .form-group {
        margin-bottom: 25px;
    }
    
    .form-label {
        display: block;
        color: #e4e6eb;
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    .form-label .required {
        color: #ef4444;
        margin-left: 3px;
    }
    
    /* ========== FORM CONTROLS ========== */
    .form-control {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 10px 14px;
        color: #fff;
        font-size: 1rem;
        transition: all 0.2s ease;
    }
    
    .form-control:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.1);
        border-color: #60a5fa;
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
    }
    
    .form-control::placeholder {
        color: #6b7280;
    }
    
    select.form-control {
        cursor: pointer;
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 100px;
        font-family: inherit;
    }
    
    /* ========== VALIDATION ========== */
    .invalid-feedback {
        display: block;
        color: #ef4444;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    .form-control.is-invalid {
        border-color: #ef4444;
    }
    
    /* ========== HELP TEXT ========== */
    .form-text {
        display: block;
        color: #8b92a5;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    /* ========== NETWORK TYPE HINT ========== */
    .network-hint {
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 8px;
        padding: 12px;
        margin-top: 10px;
        display: none;
    }
    
    .network-hint.show {
        display: block;
    }
    
    .network-hint.private {
        background: rgba(167, 139, 250, 0.1);
        border-color: rgba(167, 139, 250, 0.2);
        color: #a78bfa;
    }
    
    .network-hint.public {
        background: rgba(52, 211, 153, 0.1);
        border-color: rgba(52, 211, 153, 0.2);
        color: #34d399;
    }
    
    /* ========== RESPONSIVE GRID ========== */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    
    .form-row-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }
    
    /* ========== BUTTON GROUP ========== */
    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 35px;
        padding-top: 25px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        color: white;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
    }
    
    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s ease;
    }
    
    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
    }
</style>
{% endblock %}

{% block content %}
<div class="form-container">
    <h2 style="color: #60a5fa; margin-bottom: 30px;">Add Network Device</h2>
    
    <div class="form-card">
        <form method="POST" action="{{ url_for('network_devices.add_device') }}" novalidate>
            {{ form.hidden_tag() }}
            
            <!-- ========== DEVICE IDENTIFICATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Device Identification</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.hostname.id }}" class="form-label">
                            Hostname <span class="required">*</span>
                        </label>
                        {{ form.hostname(class="form-control" + (" is-invalid" if form.hostname.errors else "")) }}
                        <small class="form-text">Full device hostname</small>
                        {% if form.hostname.errors %}
                            {% for error in form.hostname.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.identifier.id }}" class="form-label">
                            Identifier <span class="required">*</span>
                        </label>
                        {{ form.identifier(class="form-control" + (" is-invalid" if form.identifier.errors else "")) }}
                        <small class="form-text">Short identifier (INT5, DISTRO1, etc.)</small>
                        {% if form.identifier.errors %}
                            {% for error in form.identifier.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.device_type.id }}" class="form-label">
                            Device Type <span class="required">*</span>
                        </label>
                        {{ form.device_type(class="form-control") }}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.device_role.id }}" class="form-label">
                            Device Role <span class="required">*</span>
                        </label>
                        {{ form.device_role(class="form-control") }}
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.network_type.id }}" class="form-label">
                            Network Type <span class="required">*</span>
                        </label>
                        {{ form.network_type(class="form-control" + (" is-invalid" if form.network_type.errors else "")) }}
                        <div id="networkHint" class="network-hint">
                            <span id="networkHintText"></span>
                        </div>
                        {% if form.network_type.errors %}
                            {% for error in form.network_type.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                <!-- ========== SWITCH MODEL SELECTION (NEW) ========== -->
                <div class="form-row" id="switch-model-row" style="display: none;">
                    <div class="form-group">
                        <label for="{{ form.switch_model_id.id }}" class="form-label">
                            Switch Model <span style="color: #60a5fa;">(Select to auto-populate specs)</span>
                        </label>
                        {{ form.switch_model_id(class="form-control", id="switch_model_select") }}
                        <small class="form-text">
                            Selecting a model will automatically set manufacturer, model, port count, and power consumption
                        </small>
                    </div>
                </div>
            </div>
            
            <!-- ========== HARDWARE INFORMATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Hardware Information</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.manufacturer.id }}" class="form-label">
                            Manufacturer
                        </label>
                        {{ form.manufacturer(class="form-control") }}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.model.id }}" class="form-label">
                            Model
                        </label>
                        {{ form.model(class="form-control") }}
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.serial_number.id }}" class="form-label">
                            Serial Number
                        </label>
                        {{ form.serial_number(class="form-control") }}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.software_version.id }}" class="form-label">
                            Software Version
                        </label>
                        {{ form.software_version(class="form-control") }}
                        <small class="form-text">IOS version, firmware, etc.</small>
                    </div>
                </div>
            </div>
            
            <!-- ========== PHYSICAL LOCATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Physical Location</h3>
                
                <div class="form-group">
                    <label for="{{ form.rack_id.id }}" class="form-label">
                        Rack Location <span class="required">*</span>
                    </label>
                    {{ form.rack_id(class="form-control" + (" is-invalid" if form.rack_id.errors else "")) }}
                    {% if form.rack_id.errors %}
                        {% for error in form.rack_id.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.start_u.id }}" class="form-label">
                            Starting U Position <span class="required">*</span>
                        </label>
                        {{ form.start_u(class="form-control" + (" is-invalid" if form.start_u.errors else "")) }}
                        <small class="form-text">Top of rack is typically U42</small>
                        {% if form.start_u.errors %}
                            {% for error in form.start_u.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.size_u.id }}" class="form-label">
                            Size (in U) <span class="required">*</span>
                        </label>
                        {{ form.size_u(class="form-control" + (" is-invalid" if form.size_u.errors else "")) }}
                        <small class="form-text">Number of rack units</small>
                        {% if form.size_u.errors %}
                            {% for error in form.size_u.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- ========== NETWORK CONFIGURATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Network Configuration</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.management_ip.id }}" class="form-label">
                            Management IP
                        </label>
                        {{ form.management_ip(class="form-control" + (" is-invalid" if form.management_ip.errors else "")) }}
                        <small class="form-text">Device management IP address</small>
                        {% if form.management_ip.errors %}
                            {% for error in form.management_ip.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.port_count.id }}" class="form-label">
                            Port Count
                        </label>
                        {{ form.port_count(class="form-control") }}
                        <small class="form-text">Total number of ports</small>
                    </div>
                </div>
                
                <!-- ADD THIS NEW ROW FOR VLAN -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.vlan_id.id }}" class="form-label">
                            VLAN Assignment
                        </label>
                        {{ form.vlan_id(class="form-control") }}
                        <small class="form-text">Assign device to a VLAN</small>
                        {% if form.vlan_id.errors %}
                            {% for error in form.vlan_id.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- ========== POWER CONFIGURATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Power Configuration</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.pdu_1_id.id }}" class="form-label">
                            Primary PDU
                        </label>
                        {{ form.pdu_1_id(class="form-control" + (" is-invalid" if form.pdu_1_id.errors else "")) }}
                        {% if form.pdu_1_id.errors %}
                            {% for error in form.pdu_1_id.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.pdu_1_outlet.id }}" class="form-label">
                            Primary PDU Outlet
                        </label>
                        {{ form.pdu_1_outlet(class="form-control" + (" is-invalid" if form.pdu_1_outlet.errors else "")) }}
                        {% if form.pdu_1_outlet.errors %}
                            {% for error in form.pdu_1_outlet.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.pdu_2_id.id }}" class="form-label">
                            Redundant PDU (optional)
                        </label>
                        {{ form.pdu_2_id(class="form-control" + (" is-invalid" if form.pdu_2_id.errors else "")) }}
                        {% if form.pdu_2_id.errors %}
                            {% for error in form.pdu_2_id.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.pdu_2_outlet.id }}" class="form-label">
                            Redundant PDU Outlet
                        </label>
                        {{ form.pdu_2_outlet(class="form-control" + (" is-invalid" if form.pdu_2_outlet.errors else "")) }}
                        {% if form.pdu_2_outlet.errors %}
                            {% for error in form.pdu_2_outlet.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="{{ form.power_consumption.id }}" class="form-label">
                        Power Consumption (Watts) <span class="required">*</span>
                    </label>
                    {{ form.power_consumption(class="form-control" + (" is-invalid" if form.power_consumption.errors else ""), required=true) }}
                    {% if form.power_consumption.errors %}
                        {% for error in form.power_consumption.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                    <small class="form-text">REQUIRED - Enter actual device power consumption in watts</small>
                </div>
            </div>
            
            <!-- ========== STATUS & NOTES ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Status & Notes</h3>
                
                <div class="form-group">
                    <label for="{{ form.status.id }}" class="form-label">
                        Status <span class="required">*</span>
                    </label>
                    {{ form.status(class="form-control") }}
                </div>
                
                <div class="form-group">
                    <label for="{{ form.notes.id }}" class="form-label">
                        Notes
                    </label>
                    {{ form.notes(class="form-control") }}
                </div>
            </div>
            
            <!-- ========== ACTION BUTTONS ========== -->
            <div class="button-group">
                <button type="submit" class="btn btn-success">
                    <span style="margin-right: 8px;">✓</span> Add Device
                </button>
                <a href="{{ url_for('network_devices.index') }}" class="btn btn-cancel">
                    <span style="margin-right: 8px;">✕</span> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// ========== AUTO-UPPERCASE FIELDS ==========
document.getElementById('{{ form.hostname.id }}').addEventListener('input', function(e) {
    e.target.value = e.target.value.toUpperCase();
});

document.getElementById('{{ form.identifier.id }}').addEventListener('input', function(e) {
    e.target.value = e.target.value.toUpperCase();
});

// ========== NETWORK TYPE HINTS ==========
document.getElementById('{{ form.network_type.id }}').addEventListener('change', function(e) {
    const hint = document.getElementById('networkHint');
    const hintText = document.getElementById('networkHintText');
    
    hint.className = 'network-hint';
    
    switch(e.target.value) {
        case 'private':
            hint.classList.add('show', 'private');
            hintText.textContent = '💡 Private network devices typically use INT or PRIV prefix (e.g., INT5, PRIVCORE)';
            break;
        case 'public':
            hint.classList.add('show', 'public');
            hintText.textContent = '💡 Public network devices typically use DISTRO or CORE prefix (e.g., DISTRO1, CORE)';
            break;
        case 'both':
            hint.classList.add('show');
            hintText.textContent = '💡 Device handles both public and private traffic';
            break;
        default:
            hint.classList.remove('show');
    }
});

// ========== PDU CONFLICT CHECKING ==========
document.addEventListener('DOMContentLoaded', function() {
    const pdu1Select = document.getElementById('{{ form.pdu_1_id.id }}');
    const pdu1Outlet = document.getElementById('{{ form.pdu_1_outlet.id }}');
    const pdu2Select = document.getElementById('{{ form.pdu_2_id.id }}');
    const pdu2Outlet = document.getElementById('{{ form.pdu_2_outlet.id }}');
    
    function checkPDUConflicts() {
        // Clear any previous warnings
        clearPDUWarnings();
        
        // Check if same PDU is selected for both
        if (pdu1Select.value && pdu2Select.value && pdu1Select.value === pdu2Select.value) {
            // Check if same outlet is used
            if (pdu1Outlet.value && pdu2Outlet.value && pdu1Outlet.value === pdu2Outlet.value) {
                showPDUWarning(pdu2Outlet, 'Cannot use the same outlet for primary and redundant power on the same PDU');
            }
        }
    }
    
    function showPDUWarning(element, message) {
        element.classList.add('is-invalid');
        
        // Remove any existing error message
        const existingError = element.parentElement.querySelector('.invalid-feedback.dynamic');
        if (existingError) {
            existingError.remove();
        }
        
        // Add new error message
        const errorDiv = document.createElement('div');
        errorDiv.className = 'invalid-feedback dynamic';
        errorDiv.textContent = message;
        element.parentElement.appendChild(errorDiv);
    }
    
    function clearPDUWarnings() {
        // Clear dynamic warnings only
        document.querySelectorAll('.invalid-feedback.dynamic').forEach(el => el.remove());
        
        // Don't clear server-side validation errors
        if (!pdu1Outlet.parentElement.querySelector('.invalid-feedback:not(.dynamic)')) {
            pdu1Outlet.classList.remove('is-invalid');
        }
        if (!pdu2Outlet.parentElement.querySelector('.invalid-feedback:not(.dynamic)')) {
            pdu2Outlet.classList.remove('is-invalid');
        }
    }
    
    // Add event listeners
    if (pdu1Select) pdu1Select.addEventListener('change', checkPDUConflicts);
    if (pdu1Outlet) pdu1Outlet.addEventListener('change', checkPDUConflicts);
    if (pdu2Select) pdu2Select.addEventListener('change', checkPDUConflicts);
    if (pdu2Outlet) pdu2Outlet.addEventListener('change', checkPDUConflicts);
});

// ========== FORM VALIDATION FEEDBACK ==========
document.querySelectorAll('.form-control').forEach(function(input) {
    input.addEventListener('input', function() {
        if (this.classList.contains('is-invalid')) {
            this.classList.remove('is-invalid');
            const feedback = this.parentElement.querySelectorAll('.invalid-feedback:not(.dynamic)');
            feedback.forEach(function(msg) {
                msg.style.display = 'none';
            });
        }
    });
});

// ========== SWITCH MODEL AUTO-POPULATION ==========
document.addEventListener('DOMContentLoaded', function() {
    const deviceTypeSelect = document.getElementById('{{ form.device_type.id }}');
    const switchModelRow = document.getElementById('switch-model-row');
    const switchModelSelect = document.getElementById('switch_model_select');
    
    // Show/hide switch model dropdown based on device type
    function toggleSwitchModel() {
        if (deviceTypeSelect.value === 'Switch' || deviceTypeSelect.value === 'Core') {
            switchModelRow.style.display = 'block';
        } else {
            switchModelRow.style.display = 'none';
            switchModelSelect.value = '0';
        }
    }
    
    // Initial check
    toggleSwitchModel();
    
    // Listen for device type changes
    deviceTypeSelect.addEventListener('change', toggleSwitchModel);
    
    // Auto-populate fields when switch model is selected
    switchModelSelect.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        
        if (this.value && this.value !== '0') {
            // Parse the display name to extract details
            const displayName = selectedOption.text;
            
            // Extract manufacturer (first word)
            const manufacturer = displayName.split(' ')[0];
            
            // Extract model number (look for pattern like CRS354-48G-4S+2Q+)
            const modelMatch = displayName.match(/([A-Z]+[\d\-\+A-Z]+)/);
            const model = modelMatch ? modelMatch[1] : '';
            
            // Extract port count from parentheses
            const portMatch = displayName.match(/\(.*?(\d+)x/);
            let totalPorts = 0;
            
            // Count all port types mentioned
            const portCounts = displayName.match(/(\d+)x/g);
            if (portCounts) {
                portCounts.forEach(match => {
                    totalPorts += parseInt(match);
                });
            }
            
            // Determine typical power based on model
            let typicalPower = 100; // Default
            if (displayName.includes('CSS326-24G')) typicalPower = 35;
            else if (displayName.includes('CRS326-24S')) typicalPower = 50;
            else if (displayName.includes('CRS354-48G')) typicalPower = 60;
            else if (displayName.includes('7048T')) typicalPower = 125;
            else if (displayName.includes('7124SX')) typicalPower = 175;
            else if (displayName.includes('7050S-52')) typicalPower = 210;
            
            // Auto-fill the fields
            document.getElementById('{{ form.manufacturer.id }}').value = manufacturer;
            document.getElementById('{{ form.model.id }}').value = model;
            document.getElementById('{{ form.port_count.id }}').value = totalPorts;
            document.getElementById('{{ form.power_consumption.id }}').value = typicalPower;
            document.getElementById('{{ form.size_u.id }}').value = 1; // All your switches are 1U
            
            // Show a notification
            const notification = document.createElement('div');
            notification.className = 'alert alert-success';
            notification.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; padding: 15px; border-radius: 8px; background: rgba(16, 185, 129, 0.2); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981;';
            notification.textContent = `Auto-populated specs for ${model}: ${totalPorts} ports, ${typicalPower}W power`;
            document.body.appendChild(notification);
            
            setTimeout(() => notification.remove(), 3000);
        }
    });
});

// IP validation and VLAN detection for management IP field
function validateManagementIP() {
    const ipInput = document.getElementById('{{ form.management_ip.id }}');
    const ip = ipInput.value.trim();
    const vlanSelect = document.getElementById('{{ form.vlan_id.id }}');
    
    // Create or find feedback div
    let feedbackDiv = document.getElementById('mgmtIpFeedback');
    if (!feedbackDiv) {
        feedbackDiv = document.createElement('div');
        feedbackDiv.id = 'mgmtIpFeedback';
        feedbackDiv.style.marginTop = '5px';
        ipInput.parentElement.appendChild(feedbackDiv);
    }
    
    if (!ip) {
        feedbackDiv.innerHTML = '';
        ipInput.classList.remove('is-invalid');
        return;
    }
    
    // Check IP availability using the existing API
    fetch(`/servers/api/ip/check-availability?ip=${encodeURIComponent(ip)}`)
        .then(response => response.json())
        .then(data => {
            if (data.available) {
                feedbackDiv.innerHTML = '<span style="color: #10b981;">✓ IP is available</span>';
                ipInput.classList.remove('is-invalid');
                ipInput.classList.add('is-valid');
                
                // Now auto-detect VLAN
                detectVLAN(ip);
                
            } else if (data.not_tch_ip) {
                // Not a TCH IP
                feedbackDiv.innerHTML = '<span style="color: #ef4444;">❌ ' + (data.error || 'IP IS NOT A TCH IP') + '</span>';
                ipInput.classList.add('is-invalid');
                ipInput.classList.remove('is-valid');
            } else {
                // IP already assigned
                feedbackDiv.innerHTML = '<span style="color: #ef4444;">❌ IP already assigned to ' + (data.assigned_to || data.device_info) + '</span>';
                ipInput.classList.add('is-invalid');
                ipInput.classList.remove('is-valid');
            }
        })
        .catch(err => {
            console.error('Error checking IP:', err);
            feedbackDiv.innerHTML = '<span style="color: #f59e0b;">⚠ Unable to verify IP</span>';
        });
}

// Auto-detect VLAN from IP
function detectVLAN(ip) {
    const vlanSelect = document.getElementById('{{ form.vlan_id.id }}');
    
    // Create or find VLAN feedback div
    let vlanFeedback = document.getElementById('vlanDetectionFeedback');
    if (!vlanFeedback) {
        vlanFeedback = document.createElement('div');
        vlanFeedback.id = 'vlanDetectionFeedback';
        vlanFeedback.style.marginTop = '5px';
        vlanFeedback.style.color = '#10b981';
        vlanSelect.parentElement.appendChild(vlanFeedback);
    }
    
    fetch(`/servers/api/detect-vlan?ip=${encodeURIComponent(ip)}`)
        .then(response => response.json())
        .then(data => {
            if (data.found && data.vlan_id) {
                // Auto-select the VLAN
                vlanSelect.value = data.vlan_id;
                vlanFeedback.innerHTML = `✓ Auto-detected VLAN ${data.vlan_number} - ${data.vlan_name}`;
                
                // Clear the message after a few seconds
                setTimeout(() => {
                    vlanFeedback.innerHTML = '';
                }, 5000);
            } else {
                vlanFeedback.innerHTML = '';
            }
        })
        .catch(err => {
            console.error('Error detecting VLAN:', err);
            vlanFeedback.innerHTML = '';
        });
}

// Add event listener when page loads
document.addEventListener('DOMContentLoaded', function() {
    const mgmtIpField = document.getElementById('{{ form.management_ip.id }}');
    if (mgmtIpField) {
        mgmtIpField.addEventListener('blur', validateManagementIP);
    }
});

// PDU outlet availability checking
function checkPDUOutletAvailability(pduFieldId, outletFieldId) {
    const pduSelect = document.getElementById(pduFieldId);
    const outletInput = document.getElementById(outletFieldId);
    const pduId = pduSelect.value;
    const outlet = outletInput.value;
    
    // NO device.id here - this is for NEW devices
    
    // Create or find feedback div
    let feedbackDiv = document.getElementById(outletFieldId + 'Feedback');
    if (!feedbackDiv) {
        feedbackDiv = document.createElement('div');
        feedbackDiv.id = outletFieldId + 'Feedback';
        feedbackDiv.style.marginTop = '5px';
        outletInput.parentElement.appendChild(feedbackDiv);
    }
    
    if (!pduId || pduId === '0' || !outlet) {
        feedbackDiv.innerHTML = '';
        outletInput.classList.remove('is-invalid', 'is-valid');
        return;
    }
    
    // Check outlet availability using the existing API
    fetch(`/servers/api/pdu/${pduId}/outlet/${outlet}/availability`)
        .then(response => response.json())
        .then(data => {
            if (data.error) {
                feedbackDiv.innerHTML = `<span style="color: #f59e0b;">⚠ ${data.error}</span>`;
                outletInput.classList.add('is-invalid');
                outletInput.classList.remove('is-valid');
            } else if (data.available) {
                feedbackDiv.innerHTML = `<span style="color: #10b981;">✓ Outlet ${outlet} is available</span>`;
                outletInput.classList.remove('is-invalid');
                outletInput.classList.add('is-valid');
            } else {
                feedbackDiv.innerHTML = `<span style="color: #ef4444;">❌ Outlet ${outlet} is in use by ${data.device_info}</span>`;
                outletInput.classList.add('is-invalid');
                outletInput.classList.remove('is-valid');
            }
        })
        .catch(err => {
            console.error('Error checking PDU outlet:', err);
            feedbackDiv.innerHTML = `<span style="color: #f59e0b;">⚠ Unable to verify outlet availability</span>`;
        });
}

// Add event listeners when page loads
document.addEventListener('DOMContentLoaded', function() {
    // Primary PDU outlet check
    const pdu1Outlet = document.getElementById('{{ form.pdu_1_outlet.id }}');
    const pdu1Select = document.getElementById('{{ form.pdu_1_id.id }}');
    
    if (pdu1Outlet) {
        pdu1Outlet.addEventListener('blur', function() {
            checkPDUOutletAvailability('{{ form.pdu_1_id.id }}', '{{ form.pdu_1_outlet.id }}');
        });
    }
    
    if (pdu1Select) {
        pdu1Select.addEventListener('change', function() {
            if (pdu1Outlet && pdu1Outlet.value) {
                checkPDUOutletAvailability('{{ form.pdu_1_id.id }}', '{{ form.pdu_1_outlet.id }}');
            }
        });
    }
    
    // Redundant PDU outlet check
    const pdu2Outlet = document.getElementById('{{ form.pdu_2_outlet.id }}');
    const pdu2Select = document.getElementById('{{ form.pdu_2_id.id }}');
    
    if (pdu2Outlet) {
        pdu2Outlet.addEventListener('blur', function() {
            checkPDUOutletAvailability('{{ form.pdu_2_id.id }}', '{{ form.pdu_2_outlet.id }}');
        });
    }
    
    if (pdu2Select) {
        pdu2Select.addEventListener('change', function() {
            if (pdu2Outlet && pdu2Outlet.value) {
                checkPDUOutletAvailability('{{ form.pdu_2_id.id }}', '{{ form.pdu_2_outlet.id }}');
            }
        });
    }
});

// Rack space availability checking
function checkRackSpace() {
    const rackSelect = document.getElementById('{{ form.rack_id.id }}');
    const startUInput = document.getElementById('{{ form.start_u.id }}');
    const sizeUInput = document.getElementById('{{ form.size_u.id }}');
    
    const rackId = rackSelect.value;
    const startU = parseInt(startUInput.value);
    const sizeU = parseInt(sizeUInput.value);
    
    // Create or find feedback div
    let feedbackDiv = document.getElementById('rackSpaceFeedback');
    if (!feedbackDiv) {
        feedbackDiv = document.createElement('div');
        feedbackDiv.id = 'rackSpaceFeedback';
        feedbackDiv.style.marginTop = '5px';
        startUInput.parentElement.appendChild(feedbackDiv);
    }
    
    if (!rackId || !startU || !sizeU) {
        feedbackDiv.innerHTML = '';
        startUInput.classList.remove('is-invalid', 'is-valid');
        return;
    }
    
    const endU = startU + sizeU - 1;
    
    // Check rack availability using the existing API
    fetch(`/servers/api/rack/${rackId}/availability`)
        .then(response => response.json())
        .then(data => {
            // Check if space is available
            let conflict = false;
            let conflictDevice = '';
            
            for (let u = startU; u <= endU; u++) {
                if (data.usage && data.usage[u]) {
                    conflict = true;
                    const usage = data.usage[u];
                    conflictDevice = usage.device_id || usage.server_id || 'Unknown device';
                    break;
                }
            }
            
            if (conflict) {
                feedbackDiv.innerHTML = `<span style="color: #ef4444;">❌ Conflict at U${startU}-U${endU} with ${conflictDevice}</span>`;
                startUInput.classList.add('is-invalid');
                startUInput.classList.remove('is-valid');
            } else {
                feedbackDiv.innerHTML = `<span style="color: #10b981;">✓ Space available (U${startU}-U${endU})</span>`;
                startUInput.classList.remove('is-invalid');
                startUInput.classList.add('is-valid');
            }
            
            // Also check if position is within rack bounds
            if (endU > data.total_u) {
                feedbackDiv.innerHTML = `<span style="color: #ef4444;">❌ Position exceeds rack height (max U${data.total_u})</span>`;
                startUInput.classList.add('is-invalid');
                startUInput.classList.remove('is-valid');
            }
        })
        .catch(err => {
            console.error('Error checking rack space:', err);
            feedbackDiv.innerHTML = `<span style="color: #f59e0b;">⚠ Unable to verify rack space</span>`;
        });
}

// Add to the existing DOMContentLoaded event listener
document.addEventListener('DOMContentLoaded', function() {
    // ... existing PDU outlet code ...
    
    // Rack space checking
    const rackSelect = document.getElementById('{{ form.rack_id.id }}');
    const startUInput = document.getElementById('{{ form.start_u.id }}');
    const sizeUInput = document.getElementById('{{ form.size_u.id }}');
    
    if (rackSelect) {
        rackSelect.addEventListener('change', checkRackSpace);
    }
    
    if (startUInput) {
        startUInput.addEventListener('blur', checkRackSpace);
    }
    
    if (sizeUInput) {
        sizeUInput.addEventListener('blur', checkRackSpace);
    }
});
</script>
{% endblock %}