{% extends "base.html" %}

{% block title %}DCMS - Dashboard{% endblock %}
{% block page_title %}Dashboard Overview{% endblock %}

{% block header_actions %}
<a href="/datacenters/add" class="btn btn-sm">+ Add Data Center</a>
{% endblock %}

{% block content %}
<!-- Statistics Grid -->
<div class="grid-4 mb-3">
    <div class="stat-box">
        <div class="emoji">🏢</div>
        <div class="stat-value">3</div>
        <div class="stat-label">Data Centers</div>
        <div class="stat-change">+1 this month</div>
    </div>
    
    <div class="stat-box">
        <div class="emoji">🗄️</div>
        <div class="stat-value">42</div>
        <div class="stat-label">Active Racks</div>
        <div class="stat-change">+5 this month</div>
    </div>
    
    <div class="stat-box">
        <div class="emoji">⚡</div>
        <div class="stat-value">18</div>
        <div class="stat-label">PDUs Online</div>
        <div class="stat-change">All operational</div>
    </div>
    
    <div class="stat-box">
        <div class="emoji">🌐</div>
        <div class="stat-value">156</div>
        <div class="stat-label">Network Devices</div>
        <div class="stat-change negative">-2 offline</div>
    </div>
</div>

<!-- Quick Actions Card -->
<div class="card">
    <div class="card-header">
        <h2>Quick Actions</h2>
    </div>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/datacenters/add" class="btn">🏢 Add Data Center</a>
        <a href="/racks/add" class="btn">🗄️ Add Rack</a>
        <a href="/pdus/add" class="btn">⚡ Add PDU</a>
        <a href="/network-devices/add" class="btn">🌐 Add Device</a>
        <a href="/reports/power" class="btn btn-secondary">📊 Power Report</a>
    </div>
</div>

<!-- Data Centers Overview -->
<div class="card">
    <div class="card-header">
        <h2>Data Centers</h2>
        <a href="/datacenters" class="btn btn-sm">View All →</a>
    </div>
    
    <table>
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Location</th>
                <th>Status</th>
                <th>Power Usage</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>SFJ</td>
                <td>San Francisco - Main</td>
                <td>San Francisco, CA</td>
                <td><span class="badge badge-active">Active</span></td>
                <td>2,500 / 5,000 kW</td>
            </tr>
            <tr>
                <td>NYK</td>
                <td>New York - Primary</td>
                <td>New York, NY</td>
                <td><span class="badge badge-active">Active</span></td>
                <td>3,200 / 6,000 kW</td>
            </tr>
            <tr>
                <td>LON</td>
                <td>London - Europe Hub</td>
                <td>London, UK</td>
                <td><span class="badge badge-maintenance">Maintenance</span></td>
                <td>1,800 / 4,000 kW</td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Recent Activity -->
<div class="card">
    <h2>Recent Activity</h2>
    <div class="text-muted">
        <p>• PDU-A-15 added to Rack SFJ-1.05</p>
        <p>• Network device SW-CORE-01 configuration updated</p>
        <p>• New floor added to NYC data center</p>
        <p>• Power capacity increased for Rack LON-2.08</p>
    </div>
</div>
{% endblock %}