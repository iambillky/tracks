"""
File: forms/datacenter_forms.py (PDUForm section only)
Purpose: Updated PDU form with switch connectivity fields
Version: 1.2.0
Author: DCMS Team

Revision History:
- v1.1.0: Added model field for tracking APC model numbers
- v1.2.0: Added switch connectivity fields for network management
"""

from flask_wtf import FlaskForm
from wtforms import StringField, IntegerField, FloatField, TextAreaField, SelectField
from wtforms.validators import DataRequired, Length, Email, Optional, NumberRange, Regexp, ValidationError, IPAddress

# ========== FORM DEFINITIONS ==========

class DataCenterForm(FlaskForm):
    """
    Form for adding/editing data centers
    Validates DC code is exactly 3 characters
    Includes fields for multiple contact types (sales, PM, manager)
    """
    # Basic Information
    code = StringField('DC Code', 
                      validators=[DataRequired(), Length(min=3, max=3)],
                      render_kw={'style': 'text-transform: uppercase;'})
    name = StringField('DC Name', 
                      validators=[DataRequired(), Length(max=100)])
    address = TextAreaField('Address', 
                          validators=[Optional()],
                          render_kw={'rows': 3})
    
    # Primary Contact Information
    contact_phone = StringField('Contact Phone', 
                               validators=[Optional(), Length(max=20)])
    contact_email = StringField('Contact Email', 
                               validators=[Optional(), Email()])
    
    # Sales Contact - FIXED: Line 43-44 was truncated
    sales_name = StringField('Sales Contact Name', 
                            validators=[Optional(), Length(max=100)])
    sales_email = StringField('Sales Contact Email', 
                             validators=[Optional(), Email()])
    sales_phone = StringField('Sales Contact Phone', 
                              validators=[Optional(), Length(max=20)])
    sales_title = StringField('Sales Contact Title', 
                             validators=[Optional(), Length(max=100)])
    
    # Project Manager Contact
    pm_name = StringField('PM Name', 
                         validators=[Optional(), Length(max=100)])
    pm_email = StringField('PM Email', 
                          validators=[Optional(), Email()])
    pm_phone = StringField('PM Phone', 
                          validators=[Optional(), Length(max=20)])
    pm_title = StringField('PM Title', 
                          validators=[Optional(), Length(max=100)])
    
    # Manager Contact
    manager_name = StringField('Manager Name', 
                              validators=[Optional(), Length(max=100)])
    manager_email = StringField('Manager Email', 
                               validators=[Optional(), Email()])
    manager_phone = StringField('Manager Phone', 
                               validators=[Optional(), Length(max=20)])
    manager_title = StringField('Manager Title', 
                               validators=[Optional(), Length(max=100)])
    
    # Additional Information
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3})


class FloorForm(FlaskForm):
    """
    Form for adding/editing floors
    Maps provider designation to actual floor numbers
    """
    provider_designation = StringField('Provider Designation', 
                                     validators=[DataRequired(), Length(max=10)])
    actual_floor = SelectField('Actual Floor',
                              choices=[
                                  ('Basement', 'Basement'),
                                  ('1st Floor', '1st Floor'),
                                  ('2nd Floor', '2nd Floor'),
                                  ('3rd Floor', '3rd Floor'),
                                  ('4th Floor', '4th Floor'),
                                  ('5th Floor', '5th Floor'),
                                  ('6th Floor', '6th Floor'),
                                  ('7th Floor', '7th Floor'),
                                  ('8th Floor', '8th Floor'),
                                  ('9th Floor', '9th Floor'),
                                  ('10th Floor', '10th Floor'),
                              ],
                              validators=[DataRequired()])
    description = StringField('Description', 
                            validators=[Optional(), Length(max=100)])


class RackForm(FlaskForm):
    """
    Form for adding/editing racks
    Validates rack specifications within reasonable limits
    Includes 4-digit rack access code field
    """
    row_number = StringField('Row/Grid Number', 
                           validators=[DataRequired(), Length(max=10)])
    cabinet_number = StringField('Cabinet Number', 
                               validators=[DataRequired(), Length(max=10)])
    u_height = IntegerField('Total U Height', 
                          validators=[DataRequired(), NumberRange(min=1, max=60)],
                          default=42)
    power_capacity = FloatField('Power Capacity (Amps)', 
                              validators=[Optional(), NumberRange(min=0)])
    rack_code = StringField('Rack Access Code', 
                          validators=[Optional(), 
                                    Regexp('^[0-9]{4}$', message='Must be exactly 4 digits')],
                          render_kw={'maxlength': '4'})
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3})


"""
File: forms/datacenter_forms.py (PDUForm section only)
Purpose: Updated PDU form with switch connectivity fields
Version: 1.2.0
Author: DCMS Team

Revision History:
- v1.1.0: Added model field for tracking APC model numbers
- v1.2.0: Added switch connectivity fields for network management
"""

from flask_wtf import FlaskForm
from wtforms import StringField, IntegerField, FloatField, TextAreaField, SelectField
from wtforms.validators import DataRequired, Length, Optional, NumberRange, ValidationError, IPAddress

class PDUForm(FlaskForm):
    """
    Form for adding/editing PDUs
    Validates electrical specifications for rack PDUs
    Includes model field for tracking APC model numbers
    NOW INCLUDES: Switch connectivity for managed PDUs
    
    Version 1.2.0 - Added network switch connectivity
    """
    # ========== PDU IDENTIFICATION ==========
    identifier = StringField('PDU Identifier', 
                           validators=[DataRequired(), Length(max=50)])
    model = StringField('Model Number', 
                       validators=[Optional(), Length(max=50)])
    circuit_id = StringField('Circuit ID', 
                           validators=[Optional(), Length(max=50)])
    
    # ========== ELECTRICAL SPECIFICATIONS ==========
    capacity_amps = FloatField('Capacity (Amps)', 
                             validators=[DataRequired(), NumberRange(min=0, max=100)])
    voltage = SelectField('Voltage',
                         choices=[
                             (120, '120V'),
                             (208, '208V'),
                             (240, '240V'),
                         ],
                         coerce=int,
                         validators=[DataRequired()])
    phase = SelectField('Phase',
                       choices=[
                           ('Single', 'Single Phase'),
                           ('Three', 'Three Phase'),
                       ],
                       validators=[DataRequired()])
    
    # ========== OUTLET CONFIGURATION ==========
    total_outlets = IntegerField('Total Outlets', 
                                validators=[DataRequired(), NumberRange(min=1, max=48)],
                                default=24)
    
    # ========== NETWORK MANAGEMENT - UPDATED v1.2.0 ==========
    ip_address = StringField('Management IP', 
                           validators=[Optional(), IPAddress(ipv4=True, ipv6=False)])
    
    # NEW FIELDS: Switch connectivity for managed PDUs
    connected_switch_id = SelectField('Connected Switch',
                                     coerce=int,
                                     validators=[Optional()])
    
    connected_switch_port = IntegerField('Switch Port Number',
                                        validators=[Optional(), NumberRange(min=1, max=96)])
    
    # ========== ADDITIONAL ==========
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3})
    
    def validate(self, **kwargs):
        """
        Custom validation for PDU form
        Ensures network connectivity is properly configured
        """
        if not super().validate(**kwargs):
            return False
        
        # If switch is selected, port must be specified
        if self.connected_switch_id.data and self.connected_switch_id.data != 0:
            if not self.connected_switch_port.data:
                self.connected_switch_port.errors.append('Port number required when switch is selected')
                return False
        
        # If port is specified, switch must be selected
        if self.connected_switch_port.data:
            if not self.connected_switch_id.data or self.connected_switch_id.data == 0:
                self.connected_switch_id.errors.append('Switch must be selected when port is specified')
                return False
        
        # Validate IP is in management range (10.10.x.x)
        if self.ip_address.data:
            if not self.ip_address.data.startswith('10.10.'):
                # Warning but not blocking
                pass
        
        return True