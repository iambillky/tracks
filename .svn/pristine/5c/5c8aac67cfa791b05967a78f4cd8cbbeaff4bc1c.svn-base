"""
File: forms/network_device_forms.py
Purpose: WTForms form definitions for network device management
Version: 1.2.1
Author: DCMS Team

Revision History:
- v1.0.0: Initial form definitions for network devices
- v1.0.1: Added custom validation for network type/identifier matching
- v1.0.2: Added IPAddress validator for management IP field
- v1.1.0: Fixed redundant PDU validation bug
- v1.1.1: Fixed indentation issue with redundant PDU validation
- v1.2.0: Added PDU outlet duplicate validation to prevent multiple devices on same outlet
- v1.2.1: Fixed redundant PDU validation to enforce true redundancy (different PDUs required)

Changelog:
- v1.2.1: Enforced true power redundancy - redundant PDU must be different from primary PDU
"""

from flask_wtf import FlaskForm
from wtforms import StringField, IntegerField, FloatField, TextAreaField, SelectField
from wtforms.validators import DataRequired, Length, Optional, NumberRange, IPAddress

# Import models for database queries (add this import at the top of the file)
from models.network_device import NetworkDevice

# ========== CUSTOM VALIDATORS ==========

# ... [existing validator code remains the same] ...

# ========== FORM DEFINITIONS ==========

class NetworkDeviceForm(FlaskForm):
    """
    Form for adding/editing network devices
    Handles validation for network device configuration including PDU assignments
    """
    # ========== IDENTIFICATION ==========
    hostname = StringField('Hostname', 
                          validators=[DataRequired(), Length(max=100)],
                          render_kw={'placeholder': 'SWITCH-DC01-DIST01', 
                                   'style': 'text-transform: uppercase;'})
    
    identifier = StringField('Identifier', 
                           validators=[DataRequired(), Length(max=50)],
                           render_kw={'placeholder': 'DISTRO1, INT5, PRIVCORE, etc.',
                                    'style': 'text-transform: uppercase;'})
    
    # ========== DEVICE TYPE & ROLE ==========
    device_type = SelectField('Device Type',
                            choices=[
                                ('Switch', 'Switch'),
                                ('Core', 'Core Switch/Router'),
                                ('Firewall', 'Firewall'),
                                ('Load Balancer', 'Load Balancer'),
                                ('Other', 'Other')
                            ],
                            validators=[DataRequired()])
    
    device_role = SelectField('Device Role',
                            choices=[
                                ('Core', 'Core Switch/Router'),
                                ('Distribution', 'Distribution'),
                                ('Access', 'Access/ToR'),
                                ('OOB', 'Out-of-Band'),
                                ('Other', 'Other')
                            ],
                            validators=[DataRequired()])
    
    # ========== EQUIPMENT LIBRARY ==========
    switch_model_id = SelectField('Switch Model',
                                coerce=int,
                                validators=[Optional()],
                                render_kw={'id': 'switch_model_select'})
    
    network_type = SelectField('Network Type',
                             choices=[
                                 ('public', 'Public Network'),
                                 ('private', 'Private Network'),
                                 ('both', 'Both Networks'),
                                 ('oob', 'Out-of-Band')
                             ],
                             validators=[DataRequired()])
    
    # ========== HARDWARE ==========
    manufacturer = SelectField('Manufacturer',
                             choices=[
                                 ('', '-- Select Manufacturer --'),
                                 ('MikroTik', 'MikroTik'),
                                 ('Arista', 'Arista')
                             ],
                             validators=[Optional()])  # Changed to Optional since it will be auto-filled
    
    model = StringField('Model', 
                       validators=[Optional(), Length(max=100)],
                       render_kw={'placeholder': 'Catalyst 3850, Nexus 9300, etc.'})
    
    serial_number = StringField('Serial Number', 
                              validators=[Optional(), Length(max=100)],
                              render_kw={'placeholder': 'Optional'})
    
    # ========== SOFTWARE ==========
    software_version = StringField('Software Version', 
                                  validators=[Optional(), Length(max=100)],
                                  render_kw={'placeholder': '15.2(7)E3, 9.3(8), etc.'})
    
    # ========== PHYSICAL LOCATION ==========
    # Rack will be a SelectField populated dynamically in the route
    rack_id = SelectField('Rack Location',
                         coerce=int,
                         validators=[DataRequired()])
    
    start_u = IntegerField('Starting U Position', 
                          validators=[DataRequired(), NumberRange(min=1, max=50)],
                          render_kw={'placeholder': '42 (top of rack)'})
    
    size_u = IntegerField('Size (in U)', 
                         validators=[DataRequired(), NumberRange(min=1, max=10)],
                         default=1,
                         render_kw={'placeholder': '1'})
    
    # ========== NETWORK INFO ==========
    management_ip = StringField('Management IP', 
                               validators=[Optional(), IPAddress(ipv4=True, ipv6=False)],
                               render_kw={'placeholder': '10.10.5.236'})
    
    port_count = IntegerField('Port Count', 
                            validators=[Optional(), NumberRange(min=1, max=96)],
                            render_kw={'placeholder': '24, 48, etc.'})
    
    # ========== POWER CONFIGURATION ==========
    # PDU fields will be SelectFields populated dynamically in the route
    pdu_1_id = SelectField('Primary PDU',
                          coerce=int,
                          validators=[Optional()])
    
    pdu_1_outlet = IntegerField('Primary PDU Outlet', 
                               validators=[Optional(), NumberRange(min=1, max=48)],
                               render_kw={'placeholder': 'Outlet number'})
    
    pdu_2_id = SelectField('Redundant PDU (optional)',
                          coerce=int,
                          validators=[Optional()])
    
    pdu_2_outlet = IntegerField('Redundant PDU Outlet', 
                               validators=[Optional(), NumberRange(min=1, max=48)],
                               render_kw={'placeholder': 'Outlet number'})
    
    power_consumption = FloatField('Power Consumption (Watts)',
                                  validators=[DataRequired(), NumberRange(min=1, max=5000)],
                                  render_kw={'placeholder': 'Required - Enter actual watts'})
    
    # ========== STATUS ==========
    status = SelectField('Status',
                        choices=[
                            ('active', 'Active'),
                            ('spare', 'Spare'),
                            ('failed', 'Failed'),
                            ('maintenance', 'Maintenance')
                        ],
                        default='active',
                        validators=[DataRequired()])
    
    # ========== NOTES ==========
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3, 
                                  'placeholder': 'Any additional notes about this device'})
    
    def validate(self, **kwargs):
        """
        Custom validation to ensure:
        1. Network type matches identifier
        2. PDU configuration is valid
        3. PDU outlets are not already in use /* CHANGED: Added outlet duplicate checking */
        """
        # First run standard validation
        rv = FlaskForm.validate(self)
        if not rv:
            return False
        
        # Check if identifier matches network type
        if self.identifier.data and self.network_type.data:
            identifier_upper = self.identifier.data.upper()
            
            # Private network identifiers
            if self.network_type.data == 'private':
                if not (identifier_upper.startswith('INT') or 
                       identifier_upper == 'PRIVCORE' or
                       identifier_upper.startswith('PRIV')):
                    self.identifier.errors.append(
                        'Private network devices should use INT or PRIV prefix'
                    )
                    return False
            
            # Public network identifiers  
            elif self.network_type.data == 'public':
                if identifier_upper.startswith('INT') or identifier_upper.startswith('PRIV'):
                    self.identifier.errors.append(
                        'Public network devices should use DISTRO or CORE prefix'
                    )
                    return False
        
        # Check redundant PDU configuration
        if self.pdu_2_id.data and not self.pdu_1_id.data:
            self.pdu_2_id.errors.append('Cannot set redundant PDU without primary PDU')
            return False
        
        if self.pdu_2_outlet.data and not self.pdu_2_id.data:
            self.pdu_2_outlet.errors.append('Select a redundant PDU first')
            return False
        
        # /* CHANGED: v1.2.1 - Enforce true power redundancy */
        # Check if Redundant PDU is UNIQUE - must be different PDU for true redundancy!
        if self.pdu_1_id.data and self.pdu_2_id.data:
            if self.pdu_1_id.data == self.pdu_2_id.data:
                self.pdu_2_id.errors.append('Redundant PDU must be different from Primary PDU for true power redundancy')
                return False
        
        # /* CHANGED: Added PDU outlet duplicate validation */
        # Check if PDU outlets are already in use by other devices
        # Get the device ID if we're editing (will be None for new devices)
        device_id = getattr(self, '_obj', None)
        if device_id:
            device_id = device_id.id if hasattr(device_id, 'id') else None
        
        # Check Primary PDU outlet
        if self.pdu_1_id.data and self.pdu_1_outlet.data:
            # Query for any device using this PDU and outlet
            existing = NetworkDevice.query.filter_by(
                pdu_1_id=self.pdu_1_id.data,
                pdu_1_outlet=self.pdu_1_outlet.data
            ).first()
            
            # If found and it's not the current device being edited
            if existing and (not device_id or existing.id != device_id):
                self.pdu_1_outlet.errors.append(
                    f'Outlet {self.pdu_1_outlet.data} is already in use by {existing.identifier}'
                )
                return False
            
            # Also check if another device uses this outlet as redundant
            existing = NetworkDevice.query.filter_by(
                pdu_2_id=self.pdu_1_id.data,
                pdu_2_outlet=self.pdu_1_outlet.data
            ).first()
            
            if existing and (not device_id or existing.id != device_id):
                self.pdu_1_outlet.errors.append(
                    f'Outlet {self.pdu_1_outlet.data} is already in use by {existing.identifier} (redundant)'
                )
                return False
        
        # Check Redundant PDU outlet
        if self.pdu_2_id.data and self.pdu_2_outlet.data:
            # Query for any device using this PDU and outlet as primary
            existing = NetworkDevice.query.filter_by(
                pdu_1_id=self.pdu_2_id.data,
                pdu_1_outlet=self.pdu_2_outlet.data
            ).first()
            
            if existing and (not device_id or existing.id != device_id):
                self.pdu_2_outlet.errors.append(
                    f'Outlet {self.pdu_2_outlet.data} is already in use by {existing.identifier}'
                )
                return False
            
            # Also check if another device uses this outlet as redundant
            existing = NetworkDevice.query.filter_by(
                pdu_2_id=self.pdu_2_id.data,
                pdu_2_outlet=self.pdu_2_outlet.data
            ).first()
            
            if existing and (not device_id or existing.id != device_id):
                self.pdu_2_outlet.errors.append(
                    f'Outlet {self.pdu_2_outlet.data} is already in use by {existing.identifier} (redundant)'
                )
                return False
        
        return True