<!--
File: templates/datacenters/add_dc.html
Purpose: Form template for adding new data centers
Version: 1.3.0
Author: iambilky

Revision History:
- v1.0.0: Initial creation with form fields and dark theme styling
- v1.0.1: Updated revision history format
- v1.0.2: Fixed text color visibility issue in form inputs
- v1.1.0: Added dedicated Contacts section for sales, PM, and manager
- v1.2.0: Fixed contacts to use Flask-WTForms fields instead of hardcoded HTML
- v1.3.0: Expanded form width to 1400px for better screen utilization
-->

{% extends "base.html" %}

{% block title %}Add Data Center{% endblock %}

{% block extra_css %}
<style>
    /* ========== FORM CONTAINER ========== */
    .form-container {
        max-width: 1400px; /* CHANGED: from 800px to 1400px */
        margin: 0 auto;
        padding: 0 20px; /* CHANGED: Added horizontal padding */
    }
    
    .form-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 40px; /* CHANGED: from 30px to 40px */
    }
    
    /* ========== FORM GROUPS ========== */
    .form-group {
        margin-bottom: 25px;
    }
    
    .form-label {
        display: block;
        color: #e4e6eb;
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    .form-label .required {
        color: #ef4444;
        margin-left: 3px;
    }
    
    /* ========== FORM CONTROLS ========== */
    .form-control {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 10px 14px;
        color: #ffffff !important;
        font-size: 1rem;
        transition: all 0.2s ease;
        -webkit-text-fill-color: #ffffff !important;
    }
    
    .form-control:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.1);
        border-color: #60a5fa;
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
        color: #ffffff !important;
        -webkit-text-fill-color: #ffffff !important;
    }
    
    .form-control::placeholder {
        color: #6b7280;
    }
    
    /* Autofill styles */
    .form-control:-webkit-autofill,
    .form-control:-webkit-autofill:hover,
    .form-control:-webkit-autofill:focus,
    .form-control:-webkit-autofill:active {
        -webkit-text-fill-color: #ffffff !important;
        -webkit-box-shadow: 0 0 0 30px rgba(255, 255, 255, 0.08) inset !important;
        box-shadow: 0 0 0 30px rgba(255, 255, 255, 0.08) inset !important;
        transition: background-color 5000s ease-in-out 0s;
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 100px;
        font-family: inherit;
    }
    
    /* ========== VALIDATION FEEDBACK ========== */
    .invalid-feedback {
        display: block;
        color: #ef4444;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    .form-control.is-invalid {
        border-color: #ef4444;
    }
    
    .form-control.is-invalid:focus {
        border-color: #ef4444;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
    }
    
    /* ========== HELP TEXT ========== */
    .form-text {
        display: block;
        color: #8b92a5;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    /* ========== FORM SECTIONS ========== */
    .form-section {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin-top: 30px;
        padding-top: 25px;
    }
    
    .form-section-title {
        color: #60a5fa;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 20px;
    }
    
    /* ========== BUTTON GROUP ========== */
    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 35px;
        padding-top: 25px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        color: white;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    
    .btn-success:hover {
        background: linear-gradient(135deg, #059669, #047857);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }
    
    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
        text-decoration: none;
        cursor: pointer;
    }
    
    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.3);
        text-decoration: none;
    }
    
    /* ========== RESPONSIVE GRID ========== */
    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px; /* CHANGED: from 20px to 30px */
    }
    
    .form-row-3 { /* CHANGED: Added 3-column grid */
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }
    
    @media (max-width: 1200px) { /* CHANGED: Added medium breakpoint */
        .form-row-3 {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    
    @media (max-width: 768px) {
        .form-row,
        .form-row-3 {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">Add New Data Center</h1>
    <p class="page-subtitle">Configure a new data center location</p>
</div>

<div class="form-container">
    <div class="form-card">
        <form method="POST" action="{{ url_for('datacenters.add_datacenter') }}" novalidate>
            {{ form.hidden_tag() }}
            
            <!-- ========== BASIC INFORMATION ========== -->
            <div class="form-row">
                <div class="form-group">
                    <label for="{{ form.code.id }}" class="form-label">
                        Data Center Code <span class="required">*</span>
                    </label>
                    {{ form.code(class="form-control" + (" is-invalid" if form.code.errors else "")) }}
                    <small class="form-text">3-letter identifier (e.g., SFJ, LAX)</small>
                    {% if form.code.errors %}
                        {% for error in form.code.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
                
                <div class="form-group">
                    <label for="{{ form.name.id }}" class="form-label">
                        Name <span class="required">*</span>
                    </label>
                    {{ form.name(class="form-control" + (" is-invalid" if form.name.errors else "")) }}
                    <small class="form-text">Descriptive name for the data center</small>
                    {% if form.name.errors %}
                        {% for error in form.name.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            
            <div class="form-group">
                <label for="{{ form.address.id }}" class="form-label">Address</label>
                {{ form.address(class="form-control") }}
                <small class="form-text">Physical location of the data center</small>
                {% if form.address.errors %}
                    {% for error in form.address.errors %}
                        <div class="invalid-feedback">{{ error }}</div>
                    {% endfor %}
                {% endif %}
            </div>
            
            <!-- ========== PRIMARY CONTACT INFORMATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Primary Contact Information</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.contact_phone.id }}" class="form-label">Main Phone</label>
                        {{ form.contact_phone(class="form-control") }}
                        <small class="form-text">Primary contact number</small>
                        {% if form.contact_phone.errors %}
                            {% for error in form.contact_phone.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.contact_email.id }}" class="form-label">Main Email</label>
                        {{ form.contact_email(class="form-control") }}
                        <small class="form-text">Primary contact email</small>
                        {% if form.contact_email.errors %}
                            {% for error in form.contact_email.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- ========== CONTACTS SECTION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Contacts</h3>
                
                <div class="form-row-3" style="gap: 25px;"> <!-- CHANGED: Using 3-column grid -->
                    <!-- Sales Contact -->
                    <div style="background: rgba(255, 255, 255, 0.03); border-radius: 8px; padding: 25px;">
                        <h4 style="color: #60a5fa; font-size: 1.1rem; margin-bottom: 20px; font-weight: 600;">Sales Contact</h4>
                        <div class="form-group">
                            <label for="{{ form.sales_name.id }}" class="form-label">Name</label>
                            {{ form.sales_name(class="form-control") }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.sales_email.id }}" class="form-label">Email</label>
                            {{ form.sales_email(class="form-control" + (" is-invalid" if form.sales_email.errors else "")) }}
                            {% if form.sales_email.errors %}
                                {% for error in form.sales_email.errors %}
                                    <div class="invalid-feedback">{{ error }}</div>
                                {% endfor %}
                            {% endif %}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.sales_phone.id }}" class="form-label">Phone</label>
                            {{ form.sales_phone(class="form-control") }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.sales_title.id }}" class="form-label">Title</label>
                            {{ form.sales_title(class="form-control") }}
                        </div>
                    </div>
                    
                    <!-- Project Manager Contact -->
                    <div style="background: rgba(255, 255, 255, 0.03); border-radius: 8px; padding: 25px;">
                        <h4 style="color: #60a5fa; font-size: 1.1rem; margin-bottom: 20px; font-weight: 600;">Project Manager</h4>
                        <div class="form-group">
                            <label for="{{ form.pm_name.id }}" class="form-label">Name</label>
                            {{ form.pm_name(class="form-control") }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.pm_email.id }}" class="form-label">Email</label>
                            {{ form.pm_email(class="form-control" + (" is-invalid" if form.pm_email.errors else "")) }}
                            {% if form.pm_email.errors %}
                                {% for error in form.pm_email.errors %}
                                    <div class="invalid-feedback">{{ error }}</div>
                                {% endfor %}
                            {% endif %}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.pm_phone.id }}" class="form-label">Phone</label>
                            {{ form.pm_phone(class="form-control") }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.pm_title.id }}" class="form-label">Title</label>
                            {{ form.pm_title(class="form-control") }}
                        </div>
                    </div>
                    
                    <!-- Manager Contact -->
                    <div style="background: rgba(255, 255, 255, 0.03); border-radius: 8px; padding: 25px;">
                        <h4 style="color: #60a5fa; font-size: 1.1rem; margin-bottom: 20px; font-weight: 600;">Manager</h4>
                        <div class="form-group">
                            <label for="{{ form.manager_name.id }}" class="form-label">Name</label>
                            {{ form.manager_name(class="form-control") }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.manager_email.id }}" class="form-label">Email</label>
                            {{ form.manager_email(class="form-control" + (" is-invalid" if form.manager_email.errors else "")) }}
                            {% if form.manager_email.errors %}
                                {% for error in form.manager_email.errors %}
                                    <div class="invalid-feedback">{{ error }}</div>
                                {% endfor %}
                            {% endif %}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.manager_phone.id }}" class="form-label">Phone</label>
                            {{ form.manager_phone(class="form-control") }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.manager_title.id }}" class="form-label">Title</label>
                            {{ form.manager_title(class="form-control") }}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- ========== ADDITIONAL INFORMATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Additional Information</h3>
                
                <div class="form-group">
                    <label for="{{ form.notes.id }}" class="form-label">Notes</label>
                    {{ form.notes(class="form-control") }}
                    <small class="form-text">Any additional information about this data center</small>
                    {% if form.notes.errors %}
                        {% for error in form.notes.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            
            <!-- ========== ACTION BUTTONS ========== -->
            <div class="button-group">
                <button type="submit" class="btn btn-success">
                    <span style="margin-right: 8px;">✓</span> Save Data Center
                </button>
                <a href="{{ url_for('datacenters.index') }}" class="btn btn-cancel">
                    <span style="margin-right: 8px;">✕</span> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// ========== AUTO-UPPERCASE DC CODE ==========
document.getElementById('{{ form.code.id }}').addEventListener('input', function(e) {
    e.target.value = e.target.value.toUpperCase();
});

// ========== FORM VALIDATION FEEDBACK ==========
// Remove validation classes when user starts typing
document.querySelectorAll('.form-control').forEach(function(input) {
    input.addEventListener('input', function() {
        if (this.classList.contains('is-invalid')) {
            this.classList.remove('is-invalid');
            // Hide error messages for this field
            const feedback = this.parentElement.querySelectorAll('.invalid-feedback');
            feedback.forEach(function(msg) {
                msg.style.display = 'none';
            });
        }
    });
});
</script>
{% endblock %}