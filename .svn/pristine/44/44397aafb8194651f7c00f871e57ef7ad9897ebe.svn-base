<!--
File: templates/pdus/edit_pdu.html
Purpose: Form template for editing existing PDUs
Version: 1.1.2
Author: DCMS Team

Revision History:
- v1.0.0: Initial creation with edit form functionality
- v1.1.0: Removed manufacturer field (100% APC equipped), kept model field only
- v1.1.1: CHANGED: Removed duplicate Management Interface section
         CHANGED: Removed duplicate JavaScript functions for switch port validation
- v1.1.2: CHANGED: Removed width limitation for full-screen usage
-->

{% extends "base.html" %}

{% block title %}Edit PDU{% endblock %}

{% block extra_css %}
<style>
    /* ========== PDU INFO BAR ========== */
    .pdu-info-bar {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(251, 191, 36, 0.05));
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .pdu-info-content {
        flex: 1;
    }
    
    .pdu-current-id {
        color: #f59e0b;
        font-size: 2rem;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        margin-bottom: 5px;
    }
    
    .pdu-current-location {
        color: #e4e6eb;
        font-size: 1.1rem;
    }
    
    .pdu-stats {
        text-align: right;
    }
    
    .pdu-stat-item {
        color: #8b92a5;
        font-size: 0.9rem;
        margin-bottom: 5px;
    }
    
    .pdu-stat-value {
        color: #f59e0b;
        font-weight: 600;
    }
    
    /* ========== INFO BOX ========== */
    .info-box {
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
    }
    
    .info-box-title {
        color: #60a5fa;
        font-weight: 600;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .info-box-content {
        color: #e4e6eb;
        font-size: 0.95rem;
        line-height: 1.6;
    }
    
    /* ========== FORM CONTAINER ========== */
    /* CHANGED: Removed max-width limitation to use full screen */
    .form-container {
        padding: 0 20px;
    }
    
    .form-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 30px;
    }
    
    /* ========== FORM SECTIONS ========== */
    .form-section {
        margin-bottom: 35px;
    }
    
    .form-section-title {
        color: #f59e0b;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    /* ========== FORM GROUPS ========== */
    .form-group {
        margin-bottom: 25px;
    }
    
    .form-label {
        display: block;
        color: #e4e6eb;
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    .form-label .required {
        color: #ef4444;
        margin-left: 3px;
    }
    
    /* ========== FORM CONTROLS ========== */
    .form-control {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }
    
    .form-control:focus {
        outline: none;
        border-color: #f59e0b;
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
    }
    
    .form-control.is-invalid {
        border-color: #ef4444;
    }
    
    .form-control[disabled] {
        background: rgba(255, 255, 255, 0.03);
        color: #8b92a5;
        cursor: not-allowed;
    }
    
    /* ========== SELECT DROPDOWN ========== */
    select.form-control {
        cursor: pointer;
    }
    
    select.form-control option {
        background: #1a1f2e;
        color: #e4e6eb;
    }
    
    /* ========== TEXTAREA ========== */
    textarea.form-control {
        min-height: 100px;
        resize: vertical;
    }
    
    /* ========== FORM TEXT ========== */
    .form-text {
        display: block;
        color: #8b92a5;
        font-size: 0.85rem;
        margin-top: 5px;
    }
    
    /* ========== VALIDATION FEEDBACK ========== */
    .invalid-feedback {
        display: block;
        color: #ef4444;
        font-size: 0.85rem;
        margin-top: 5px;
    }
    
    /* ========== BUTTON GROUP ========== */
    .button-group {
        margin-top: 40px;
        display: flex;
        gap: 15px;
        justify-content: flex-start;
    }
    
    /* ========== BUTTONS ========== */
    .btn {
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }
    
    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
    }
    
    .btn-success:hover {
        background: linear-gradient(135deg, #059669, #047857);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }
    
    .btn-cancel {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
    }
    
    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
    }
    
    .btn-danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        float: right;
    }
    
    .btn-danger:hover {
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }
    
    /* ========== RESPONSIVE GRID ========== */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    
    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }
        
        .pdu-info-bar {
            flex-direction: column;
            text-align: center;
        }
        
        .pdu-stats {
            text-align: center;
            margin-top: 20px;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">Edit PDU</h1>
    <p class="page-subtitle">Update PDU configuration</p>
</div>

<!-- ========== PDU INFO BAR ========== -->
<div class="pdu-info-bar">
    <div class="pdu-info-content">
        <div class="pdu-current-id">{{ pdu.identifier }}</div>
        <div class="pdu-current-location">Rack: {{ pdu.rack.rack_id }}</div>
    </div>
    <div class="pdu-stats">
        <div class="pdu-stat-item">
            Outlets Used: <span class="pdu-stat-value">{{ pdu.used_outlets }}/{{ pdu.total_outlets }}</span>
        </div>
        <div class="pdu-stat-item">
            Capacity: <span class="pdu-stat-value">{{ pdu.capacity_amps }}A @ {{ pdu.voltage }}V</span>
        </div>
        {% if pdu.ip_address %}
        <div class="pdu-stat-item">
            IP: <span class="pdu-stat-value">{{ pdu.ip_address }}</span>
        </div>
        {% endif %}
    </div>
</div>

<div class="form-container">
    <div class="form-card">
        <form method="POST" action="{{ url_for('pdus.edit_pdu', pdu_id=pdu.id) }}" novalidate>
            {{ form.hidden_tag() }}
            
            <!-- ========== IDENTIFICATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">PDU Identification</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.identifier.id }}" class="form-label">
                            PDU Identifier <span class="required">*</span>
                        </label>
                        {{ form.identifier(class="form-control" + (" is-invalid" if form.identifier.errors else "")) }}
                        <small class="form-text">Sequential numbering (APC 1, APC 2, etc.)</small>
                        {% if form.identifier.errors %}
                            {% for error in form.identifier.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.model.id }}" class="form-label">
                            PDU Model
                        </label>
                        {{ form.model(class="form-control") }}
                        <small class="form-text">APC model number</small>
                        {% if form.model.errors %}
                            {% for error in form.model.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="{{ form.circuit_id.id }}" class="form-label">
                        Circuit ID
                    </label>
                    {{ form.circuit_id(class="form-control") }}
                    <small class="form-text">Electrical panel circuit number</small>
                    {% if form.circuit_id.errors %}
                        {% for error in form.circuit_id.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            
            <!-- ========== CAPACITY ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Electrical Specifications</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.capacity_amps.id }}" class="form-label">
                            Capacity (Amps) <span class="required">*</span>
                        </label>
                        {{ form.capacity_amps(class="form-control" + (" is-invalid" if form.capacity_amps.errors else "")) }}
                        <small class="form-text">Maximum amperage rating</small>
                        {% if form.capacity_amps.errors %}
                            {% for error in form.capacity_amps.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.voltage.id }}" class="form-label">
                            Voltage <span class="required">*</span>
                        </label>
                        {{ form.voltage(class="form-control" + (" is-invalid" if form.voltage.errors else "")) }}
                        <small class="form-text">Operating voltage</small>
                        {% if form.voltage.errors %}
                            {% for error in form.voltage.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.phase.id }}" class="form-label">
                            Phase <span class="required">*</span>
                        </label>
                        {{ form.phase(class="form-control" + (" is-invalid" if form.phase.errors else "")) }}
                        <small class="form-text">Single or three phase</small>
                        {% if form.phase.errors %}
                            {% for error in form.phase.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.total_outlets.id }}" class="form-label">
                            Total Outlets <span class="required">*</span>
                        </label>
                        {{ form.total_outlets(class="form-control" + (" is-invalid" if form.total_outlets.errors else ""), min=pdu.used_outlets) }}
                        <small class="form-text">
                            Number of available outlets 
                            {% if pdu.used_outlets > 0 %}
                            (minimum {{ pdu.used_outlets }} - currently in use)
                            {% endif %}
                        </small>
                        {% if form.total_outlets.errors %}
                            {% for error in form.total_outlets.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- ========== NETWORK CONNECTIVITY ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Network Switch Connection</h3>
                
                <div class="info-box" style="margin-bottom: 20px;">
                    <div class="info-box-content">
                        <strong>For Managed PDUs:</strong> Specify which switch and port this PDU's management interface connects to.
                        This helps track network topology and troubleshoot connectivity issues.
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.connected_switch_id.id }}" class="form-label">
                            Connected to Switch
                        </label>
                        {{ form.connected_switch_id(class="form-control", onchange="updatePortOptions()") }}
                        <small class="form-text">Select the switch this PDU connects to</small>
                        {% if form.connected_switch_id.errors %}
                            {% for error in form.connected_switch_id.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.connected_switch_port.id }}" class="form-label">
                            Switch Port Number
                        </label>
                        {{ form.connected_switch_port(class="form-control" + (" is-invalid" if form.connected_switch_port.errors else "")) }}
                        <small class="form-text">Port number on the selected switch (1-48, etc.)</small>
                        {% if form.connected_switch_port.errors %}
                            {% for error in form.connected_switch_port.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div id="portAvailabilityMessage" style="margin-top: 10px; display: none;">
                    <div class="alert" style="padding: 10px; border-radius: 6px;">
                        <span id="portStatus"></span>
                    </div>
                </div>
            </div>
            
            <!-- ========== MANAGEMENT INTERFACE ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Management Interface</h3>
                
                <div class="form-group">
                    <label for="{{ form.ip_address.id }}" class="form-label">
                        Management IP Address
                    </label>
                    {{ form.ip_address(class="form-control") }}
                    <small class="form-text">Private network IP (10.10.x.x) for web interface</small>
                    {% if pdu and pdu.connected_switch %}
                    <small class="form-text" style="color: #60a5fa;">
                        Connected via: {{ pdu.connected_switch.identifier }} Port {{ pdu.connected_switch_port }}
                    </small>
                    {% endif %}
                </div>
            </div>
            
            <!-- ========== NOTES ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Notes</h3>
                
                <div class="form-group">
                    <label for="{{ form.notes.id }}" class="form-label">
                        Additional Notes
                    </label>
                    {{ form.notes(class="form-control") }}
                    <small class="form-text">Any additional information about this PDU</small>
                    {% if form.notes.errors %}
                        {% for error in form.notes.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            
            <!-- ========== ACTION BUTTONS ========== -->
            <div class="button-group">
                <button type="submit" class="btn btn-success">
                    <span style="margin-right: 8px;">💾</span> Save Changes
                </button>
                <a href="{{ url_for('pdus.index') }}" class="btn btn-cancel">
                    <span style="margin-right: 8px;">✕</span> Cancel
                </a>
                
                {% if pdu.used_outlets == 0 %}
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                    <span style="margin-right: 8px;">🗑️</span> Delete PDU
                </button>
                {% endif %}
            </div>
        </form>
        
        <!-- Hidden delete form -->
        {% if pdu.used_outlets == 0 %}
        <form id="deleteForm" method="POST" action="{{ url_for('pdus.delete_pdu', pdu_id=pdu.id) }}" style="display: none;">
        </form>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// ========== DELETE CONFIRMATION ==========
{% if pdu.used_outlets == 0 %}
function confirmDelete() {
    if (confirm('Are you sure you want to delete PDU {{ pdu.identifier }}? This action cannot be undone.')) {
        document.getElementById('deleteForm').submit();
    }
}
{% endif %}

// ========== MINIMUM OUTLET ENFORCEMENT ==========
{% if pdu.used_outlets > 0 %}
document.getElementById('{{ form.total_outlets.id }}').addEventListener('change', function(e) {
    const minOutlets = {{ pdu.used_outlets }};
    if (parseInt(e.target.value) < minOutlets) {
        e.target.value = minOutlets;
        alert(`Cannot set outlet count below ${minOutlets} as ${minOutlets} outlets are currently in use.`);
    }
});
{% endif %}

// ========== FORM VALIDATION FEEDBACK ==========
document.querySelectorAll('.form-control').forEach(function(input) {
    input.addEventListener('input', function() {
        if (this.classList.contains('is-invalid')) {
            this.classList.remove('is-invalid');
            const feedback = this.parentElement.querySelectorAll('.invalid-feedback');
            feedback.forEach(function(msg) {
                msg.style.display = 'none';
            });
        }
    });
});

// ========== CALCULATE WATTS DISPLAY ==========
function updateWattsDisplay() {
    const amps = parseFloat(document.getElementById('{{ form.capacity_amps.id }}').value) || 0;
    const volts = parseInt(document.getElementById('{{ form.voltage.id }}').value) || 0;
    const watts = amps * volts;
    
    // Update the display in the info bar if needed
    console.log(`Power Capacity: ${watts}W (${amps}A @ ${volts}V)`);
}

// Update on change
document.getElementById('{{ form.capacity_amps.id }}').addEventListener('change', updateWattsDisplay);
document.getElementById('{{ form.voltage.id }}').addEventListener('change', updateWattsDisplay);

// ========== SWITCH PORT VALIDATION ==========
function updatePortOptions() {
    const switchSelect = document.getElementById('{{ form.connected_switch_id.id }}');
    const portInput = document.getElementById('{{ form.connected_switch_port.id }}');
    const messageDiv = document.getElementById('portAvailabilityMessage');
    
    if (switchSelect.value == '0') {
        portInput.disabled = true;
        portInput.value = '';
        messageDiv.style.display = 'none';
    } else {
        portInput.disabled = false;
        // Could add AJAX call here to check port availability
        checkPortAvailability();
    }
}

function checkPortAvailability() {
    const switchId = document.getElementById('{{ form.connected_switch_id.id }}').value;
    const portNumber = document.getElementById('{{ form.connected_switch_port.id }}').value;
    
    if (switchId && switchId != '0' && portNumber) {
        // AJAX call to check if port is available
        fetch(`/api/switch/${switchId}/port/${portNumber}/check`)
            .then(response => response.json())
            .then(data => {
                const messageDiv = document.getElementById('portAvailabilityMessage');
                const statusSpan = document.getElementById('portStatus');
                
                messageDiv.style.display = 'block';
                
                if (data.available) {
                    messageDiv.querySelector('.alert').className = 'alert alert-success';
                    statusSpan.innerHTML = '✅ Port ' + portNumber + ' is available';
                } else {
                    messageDiv.querySelector('.alert').className = 'alert alert-warning';
                    statusSpan.innerHTML = '⚠️ Port ' + portNumber + ' is currently assigned to: ' + data.device_name;
                }
            })
            .catch(error => {
                console.log('Could not check port availability');
            });
    }
}

// Add event listener for port number changes
document.getElementById('{{ form.connected_switch_port.id }}').addEventListener('blur', checkPortAvailability);

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    const switchSelect = document.getElementById('{{ form.connected_switch_id.id }}');
    if (switchSelect.value == '0') {
        document.getElementById('{{ form.connected_switch_port.id }}').disabled = true;
    }
});
</script>
{% endblock %}