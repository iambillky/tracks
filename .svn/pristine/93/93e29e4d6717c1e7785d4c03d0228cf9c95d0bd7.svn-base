<!--
File: templates/servers/index.html
Purpose: Main server list view with filtering and search
Version: 1.0.0
Author: DCMS Team
Date: 2025-01-16

Displays all servers with comprehensive filtering options
Shows key information: ID, name, IPs, location, status
-->

{% extends "base.html" %}

{% block title %}Servers{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">Server Management</h1>
    <p class="page-subtitle">Complete server tracking with IP management and network connections</p>
</div>

<!-- ========== STATISTICS CARDS ========== -->
<div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px;">
    <div class="stat-card" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); padding: 20px; border-radius: 10px;">
        <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 5px;">Total Servers</div>
        <div style="font-size: 2rem; font-weight: bold; color: #f3f4f6;">{{ stats.total }}</div>
    </div>
    
    <div class="stat-card" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); padding: 20px; border-radius: 10px;">
        <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 5px;">Active</div>
        <div style="font-size: 2rem; font-weight: bold; color: #10b981;">{{ stats.active }}</div>
    </div>
    
    <div class="stat-card" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); padding: 20px; border-radius: 10px;">
        <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 5px;">Dedicated</div>
        <div style="font-size: 2rem; font-weight: bold; color: #60a5fa;">{{ stats.dedicated }}</div>
    </div>
    
    <div class="stat-card" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); padding: 20px; border-radius: 10px;">
        <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 5px;">Colocation</div>
        <div style="font-size: 2rem; font-weight: bold; color: #f59e0b;">{{ stats.colocation }}</div>
    </div>
    
    <div class="stat-card" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); padding: 20px; border-radius: 10px;">
        <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 5px;">With IPMI</div>
        <div style="font-size: 2rem; font-weight: bold; color: #8b5cf6;">{{ stats.with_ipmi }}</div>
    </div>
</div>

<!-- ========== ACTIONS BAR ========== -->
<div class="actions-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div class="actions-left" style="display: flex; gap: 10px;">
        <a href="{{ url_for('servers.add') }}" class="btn btn-primary">
            <span style="margin-right: 5px;">➕</span> Add Server
        </a>
        <a href="{{ url_for('servers.customers') }}" class="btn btn-secondary">
            <span style="margin-right: 5px;">👥</span> Manage Customers
        </a>
    </div>
    
    <div class="actions-right">
        <button onclick="exportData()" class="btn btn-secondary">
            <span style="margin-right: 5px;">📊</span> Export
        </button>
    </div>
</div>

<!-- ========== SEARCH AND FILTERS ========== -->
<div class="card" style="margin-bottom: 20px;">
    <div class="card-body">
        <form method="get" action="{{ url_for('servers.index') }}" id="filterForm">
            <div class="row">
                <!-- Search -->
                <div class="col-md-4 mb-3">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" class="form-control" 
                           placeholder="Server ID, Name, IP..." 
                           value="{{ filters.search }}">
                </div>
                
                <!-- Service Type -->
                <div class="col-md-2 mb-3">
                    <label class="form-label">Service Type</label>
                    <select name="service_type" class="form-control">
                        <option value="all">All Types</option>
                        <option value="dedicated" {% if filters.service_type == 'dedicated' %}selected{% endif %}>Dedicated</option>
                        <option value="shared" {% if filters.service_type == 'shared' %}selected{% endif %}>Shared</option>
                        <option value="vps" {% if filters.service_type == 'vps' %}selected{% endif %}>VPS</option>
                        <option value="colocation" {% if filters.service_type == 'colocation' %}selected{% endif %}>Colocation</option>
                        <option value="staff" {% if filters.service_type == 'staff' %}selected{% endif %}>Staff</option>
                    </select>
                </div>
                
                <!-- Status -->
                <div class="col-md-2 mb-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-control">
                        <option value="all">All Statuses</option>
                        <option value="active" {% if filters.status == 'active' %}selected{% endif %}>Active</option>
                        <option value="provisioning" {% if filters.status == 'provisioning' %}selected{% endif %}>Provisioning</option>
                        <option value="maintenance" {% if filters.status == 'maintenance' %}selected{% endif %}>Maintenance</option>
                        <option value="decommissioned" {% if filters.status == 'decommissioned' %}selected{% endif %}>Decommissioned</option>
                    </select>
                </div>
                
                <!-- Data Center -->
                <div class="col-md-2 mb-3">
                    <label class="form-label">Data Center</label>
                    {{ form.datacenter_id(class="form-control") }}
                </div>
                
                <!-- IPMI -->
                <div class="col-md-2 mb-3">
                    <label class="form-label">IPMI</label>
                    <select name="has_ipmi" class="form-control">
                        <option value="all">All</option>
                        <option value="yes" {% if filters.has_ipmi == 'yes' %}selected{% endif %}>Has IPMI</option>
                        <option value="no" {% if filters.has_ipmi == 'no' %}selected{% endif %}>No IPMI</option>
                    </select>
                </div>
            </div>
            
            <div class="row">
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Apply Filters</button>
                    <a href="{{ url_for('servers.index') }}" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ========== SERVER LIST ========== -->
<div class="card">
    <div class="card-body">
        {% if servers %}
        <table class="table table-dark-custom">
            <thead>
                <tr>
                    <th>Server ID</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Location</th>
                    <th>Primary IPs</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for server in servers %}
                <tr>
                    <td>
                        <a href="{{ url_for('servers.view', id=server.id) }}" style="color: #60a5fa; text-decoration: none;">
                            <strong>{{ server.server_id }}</strong>
                        </a>
                        {% if server.is_colocation %}
                        <span class="badge" style="background: #f59e0b; color: #000; margin-left: 5px;">COLO</span>
                        {% endif %}
                    </td>
                    <td>{{ server.server_name }}</td>
                    <td>
                        <span style="color: #94a3b8;">{{ server.service_type|title }}</span>
                        {% if server.equipment_type == 'virtual_machine' %}
                        <span class="badge" style="background: #8b5cf6;">VM</span>
                        {% endif %}
                    </td>
                    <td>
                        <span style="color: #60a5fa;">{{ server.datacenter.code if server.datacenter else '-' }}</span>
                        /
                        <span>{{ server.rack.rack_id if server.rack else '-' }}</span>
                        /
                        <span style="color: #10b981;">U{{ server.start_u }}-{{ server.start_u + server.size_u - 1 }}</span>
                    </td>
                    <td>
                        {% if server.primary_public_ip %}
                        <div style="font-size: 0.875rem;">
                            <span style="color: #60a5fa;">{{ server.primary_public_ip.ip_address }}</span>
                        </div>
                        {% endif %}
                        {% if server.primary_private_ip %}
                        <div style="font-size: 0.875rem;">
                            <span style="color: #94a3b8;">{{ server.primary_private_ip.ip_address }}</span>
                        </div>
                        {% endif %}
                        {% if server.addon_ips.count() > 0 %}
                        <div style="font-size: 0.75rem; color: #6b7280;">
                            +{{ server.addon_ips.count() }} more
                        </div>
                        {% endif %}
                    </td>
                    <td>
                        {% if server.customer %}
                        <a href="{{ url_for('servers.view_customer', id=server.customer.id) }}" style="color: #f59e0b;">
                            {{ server.customer.customer_name }}
                        </a>
                        {% else %}
                        <span style="color: #6b7280;">-</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if server.status == 'active' %}
                        <span class="badge" style="background: #10b981;">Active</span>
                        {% elif server.status == 'provisioning' %}
                        <span class="badge" style="background: #3b82f6;">Provisioning</span>
                        {% elif server.status == 'maintenance' %}
                        <span class="badge" style="background: #f59e0b;">Maintenance</span>
                        {% elif server.status == 'decommissioned' %}
                        <span class="badge" style="background: #6b7280;">Decommissioned</span>
                        {% else %}
                        <span class="badge">{{ server.status|title }}</span>
                        {% endif %}
                        
                        {% if server.ipmi_ip %}
                        <span class="badge" style="background: #8b5cf6; margin-left: 5px;" title="IPMI Available">IPMI</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="btn-group">
                            <a href="{{ url_for('servers.view', id=server.id) }}" class="btn btn-sm btn-primary">View</a>
                            <a href="{{ url_for('servers.edit', id=server.id) }}" class="btn btn-sm btn-secondary">Edit</a>
                            
                            {% if server.ipmi_ip %}
                            <a href="https://{{ server.ipmi_ip.ip_address }}" target="_blank" class="btn btn-sm" 
                               style="background: #8b5cf6; color: white;" title="Open IPMI Console">
                                IPMI
                            </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        
        <!-- ========== PAGINATION ========== -->
        {% if pagination and pagination.pages > 1 %}
        <div style="margin-top: 20px; text-align: center;">
            {% if pagination.has_prev %}
            <a href="{{ url_for('servers.index', page=pagination.prev_num, **filters) }}" 
               class="btn btn-sm">← Previous</a>
            {% endif %}
            
            <span style="margin: 0 20px; color: #94a3b8;">
                Page {{ pagination.page }} of {{ pagination.pages }}
            </span>
            
            {% if pagination.has_next %}
            <a href="{{ url_for('servers.index', page=pagination.next_num, **filters) }}" 
               class="btn btn-sm">Next →</a>
            {% endif %}
        </div>
        {% endif %}
        
        {% else %}
        <!-- ========== EMPTY STATE ========== -->
        <div class="empty-state" style="text-align: center; padding: 60px 20px;">
            <h2 style="color: #94a3b8; margin-bottom: 10px;">No Servers Found</h2>
            <p style="color: #6b7280; margin-bottom: 20px;">
                {% if filters.search or filters.service_type != 'all' or filters.status != 'all' %}
                No servers match your filter criteria
                {% else %}
                Get started by adding your first server
                {% endif %}
            </p>
            <a href="{{ url_for('servers.add') }}" class="btn btn-primary">
                <span style="margin-right: 5px;">➕</span> Add First Server
            </a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
function exportData() {
    // In production, implement CSV/Excel export
    alert('Export functionality coming soon!');
}

// Auto-submit form on filter change
document.querySelectorAll('select').forEach(select => {
    select.addEventListener('change', () => {
        document.getElementById('filterForm').submit();
    });
});
</script>
{% endblock %}