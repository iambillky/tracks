<!--
File: templates/pdus/edit_pdu.html
Purpose: Form template for editing existing PDUs
Version: 1.1.3
Author: DCMS Team

Revision History:
- v1.0.0: Initial creation with edit form functionality
- v1.1.0: Removed manufacturer field (100% APC equipped), kept model field only
- v1.1.1: CHANGED: Removed duplicate Management Interface section
         CHANGED: Removed duplicate JavaScript functions for switch port validation
- v1.1.2: CHANGED: Removed width limitation for full-screen usage  
- v1.1.3: CHANGED: Added hidden pdu_id field for IPAM validation
         CHANGED: Added optional VLAN field for IPAM tracking
-->

{% extends "base.html" %}

{% block title %}Edit PDU{% endblock %}

{% block extra_css %}
<style>
    /* ========== PDU INFO BAR ========== */
    .pdu-info-bar {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(251, 191, 36, 0.05));
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .pdu-info-content {
        flex: 1;
    }
    
    .pdu-current-id {
        color: #f59e0b;
        font-size: 2rem;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        margin-bottom: 5px;
    }
    
    .pdu-current-location {
        color: #e4e6eb;
        font-size: 1.1rem;
    }
    
    .pdu-stats {
        text-align: right;
    }
    
    .pdu-stat-item {
        color: #8b92a5;
        font-size: 0.9rem;
        margin-bottom: 5px;
    }
    
    .pdu-stat-value {
        color: #f59e0b;
        font-weight: 600;
    }
    
    /* ========== INFO BOX ========== */
    .info-box {
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
    }
    
    .info-box-title {
        color: #60a5fa;
        font-weight: 600;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .info-box-content {
        color: #e4e6eb;
        font-size: 0.95rem;
        line-height: 1.6;
    }
    
    /* ========== FORM CONTAINER ========== */
    /* CHANGED: Removed max-width limitation to use full screen */
    .form-container {
        padding: 0 20px;
    }
    
    .form-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 30px;
    }
    
    /* ========== FORM SECTIONS ========== */
    .form-section {
        margin-bottom: 30px;
    }
    
    .form-section-title {
        color: #60a5fa;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    /* ========== FORM GROUPS ========== */
    .form-group {
        margin-bottom: 25px;
    }
    
    .form-label {
        display: block;
        color: #e4e6eb;
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    .form-label .required {
        color: #ef4444;
        margin-left: 3px;
    }
    
    /* ========== FORM CONTROLS ========== */
    .form-control {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }
    
    .form-control:focus {
        outline: none;
        border-color: #60a5fa;
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
    }
    
    .form-control.is-invalid {
        border-color: #ef4444;
    }
    
    select.form-control {
        cursor: pointer;
    }
    
    select.form-control option {
        background: #0a0a0f;
        color: #e4e6eb;
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }
    
    /* ========== FORM TEXT ========== */
    .form-text {
        display: block;
        margin-top: 5px;
        font-size: 0.875rem;
        color: #8b92a5;
    }
    
    .invalid-feedback {
        display: none;
        color: #ef4444;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    .is-invalid ~ .invalid-feedback {
        display: block;
    }
    
    /* ========== BUTTON GROUP ========== */
    .button-group {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        padding-top: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .btn {
        display: inline-block;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    
    .btn-success {
        background: #10b981;
        color: #ffffff;
        border: none;
    }
    
    .btn-success:hover {
        background: #16a34a;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }
    
    .btn-cancel {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        text-decoration: none;
    }
    
    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        text-decoration: none;
    }
    
    .btn-danger {
        background: #ef4444;
        color: #ffffff;
        border: none;
        margin-left: auto;
    }
    
    .btn-danger:hover {
        background: #dc2626;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }
    
    /* ========== RESPONSIVE GRID ========== */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    
    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }
        
        .pdu-info-bar {
            flex-direction: column;
            text-align: center;
        }
        
        .pdu-stats {
            text-align: center;
            margin-top: 20px;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">Edit PDU</h1>
    <p class="page-subtitle">Update PDU configuration</p>
</div>

<!-- ========== PDU INFO BAR ========== -->
<div class="pdu-info-bar">
    <div class="pdu-info-content">
        <div class="pdu-current-id">{{ pdu.identifier }}</div>
        <div class="pdu-current-location">Rack: {{ pdu.rack.rack_id }}</div>
    </div>
    <div class="pdu-stats">
        <div class="pdu-stat-item">
            Outlets Used: <span class="pdu-stat-value">{{ pdu.used_outlets }}/{{ pdu.total_outlets }}</span>
        </div>
        <div class="pdu-stat-item">
            Capacity: <span class="pdu-stat-value">{{ pdu.capacity_amps }}A @ {{ pdu.voltage }}V</span>
        </div>
        {% if pdu.ip_address %}
        <div class="pdu-stat-item">
            IP: <span class="pdu-stat-value">{{ pdu.ip_address }}</span>
        </div>
        {% endif %}
    </div>
</div>

<div class="form-container">
    <div class="form-card">
        <form method="POST" action="{{ url_for('pdus.edit_pdu', pdu_id=pdu.id) }}" novalidate>
            {{ form.hidden_tag() }}
            {{ form.pdu_id }}  <!-- CHANGED v1.1.3: Hidden field for IPAM validation -->
            
            <!-- ========== IDENTIFICATION ========== -->
            <div class="form-section">
                <h3 class="form-section-title">PDU Identification</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.identifier.id }}" class="form-label">
                            PDU Identifier <span class="required">*</span>
                        </label>
                        {{ form.identifier(class="form-control" + (" is-invalid" if form.identifier.errors else "")) }}
                        <small class="form-text">Sequential numbering (APC 1, APC 2, etc.)</small>
                        {% if form.identifier.errors %}
                            {% for error in form.identifier.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.model.id }}" class="form-label">Model</label>
                        {{ form.model(class="form-control") }}
                        <small class="form-text">APC model number (e.g., AP7932, AP8941)</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.circuit_id.id }}" class="form-label">Circuit ID</label>
                        {{ form.circuit_id(class="form-control") }}
                        <small class="form-text">Power circuit identifier</small>
                    </div>
                </div>
            </div>
            
            <!-- ========== ELECTRICAL ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Electrical Specifications</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Capacity (Amps) <span class="required">*</span></label>
                        {{ form.capacity_amps(class="form-control" + (" is-invalid" if form.capacity_amps.errors else "")) }}
                        {% if form.capacity_amps.errors %}
                            {% for error in form.capacity_amps.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Voltage <span class="required">*</span></label>
                        {{ form.voltage(class="form-control" + (" is-invalid" if form.voltage.errors else "")) }}
                        {% if form.voltage.errors %}
                            {% for error in form.voltage.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Phase <span class="required">*</span></label>
                        {{ form.phase(class="form-control" + (" is-invalid" if form.phase.errors else "")) }}
                        {% if form.phase.errors %}
                            {% for error in form.phase.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Total Outlets <span class="required">*</span></label>
                        {{ form.total_outlets(class="form-control" + (" is-invalid" if form.total_outlets.errors else "")) }}
                        {% if form.total_outlets.errors %}
                            {% for error in form.total_outlets.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Outlets In Use</label>
                        <input type="text" class="form-control" value="{{ pdu.used_outlets }}" disabled>
                        <small class="form-text">Automatically tracked by connected devices</small>
                    </div>
                </div>
            </div>

            <!-- ========== NETWORK CONNECTIVITY (v1.2.0) ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Network Switch Connection</h3>
                
                <div class="info-box">
                    <div class="info-box-content">
                        <strong>For Managed PDUs:</strong> Specify which switch and port this PDU's management interface connects to.
                        This helps track network topology and troubleshoot connectivity issues.
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.connected_switch_id.id }}" class="form-label">
                            Connected to Switch
                        </label>
                        {{ form.connected_switch_id(class="form-control", onchange="updatePortOptions()") }}
                        <small class="form-text">Select the switch this PDU connects to</small>
                        {% if form.connected_switch_id.errors %}
                            {% for error in form.connected_switch_id.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <div class="form-group">
                        <label for="{{ form.connected_switch_port.id }}" class="form-label">
                            Switch Port Number
                        </label>
                        {{ form.connected_switch_port(class="form-control" + (" is-invalid" if form.connected_switch_port.errors else "")) }}
                        <small class="form-text">Port number on the selected switch (1-48, etc.)</small>
                        {% if form.connected_switch_port.errors %}
                            {% for error in form.connected_switch_port.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                
                <div id="portAvailabilityMessage" style="margin-top: 10px; display: none;">
                    <div class="alert" style="padding: 10px; border-radius: 6px;">
                        <span id="portStatus"></span>
                    </div>
                </div>
            </div>
            
            <!-- ========== MANAGEMENT INTERFACE ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Management Interface</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.ip_address.id }}" class="form-label">
                            Management IP Address
                        </label>
                        {{ form.ip_address(class="form-control" + (" is-invalid" if form.ip_address.errors else "")) }}
                        <small class="form-text">Private network IP (10.10.x.x) for web interface</small>
                        {% if pdu and pdu.connected_switch %}
                        <small class="form-text" style="color: #60a5fa;">
                            Connected via: {{ pdu.connected_switch.identifier }} Port {{ pdu.connected_switch_port }}
                        </small>
                        {% endif %}
                        {% if form.ip_address.errors %}
                            {% for error in form.ip_address.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    
                    <!-- CHANGED v1.1.3: Added optional VLAN field for IPAM -->
                    <div class="form-group">
                        <label for="{{ form.vlan_id.id }}" class="form-label">
                            Management VLAN  
                        </label>
                        {{ form.vlan_id(class="form-control") }}
                        <small class="form-text">Optional VLAN ID for management network</small>
                        {% if form.vlan_id.errors %}
                            {% for error in form.vlan_id.errors %}
                                <div class="invalid-feedback">{{ error }}</div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- ========== NOTES ========== -->
            <div class="form-section">
                <h3 class="form-section-title">Additional Information</h3>
                
                <div class="form-group">
                    <label for="{{ form.notes.id }}" class="form-label">
                        Additional Notes
                    </label>
                    {{ form.notes(class="form-control") }}
                    <small class="form-text">Any additional information about this PDU</small>
                    {% if form.notes.errors %}
                        {% for error in form.notes.errors %}
                            <div class="invalid-feedback">{{ error }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            
            <!-- ========== ACTION BUTTONS ========== -->
            <div class="button-group">
                <button type="submit" class="btn btn-success">
                    <span style="margin-right: 8px;">💾</span> Save Changes
                </button>
                <a href="{{ url_for('pdus.index') }}" class="btn btn-cancel">
                    <span style="margin-right: 8px;">✕</span> Cancel
                </a>
                
                {% if pdu.used_outlets == 0 %}
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                    <span style="margin-right: 8px;">🗑️</span> Delete PDU
                </button>
                {% endif %}
            </div>
        </form>
        
        <!-- Hidden delete form -->
        {% if pdu.used_outlets == 0 %}
        <form id="deleteForm" method="POST" action="{{ url_for('pdus.delete_pdu', pdu_id=pdu.id) }}" style="display: none;">
        </form>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// ========== DELETE CONFIRMATION ==========
{% if pdu.used_outlets == 0 %}
function confirmDelete() {
    if (confirm('Are you sure you want to delete PDU {{ pdu.identifier }}? This action cannot be undone.')) {
        document.getElementById('deleteForm').submit();
    }
}
{% endif %}

// ========== SWITCH PORT MANAGEMENT ==========
function updatePortOptions() {
    const switchSelect = document.getElementById('{{ form.connected_switch_id.id }}');
    const portField = document.getElementById('{{ form.connected_switch_port.id }}');
    const messageDiv = document.getElementById('portAvailabilityMessage');
    
    if (!switchSelect.value || switchSelect.value === '0') {
        portField.value = '';
        portField.disabled = true;
        messageDiv.style.display = 'none';
    } else {
        portField.disabled = false;
    }
}

// Check port availability when port number changes
document.getElementById('{{ form.connected_switch_port.id }}').addEventListener('blur', function() {
    const switchId = document.getElementById('{{ form.connected_switch_id.id }}').value;
    const portNumber = this.value;
    const messageDiv = document.getElementById('portAvailabilityMessage');
    const portStatus = document.getElementById('portStatus');
    
    if (switchId && switchId !== '0' && portNumber) {
        // Check port availability via API
        fetch(`/api/switch/${switchId}/port/${portNumber}/check`)
            .then(response => response.json())
            .then(data => {
                if (data.available) {
                    portStatus.innerHTML = '✓ Port is available';
                    messageDiv.className = 'alert alert-success';
                } else {
                    // Check if it's this PDU's current port
                    if (data.device_name && data.device_name.includes('PDU {{ pdu.identifier }}')) {
                        portStatus.innerHTML = '✓ Current port assignment';
                        messageDiv.className = 'alert alert-info';
                    } else {
                        portStatus.innerHTML = `✗ Port is in use by ${data.device_name}`;
                        messageDiv.className = 'alert alert-danger';
                    }
                }
                messageDiv.style.display = 'block';
            })
            .catch(error => {
                console.error('Error checking port:', error);
                messageDiv.style.display = 'none';
            });
    } else {
        messageDiv.style.display = 'none';
    }
});

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    updatePortOptions();
});
</script>
{% endblock %}