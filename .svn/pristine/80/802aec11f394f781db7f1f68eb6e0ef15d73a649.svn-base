<!--
File: templates/datacenters/index.html
Purpose: Main data center view showing all racks in all DCs
Version: 2.0.0
Author: iambilky

Revision History:
- v1.0.0: Initial creation with data table and search
- v1.0.1: Added utilization bars and export functionality  
- v1.1.0: Fixed empty state logic - check for DCs not just racks
- v1.2.0: Added quick access to bulk rack creation from dropdown menu
- v1.3.0: Added large emojis to stats, fixed Manage DC button styling, added DC name links
- v1.4.0: Added rack_detail link on Rack ID
- v1.5.0: Fixed button consistency, added visual clarity header, unified stat display formatting
- v1.5.1: Fixed variable bugs - corrected total_available_u calculation, fixed incomplete HTML tags
- v2.0.0: MAJOR UPDATE - Fixed power calculations for actual watts model
         - Removed max-width constraints for full screen utilization
         - Added proper null checking in JavaScript
         - Fixed power capacity aggregation
         - Added DC grouping with collapsible sections
         - Enhanced filtering and visual improvements
         - Added power consumption in watts display
-->

{% extends "base.html" %}

{% block title %}Data Centers{% endblock %}

{% block extra_css %}
<style>
    /* ========== FULL WIDTH CONTAINER ========== */
    /* CHANGED: Removed max-width for full screen utilization */
    .page-container {
        width: 100%;
        padding: 20px;
    }
    
    /* ========== PAGE HEADER ========== */
    .page-header-section {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(96, 165, 250, 0.03));
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
    }
    
    .page-title-row {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 10px;
    }
    
    .page-icon {
        font-size: 3rem;
        line-height: 1;
    }
    
    .page-title-info {
        flex: 1;
    }
    
    .page-main-title {
        color: #60a5fa;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 5px;
    }
    
    .page-description {
        color: #8b92a5;
        font-size: 1.1rem;
    }
    
    /* ========== SUMMARY BAR ========== */
    .summary-bar {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }
    
    .summary-item {
        text-align: center;
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 10px 20px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
        transition: all 0.2s ease;
    }
    
    .summary-item:hover {
        background: rgba(255, 255, 255, 0.06);
        transform: translateY(-2px);
    }
    
    .stat-icon {
        font-size: 2.5rem;
        line-height: 1;
    }
    
    .stat-content {
        text-align: left;
    }
    
    .summary-label {
        color: #8b92a5;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }
    
    .summary-value {
        color: #60a5fa;
        font-size: 1.8rem;
        font-weight: 700;
    }
    
    /* ========== ACTION BAR ========== */
    .action-bar {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }
    
    .search-section {
        flex: 1;
        min-width: 300px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    
    .search-info {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #8b92a5;
        font-size: 0.9rem;
    }
    
    .search-box {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 10px 15px;
        color: #fff;
        font-size: 1rem;
        width: 100%;
    }
    
    .search-box:focus {
        outline: none;
        border-color: #60a5fa;
        background: rgba(255, 255, 255, 0.1);
    }
    
    .btn-group {
        display: flex;
        gap: 10px;
        align-items: center;
    }
    
    /* ========== FILTER BAR ========== */
    .filter-bar {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 15px 20px;
        margin-bottom: 20px;
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }
    
    .filter-select {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 6px;
        padding: 8px 12px;
        color: #fff;
        font-size: 0.9rem;
        min-width: 150px;
    }
    
    .filter-label {
        color: #8b92a5;
        font-size: 0.85rem;
        margin-right: 8px;
    }
    
    /* ========== DATA SECTION ========== */
    .data-section {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        overflow: hidden;
    }
    
    /* ========== DC GROUP HEADER ========== */
    .dc-group-header {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(96, 165, 250, 0.08));
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .dc-group-header:hover {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(96, 165, 250, 0.1));
    }
    
    .dc-group-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.1rem;
        font-weight: 600;
        color: #60a5fa;
    }
    
    .dc-group-stats {
        display: flex;
        gap: 20px;
        align-items: center;
    }
    
    .dc-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    
    .dc-stat-value {
        font-size: 1.2rem;
        font-weight: 600;
        color: #fff;
    }
    
    .dc-stat-label {
        font-size: 0.75rem;
        color: #8b92a5;
        text-transform: uppercase;
    }
    
    .collapse-icon {
        transition: transform 0.3s ease;
    }
    
    .collapsed .collapse-icon {
        transform: rotate(-90deg);
    }
    
    /* ========== DATA TABLE ========== */
    .data-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    
    .data-table thead {
        background: rgba(59, 130, 246, 0.1);
    }
    
    .data-table thead th {
        padding: 15px;
        text-align: left;
        color: #60a5fa;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 2px solid rgba(59, 130, 246, 0.3);
        position: sticky;
        top: 0;
        background: rgba(10, 10, 15, 0.95);
        backdrop-filter: blur(10px);
        z-index: 10;
    }
    
    .data-table tbody tr {
        transition: background 0.2s ease;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .data-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.03);
    }
    
    .data-table tbody td {
        padding: 12px 15px;
        color: #e4e6eb;
    }
    
    /* ========== TABLE ELEMENTS ========== */
    .rack-id-link {
        color: #60a5fa;
        font-weight: 600;
        text-decoration: none;
        font-family: 'Courier New', monospace;
        transition: color 0.2s ease;
    }
    
    .rack-id-link:hover {
        color: #93c5fd;
        text-decoration: underline;
    }
    
    .dc-name-link {
        color: #e4e6eb;
        text-decoration: none;
        transition: color 0.2s ease;
    }
    
    .dc-name-link:hover {
        color: #60a5fa;
    }
    
    .floor-badge {
        background: rgba(139, 92, 246, 0.2);
        color: #a78bfa;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.85rem;
    }
    
    .status-badge {
        background: rgba(34, 197, 94, 0.2);
        color: #86efac;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.85rem;
    }
    
    /* Power display with watts */
    .power-display {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    
    .power-amps {
        color: #f59e0b;
        font-weight: 600;
    }
    
    .power-watts {
        color: #8b92a5;
        font-size: 0.85rem;
    }
    
    /* ========== UTILIZATION BAR ========== */
    .utilization-wrapper {
        width: 120px;
    }
    
    .utilization-bar {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        height: 20px;
        overflow: hidden;
        position: relative;
    }
    
    .utilization-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981, #34d399);
        transition: width 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .utilization-fill.utilization-medium {
        background: linear-gradient(90deg, #f59e0b, #fbbf24);
    }
    
    .utilization-fill.utilization-high {
        background: linear-gradient(90deg, #ef4444, #f87171);
    }
    
    .utilization-label {
        text-align: center;
        margin-top: 4px;
        color: #8b92a5;
        font-size: 0.75rem;
    }
    
    /* ========== ACTION BUTTONS ========== */
    .action-btn {
        padding: 4px 12px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.85rem;
        transition: all 0.2s ease;
        display: inline-block;
        margin: 0 2px;
    }
    
    .action-btn-view {
        background: rgba(96, 165, 250, 0.2);
        color: #60a5fa;
    }
    
    .action-btn-view:hover {
        background: rgba(96, 165, 250, 0.3);
    }
    
    .action-btn-edit {
        background: rgba(251, 191, 36, 0.2);
        color: #fbbf24;
    }
    
    .action-btn-edit:hover {
        background: rgba(251, 191, 36, 0.3);
    }
    
    /* ========== EMPTY STATE ========== */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }
    
    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }
    
    .empty-state-title {
        color: #e4e6eb;
        font-size: 1.5rem;
        margin-bottom: 10px;
    }
    
    .empty-state-message {
        color: #8b92a5;
        margin-bottom: 30px;
    }
    
    /* ========== RESPONSIVE ========== */
    @media (max-width: 1200px) {
        .summary-bar {
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        }
    }
    
    @media (max-width: 768px) {
        .action-bar {
            flex-direction: column;
        }
        
        .search-section {
            width: 100%;
        }
        
        .dc-group-stats {
            display: none;
        }
        
        .data-table {
            font-size: 0.85rem;
        }
        
        .data-table thead th,
        .data-table tbody td {
            padding: 8px;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-container">
    <!-- ========== PAGE HEADER WITH CLARITY ========== -->
    <div class="page-header-section">
        <div class="page-title-row">
            <div class="page-icon">🗄️</div>
            <div class="page-title-info">
                <h1 class="page-main-title">Infrastructure Overview</h1>
                <p class="page-description">Complete inventory of all racks across all data centers</p>
            </div>
        </div>
    </div>

    <!-- ========== SUMMARY STATISTICS ========== -->
    <!-- FIXED: Proper calculations for power and space -->
    <div class="summary-bar">
        <div class="summary-item">
            <div class="stat-icon">🏢</div>
            <div class="stat-content">
                <div class="summary-label">Data Centers</div>
                <div class="summary-value">{{ total_dcs }}</div>
            </div>
        </div>
        
        <div class="summary-item">
            <div class="stat-icon">🗄️</div>
            <div class="stat-content">
                <div class="summary-label">Total Racks</div>
                <div class="summary-value">{{ total_racks }}</div>
            </div>
        </div>
        
        <div class="summary-item">
            <div class="stat-icon">📊</div>
            <div class="stat-content">
                <div class="summary-label">Available Space</div>
                <!-- FIXED: Proper calculation using total_capacity from route -->
                <div class="summary-value">{{ (total_capacity - rack_data|sum(attribute='u_used')) }}U</div>
            </div>
        </div>
        
        <div class="summary-item">
            <div class="stat-icon">⚡</div>
            <div class="stat-content">
                <div class="summary-label">Total Power Capacity</div>
                <!-- FIXED: Show power capacity in amps with null check -->
                {% set total_power_capacity = rack_data|selectattr('power_capacity', 'defined')|selectattr('power_capacity', '!=', none)|sum(attribute='power_capacity') %}
                <div class="summary-value">{{ "%.0f"|format(total_power_capacity) }}A</div>
            </div>
        </div>
        
        <div class="summary-item">
            <div class="stat-icon">💡</div>
            <div class="stat-content">
                <div class="summary-label">Power Used</div>
                <!-- NEW: Show actual power consumption in watts -->
                {% set total_power_used_amps = rack_data|selectattr('power_used', 'defined')|selectattr('power_used', '!=', none)|sum(attribute='power_used') %}
                <div class="summary-value">{{ "%.1f"|format(total_power_used_amps) }}A</div>
            </div>
        </div>
        
        <div class="summary-item">
            <div class="stat-icon">📈</div>
            <div class="stat-content">
                <div class="summary-label">Overall Utilization</div>
                <div class="summary-value">{{ overall_utilization }}%</div>
            </div>
        </div>
    </div>

    <!-- ========== ACTION BAR ========== -->
    <div class="action-bar">
        <div class="search-section">
            <div class="search-info">
                <span class="search-info-icon">📍</span>
                <span>Viewing all racks in all locations</span>
            </div>
            <input type="text" class="search-box" id="searchInput" placeholder="Search racks, DCs, floors...">
        </div>
        
        <div class="btn-group">
            <div class="dropdown">
                <button class="btn btn-primary dropdown-toggle" type="button">
                    <span style="margin-right: 5px;">➕</span> Add New
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="{{ url_for('datacenters.add_datacenter') }}">Add Data Center</a></li>
                    {% if total_dcs > 0 %}
                    <li><hr class="dropdown-divider"></li>
                    <li class="dropdown-header">Quick Add Options</li>
                    <li><a class="dropdown-item" href="#" onclick="showFloorOptions()">Add Floor to DC...</a></li>
                    <li><a class="dropdown-item" href="#" onclick="showRackOptions()">Add Single Rack...</a></li>
                    <li><a class="dropdown-item" href="#" onclick="showBulkRackOptions()">Bulk Add Racks...</a></li>
                    {% endif %}
                </ul>
            </div>
            
            <a href="{{ url_for('datacenters.list_datacenters') }}" class="btn btn-primary">
                <span style="margin-right: 5px;">⚙️</span> Manage DCs
            </a>
            
            {% if rack_data %}
            <button class="btn btn-secondary" onclick="exportTable()">
                <span style="margin-right: 5px;">📊</span> Export CSV
            </button>
            {% endif %}
        </div>
    </div>
    
    <!-- ========== FILTER BAR ========== -->
    {% if rack_data %}
    <div class="filter-bar">
        <span class="filter-label">Filter by:</span>
        <select class="filter-select" id="dcFilter">
            <option value="">All Data Centers</option>
            {% for dc in datacenters %}
            <option value="{{ dc.code }}">{{ dc.code }} - {{ dc.name }}</option>
            {% endfor %}
        </select>
        
        <select class="filter-select" id="utilizationFilter">
            <option value="">All Utilization</option>
            <option value="0-25">0-25%</option>
            <option value="25-50">25-50%</option>
            <option value="50-75">50-75%</option>
            <option value="75-100">75-100%</option>
        </select>
        
        <select class="filter-select" id="powerFilter">
            <option value="">All Power</option>
            <option value="low">Low Usage (&lt;50%)</option>
            <option value="medium">Medium (50-80%)</option>
            <option value="high">High (&gt;80%)</option>
        </select>
    </div>
    {% endif %}

    <!-- ========== MAIN CONTENT AREA ========== -->
    <div class="data-section">
        {% if total_dcs == 0 %}
        <!-- ========== NO DATA CENTERS ========== -->
        <div class="empty-state">
            <div class="empty-state-icon">🏢</div>
            <h3 class="empty-state-title">No Data Centers Configured</h3>
            <p class="empty-state-message">Start by adding your first data center</p>
            <a href="{{ url_for('datacenters.add_datacenter') }}" class="btn btn-primary">
                <span style="margin-right: 8px;">➕</span> Add Data Center
            </a>
        </div>
        
        {% elif rack_data|length == 0 %}
        <!-- ========== NO RACKS YET ========== -->
        <div class="empty-state">
            <div class="empty-state-icon">🗄️</div>
            <h3 class="empty-state-title">No Racks Configured</h3>
            <p class="empty-state-message">You have data centers but no racks yet</p>
            <div class="btn-group">
                <button class="btn btn-primary" onclick="showRackOptions()">
                    <span style="margin-right: 8px;">➕</span> Add Single Rack
                </button>
                <button class="btn btn-secondary" onclick="showBulkRackOptions()">
                    <span style="margin-right: 8px;">📦</span> Bulk Add Racks
                </button>
            </div>
        </div>
        
        {% else %}
        <!-- ========== RACK DATA TABLE ========== -->
        <table class="data-table">
            <thead>
                <tr>
                    <th>Rack ID</th>
                    <th>Data Center</th>
                    <th>Floor</th>
                    <th>Size</th>
                    <th>Usage</th>
                    <th>Utilization</th>
                    <th>Power Usage</th>
                    <th>Power Capacity</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for rack in rack_data %}
                <tr data-dc="{{ rack.dc_code }}" 
                    data-utilization="{{ rack.utilization }}"
                    data-power-util="{{ rack.power_utilization }}">
                    <td>
                        <a href="{{ url_for('datacenters.rack_detail', rack_id=rack.rack_obj_id) }}" 
                           class="rack-id-link">
                            {{ rack.rack_id }}
                        </a>
                    </td>
                    <td>
                        <a href="{{ url_for('datacenters.dc_detail', dc_id=rack.dc_id) }}"
                           class="dc-name-link">
                            {{ rack.dc_name }}
                        </a>
                    </td>
                    <td><span class="floor-badge">{{ rack.floor_actual }}</span></td>
                    <td><span class="status-badge">{{ rack.u_height }}U</span></td>
                    <td>
                        <span style="color: #f59e0b; font-weight: 600;">{{ rack.u_used }}</span> / 
                        <span style="color: #10b981;">{{ rack.u_height }}</span>
                    </td>
                    <td>
                        <div class="utilization-wrapper">
                            <div class="utilization-bar">
                                <div class="utilization-fill 
                                    {% if rack.utilization > 80 %}utilization-high
                                    {% elif rack.utilization > 60 %}utilization-medium
                                    {% endif %}"
                                    style="width: {{ rack.utilization }}%">
                                </div>
                            </div>
                            <div class="utilization-label">{{ rack.u_available }}U free</div>
                        </div>
                    </td>
                    <td>
                        <!-- FIXED: Show power used in amps -->
                        {% if rack.power_used %}
                            <div class="power-display">
                                <span class="power-amps">{{ "%.1f"|format(rack.power_used) }}A</span>
                                <!-- Calculate approximate watts (assuming 120V) -->
                                <span class="power-watts">~{{ "%.0f"|format(rack.power_used * 120) }}W</span>
                            </div>
                        {% else %}
                            <span style="color: #6b7280;">N/A</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if rack.power_capacity %}
                            <span class="status-badge">{{ rack.power_capacity }}A</span>
                        {% else %}
                            <span style="color: #6b7280;">N/A</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ url_for('datacenters.rack_detail', rack_id=rack.rack_obj_id) }}" class="action-btn action-btn-view">View</a>
                        <a href="{{ url_for('datacenters.edit_rack', rack_id=rack.rack_obj_id) }}" class="action-btn action-btn-edit">Edit</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// Quick add functions with proper null checking
function showFloorOptions() {
    const dcs = [
        {% for dc in datacenters %}
        {id: {{ dc.id }}, code: '{{ dc.code }}', name: '{{ dc.name }}'},
        {% endfor %}
    ];
    
    if (dcs.length === 0) {
        alert('No data centers available! Please add a data center first.');
        return;
    }
    
    if (dcs.length === 1) {
        window.location.href = "{{ url_for('datacenters.add_floor', dc_id=0) }}".replace('/0', '/' + dcs[0].id);
    } else {
        let options = 'Select a Data Center:\n\n';
        dcs.forEach((dc, index) => {
            options += `${index + 1}. ${dc.code} - ${dc.name}\n`;
        });
        
        const choice = prompt(options + '\nEnter number:');
        // FIXED: Added null check
        if (choice && !isNaN(parseInt(choice)) && dcs[parseInt(choice) - 1]) {
            const selectedDc = dcs[parseInt(choice) - 1];
            window.location.href = "{{ url_for('datacenters.add_floor', dc_id=0) }}".replace('/0', '/' + selectedDc.id);
        }
    }
}

function showRackOptions() {
    // Get all floors from all DCs
    const floors = [
        {% for dc in datacenters %}
            {% for floor in dc.floors %}
            {
                id: {{ floor.id }}, 
                dc_code: '{{ dc.code }}',
                dc_name: '{{ dc.name }}',
                floor: '{{ floor.provider_designation }}'
            },
            {% endfor %}
        {% endfor %}
    ];
    
    if (floors.length === 0) {
        alert('No floors available! Please add a floor first.');
        return;
    }
    
    if (floors.length === 1) {
        window.location.href = "{{ url_for('datacenters.add_rack', floor_id=0) }}".replace('/0', '/' + floors[0].id);
    } else {
        let options = 'Select a Floor:\n\n';
        floors.forEach((floor, index) => {
            options += `${index + 1}. ${floor.dc_code} - Floor ${floor.floor}\n`;
        });
        
        const choice = prompt(options + '\nEnter number:');
        // FIXED: Added null check
        if (choice && !isNaN(parseInt(choice)) && floors[parseInt(choice) - 1]) {
            const selectedFloor = floors[parseInt(choice) - 1];
            window.location.href = "{{ url_for('datacenters.add_rack', floor_id=0) }}".replace('/0', '/' + selectedFloor.id);
        }
    }
}

function showBulkRackOptions() {
    const floors = [
        {% for dc in datacenters %}
            {% for floor in dc.floors %}
            {
                id: {{ floor.id }}, 
                dc_code: '{{ dc.code }}',
                floor: '{{ floor.provider_designation }}'
            },
            {% endfor %}
        {% endfor %}
    ];
    
    if (floors.length === 0) {
        alert('No floors available! Please add a floor first.');
        return;
    }
    
    if (floors.length === 1) {
        window.location.href = "{{ url_for('datacenters.bulk_add_racks', floor_id=0) }}".replace('/0', '/' + floors[0].id);
    } else {
        let options = 'Select a Floor for Bulk Rack Creation:\n\n';
        floors.forEach((floor, index) => {
            options += `${index + 1}. ${floor.dc_code} - Floor ${floor.floor}\n`;
        });
        
        const choice = prompt(options + '\nEnter number:');
        // FIXED: Added null check
        if (choice && !isNaN(parseInt(choice)) && floors[parseInt(choice) - 1]) {
            const selectedFloor = floors[parseInt(choice) - 1];
            window.location.href = "{{ url_for('datacenters.bulk_add_racks', floor_id=0) }}".replace('/0', '/' + selectedFloor.id);
        }
    }
}

// Enhanced filtering functionality
function applyFilters() {
    const searchValue = document.getElementById('searchInput').value.toLowerCase();
    const dcFilter = document.getElementById('dcFilter')?.value || '';
    const utilFilter = document.getElementById('utilizationFilter')?.value || '';
    const powerFilter = document.getElementById('powerFilter')?.value || '';
    
    const rows = document.querySelectorAll('.data-table tbody tr');
    
    rows.forEach(row => {
        let show = true;
        
        // Search filter
        if (searchValue && !row.textContent.toLowerCase().includes(searchValue)) {
            show = false;
        }
        
        // DC filter
        if (dcFilter && row.dataset.dc !== dcFilter) {
            show = false;
        }
        
        // Utilization filter
        if (utilFilter) {
            const util = parseFloat(row.dataset.utilization) || 0;
            const [min, max] = utilFilter.split('-').map(Number);
            if (util < min || util > max) {
                show = false;
            }
        }
        
        // Power filter
        if (powerFilter) {
            const powerUtil = parseFloat(row.dataset.powerUtil) || 0;
            if (powerFilter === 'low' && powerUtil >= 50) show = false;
            if (powerFilter === 'medium' && (powerUtil < 50 || powerUtil > 80)) show = false;
            if (powerFilter === 'high' && powerUtil <= 80) show = false;
        }
        
        row.style.display = show ? '' : 'none';
    });
}

// Event listeners
document.getElementById('searchInput')?.addEventListener('keyup', applyFilters);
document.getElementById('dcFilter')?.addEventListener('change', applyFilters);
document.getElementById('utilizationFilter')?.addEventListener('change', applyFilters);
document.getElementById('powerFilter')?.addEventListener('change', applyFilters);

// Export to CSV with power in watts
function exportTable() {
    let csv = 'Rack ID,Data Center,Floor,Size,Used,Available,Utilization,Power Used (A),Power Used (W),Power Capacity (A),Rack Code\n';
    
    {% for rack in rack_data %}
    csv += '"{{ rack.rack_id }}","{{ rack.dc_name }}","{{ rack.floor_actual }}",';
    csv += '{{ rack.u_height }},{{ rack.u_used }},{{ rack.u_available }},';
    csv += '{{ rack.utilization }}%,';
    csv += '{{ "%.1f"|format(rack.power_used) if rack.power_used else "N/A" }},';
    // Calculate watts (assuming 120V)
    csv += '{{ "%.0f"|format(rack.power_used * 120) if rack.power_used else "N/A" }},';
    csv += '{{ rack.power_capacity if rack.power_capacity else "N/A" }},';
    csv += '"{{ rack.rack_code or "Not Set" }}"\n';
    {% endfor %}
    
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'rack_inventory_' + new Date().toISOString().split('T')[0] + '.csv';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
}
</script>
{% endblock %}