<!--
File: templates/datacenters/list_datacenters.html
Purpose: List view for managing data centers and floors
Version: 2.0.0
Author: iambilky

Revision History:
- v1.0.0: Initial creation with DC/floor management interface
- v1.1.0: Fixed address display to show formatted multi-line address
- v2.0.0: Enhanced with emojis, visual improvements, quick stats, and interactive features
-->

{% extends "base.html" %}

{% block title %}Manage Data Centers{% endblock %}

{% block extra_css %}
<style>
    /* ========== HEADER SECTION ========== */
    .management-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(96, 165, 250, 0.02));
        padding: 25px;
        border-radius: 12px;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }
    
    .header-title {
        flex: 1;
    }
    
    .header-title h2 {
        color: #60a5fa;
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 5px;
    }
    
    .header-subtitle {
        color: #8b92a5;
        font-size: 1rem;
    }
    
    .header-actions {
        display: flex;
        gap: 12px;
    }
    
    .btn-back {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s ease;
    }
    
    .btn-back:hover {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        text-decoration: none;
        transform: translateX(-2px);
    }
    
    /* ========== SUMMARY STATS BAR ========== */
    .summary-stats {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }
    
    .summary-stat {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
        transition: all 0.2s ease;
    }
    
    .summary-stat:hover {
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-2px);
    }
    
    .summary-icon {
        font-size: 2.5rem;
        line-height: 1;
    }
    
    .summary-content {
        flex: 1;
    }
    
    .summary-value {
        color: #60a5fa;
        font-size: 1.8rem;
        font-weight: 700;
        line-height: 1;
    }
    
    .summary-label {
        color: #8b92a5;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 5px;
    }
    
    /* ========== SEARCH & FILTER BAR ========== */
    .filter-bar {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        gap: 15px;
        align-items: center;
    }
    
    .search-box {
        flex: 1;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 10px 15px;
        color: #fff;
        font-size: 1rem;
    }
    
    .search-box::placeholder {
        color: #8b92a5;
    }
    
    .search-box:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.1);
        border-color: #60a5fa;
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
    }
    
    .filter-chips {
        display: flex;
        gap: 10px;
    }
    
    .filter-chip {
        background: rgba(96, 165, 250, 0.2);
        border: 1px solid rgba(96, 165, 250, 0.3);
        color: #60a5fa;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .filter-chip:hover {
        background: rgba(96, 165, 250, 0.3);
        transform: scale(1.05);
    }
    
    .filter-chip.active {
        background: #60a5fa;
        color: #1a1f2e;
        font-weight: 600;
    }
    
    /* ========== DC CARDS ========== */
    .dc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(550px, 1fr));
        gap: 25px;
        margin-bottom: 30px;
    }
    
    .dc-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
    }
    
    .dc-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #60a5fa, transparent);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
    }
    
    .dc-card:hover::before {
        transform: translateX(100%);
    }
    
    .dc-card:hover {
        background: rgba(255, 255, 255, 0.07);
        border-color: rgba(96, 165, 250, 0.3);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        transform: translateY(-2px);
    }
    
    .dc-header {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(96, 165, 250, 0.05));
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .dc-title {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
    }
    
    .dc-code {
        font-size: 1.5rem;
        font-weight: 700;
        color: #60a5fa;
        font-family: 'Courier New', monospace;
    }
    
    .dc-name {
        color: #e4e6eb;
        font-size: 1.1rem;
        margin-bottom: 15px;
    }
    
    .dc-actions {
        display: flex;
        gap: 8px;
    }
    
    .btn-icon {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e4e6eb;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        font-size: 1.1rem;
    }
    
    .btn-icon:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
        transform: scale(1.1);
    }
    
    .btn-icon.view {
        border-color: rgba(16, 185, 129, 0.3);
    }
    
    .btn-icon.view:hover {
        background: rgba(16, 185, 129, 0.2);
        color: #10b981;
    }
    
    .btn-icon.edit {
        border-color: rgba(96, 165, 250, 0.3);
    }
    
    .btn-icon.edit:hover {
        background: rgba(96, 165, 250, 0.2);
        color: #60a5fa;
    }
    
    .btn-icon.delete {
        border-color: rgba(239, 68, 68, 0.3);
    }
    
    .btn-icon.delete:hover {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }
    
    /* ========== DC STATS ========== */
    .dc-stats {
        padding: 15px 20px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        background: rgba(0, 0, 0, 0.2);
    }
    
    .stat-item {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }
    
    .stat-emoji {
        font-size: 1.8rem;
        line-height: 1;
    }
    
    .stat-label {
        color: #8b92a5;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .stat-value {
        color: #e4e6eb;
        font-size: 1.3rem;
        font-weight: 600;
    }
    
    .stat-value.highlight {
        color: #60a5fa;
    }
    
    /* ========== DC INFO ========== */
    .dc-info {
        padding: 15px 20px;
    }
    
    .info-row {
        display: flex;
        align-items: flex-start;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .info-row:last-child {
        border-bottom: none;
    }
    
    .info-icon {
        margin-right: 10px;
        font-size: 1rem;
    }
    
    .info-label {
        color: #8b92a5;
        font-size: 0.9rem;
        min-width: 60px;
        margin-right: 15px;
    }
    
    .info-value {
        color: #e4e6eb;
        font-size: 0.9rem;
        flex: 1;
    }
    
    /* Address formatting */
    .address-value {
        color: #e4e6eb;
        font-size: 0.9rem;
        line-height: 1.4;
        white-space: pre-line;
    }
    
    /* ========== CONTACTS PREVIEW ========== */
    .contacts-preview {
        padding: 15px 20px;
        background: rgba(255, 255, 255, 0.02);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .contact-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    
    .contact-chip {
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        color: #60a5fa;
        padding: 4px 10px;
        border-radius: 15px;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    
    /* ========== FLOORS SECTION ========== */
    .floors-section {
        padding: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .floors-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }
    
    .floors-title {
        color: #60a5fa;
        font-weight: 600;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .floor-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s ease;
    }
    
    .floor-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.15);
        transform: translateX(5px);
    }
    
    .floor-info {
        flex: 1;
    }
    
    .floor-designation {
        color: #e4e6eb;
        font-weight: 600;
        margin-right: 10px;
    }
    
    .floor-actual {
        color: #8b92a5;
        font-size: 0.9rem;
    }
    
    .floor-stats {
        color: #8b92a5;
        font-size: 0.85rem;
        margin-top: 5px;
        display: flex;
        gap: 15px;
    }
    
    .floor-stat-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }
    
    .floor-actions {
        display: flex;
        gap: 8px;
    }
    
    /* ========== EMPTY STATE ========== */
    .no-floors {
        text-align: center;
        padding: 40px;
        color: #8b92a5;
        font-style: italic;
    }
    
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #8b92a5;
    }
    
    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
        animation: float 3s ease-in-out infinite;
    }
    
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }
    
    .empty-state h3 {
        color: #fff;
        font-size: 1.5rem;
        margin-bottom: 10px;
    }
    
    /* ========== UTILIZATION BAR ========== */
    .utilization-mini {
        margin-top: 10px;
    }
    
    .utilization-bar-mini {
        height: 8px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        overflow: hidden;
        position: relative;
    }
    
    .utilization-fill-mini {
        height: 100%;
        transition: width 0.6s ease;
        position: relative;
        overflow: hidden;
    }
    
    .utilization-fill-mini::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        animation: shimmer 2s infinite;
    }
    
    .utilization-low { background: linear-gradient(90deg, #10b981, #34d399); }
    .utilization-medium { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .utilization-high { background: linear-gradient(90deg, #ef4444, #f87171); }
    
    .utilization-label {
        text-align: center;
        margin-top: 8px;
        color: #8b92a5;
        font-size: 0.85rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }
    
    .utilization-percent {
        color: #60a5fa;
        font-weight: 600;
    }
    
    /* ========== RESPONSIVE ========== */
    @media (max-width: 768px) {
        .dc-grid {
            grid-template-columns: 1fr;
        }
        
        .dc-stats {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .summary-stats {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .filter-bar {
            flex-direction: column;
        }
        
        .search-box {
            width: 100%;
        }
    }
</style>
{% endblock %}

{% block content %}
<!-- ========== HEADER WITH TITLE AND ACTIONS ========== -->
<div class="management-header">
    <div class="header-title">
        <h2>🏢 Data Center Management</h2>
        <p class="header-subtitle">Manage your data centers, floors, and infrastructure</p>
    </div>
    
    <div class="header-actions">
        <a href="{{ url_for('datacenters.index') }}" class="btn-back">
            <span>←</span> Back to Rack View
        </a>
        
        <a href="{{ url_for('datacenters.add_datacenter') }}" class="btn btn-primary">
            <span style="margin-right: 8px;">➕</span> Add Data Center
        </a>
    </div>
</div>

<!-- ========== SUMMARY STATISTICS ========== -->
{% if dc_stats %}
<div class="summary-stats">
    <div class="summary-stat">
        <div class="summary-icon">🏢</div>
        <div class="summary-content">
            <div class="summary-value">{{ dc_stats|length }}</div>
            <div class="summary-label">Data Centers</div>
        </div>
    </div>
    
    <div class="summary-stat">
        <div class="summary-icon">🏗️</div>
        <div class="summary-content">
            <div class="summary-value">{{ dc_stats|sum(attribute='floor_count') }}</div>
            <div class="summary-label">Total Floors</div>
        </div>
    </div>
    
    <div class="summary-stat">
        <div class="summary-icon">🗄️</div>
        <div class="summary-content">
            <div class="summary-value">{{ dc_stats|sum(attribute='rack_count') }}</div>
            <div class="summary-label">Total Racks</div>
        </div>
    </div>
    
    <div class="summary-stat">
        <div class="summary-icon">📊</div>
        <div class="summary-content">
            <div class="summary-value">{{ dc_stats|sum(attribute='total_u') }}U</div>
            <div class="summary-label">Total Capacity</div>
        </div>
    </div>
    
    <div class="summary-stat">
        <div class="summary-icon">⚡</div>
        <div class="summary-content">
            {% set total_u_sum = dc_stats|sum(attribute='total_u') %}
            {% set used_u_sum = dc_stats|sum(attribute='used_u') %}
            {% set overall_util = ((used_u_sum / total_u_sum * 100) | round(1)) if total_u_sum > 0 else 0 %}
            <div class="summary-value">{{ overall_util }}%</div>
            <div class="summary-label">Overall Usage</div>
        </div>
    </div>
</div>

<!-- ========== SEARCH AND FILTER BAR ========== -->
<div class="filter-bar">
    <input type="text" class="search-box" id="searchInput" placeholder="🔍 Search data centers, locations, contacts...">
    
    <div class="filter-chips">
        <span class="filter-chip active" data-filter="all">All DCs</span>
        <span class="filter-chip" data-filter="high-util">High Usage (>80%)</span>
        <span class="filter-chip" data-filter="low-util">Low Usage (<50%)</span>
    </div>
</div>
{% endif %}

<!-- ========== DATA CENTER CARDS ========== -->
{% if dc_stats %}
<div class="dc-grid">
    {% for stat in dc_stats %}
    <div class="dc-card" data-utilization="{{ stat.utilization }}">
        <!-- DC Header -->
        <div class="dc-header">
            <div class="dc-title">
                <div>
                    <div class="dc-code">{{ stat.dc.code }}</div>
                    <div class="dc-name">{{ stat.dc.name }}</div>
                </div>
                <div class="dc-actions">
                    <a href="{{ url_for('datacenters.dc_detail', dc_id=stat.dc.id) }}" 
                       class="btn-icon view" title="View Details">
                        👁️
                    </a>
                    <a href="{{ url_for('datacenters.edit_datacenter', dc_id=stat.dc.id) }}" 
                       class="btn-icon edit" title="Edit Data Center">
                        ✏️
                    </a>
                    {% if stat.floor_count == 0 %}
                    <form method="POST" action="{{ url_for('datacenters.delete_datacenter', dc_id=stat.dc.id) }}" 
                          style="display: inline;" 
                          onsubmit="return confirm('Delete data center {{ stat.dc.code }}?');">
                        <button type="submit" class="btn-icon delete" title="Delete Data Center">
                            🗑️
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
        </div>
        
        <!-- DC Stats Grid with Emojis -->
        <div class="dc-stats">
            <div class="stat-item">
                <div class="stat-emoji">🏗️</div>
                <div class="stat-value">{{ stat.floor_count }}</div>
                <div class="stat-label">Floors</div>
            </div>
            <div class="stat-item">
                <div class="stat-emoji">🗄️</div>
                <div class="stat-value">{{ stat.rack_count }}</div>
                <div class="stat-label">Racks</div>
            </div>
            <div class="stat-item">
                <div class="stat-emoji">📊</div>
                <div class="stat-value">{{ stat.total_u }}</div>
                <div class="stat-label">Total U</div>
            </div>
            <div class="stat-item">
                <div class="stat-emoji">⚡</div>
                <div class="stat-value highlight">{{ stat.used_u }}</div>
                <div class="stat-label">Used U</div>
            </div>
        </div>
        
        <!-- DC Info -->
        {% if stat.dc.address or stat.dc.contact_phone or stat.dc.contact_email %}
        <div class="dc-info">
            {% if stat.dc.address %}
            <div class="info-row">
                <span class="info-icon">📍</span>
                <span class="info-label">Location:</span>
                <span class="address-value">{{ stat.dc.address | replace(',', ',\n') | trim }}</span>
            </div>
            {% endif %}
            {% if stat.dc.contact_phone %}
            <div class="info-row">
                <span class="info-icon">📞</span>
                <span class="info-label">NOC:</span>
                <span class="info-value">{{ stat.dc.contact_phone }}</span>
            </div>
            {% endif %}
            {% if stat.dc.contact_email %}
            <div class="info-row">
                <span class="info-icon">✉️</span>
                <span class="info-label">Email:</span>
                <span class="info-value">{{ stat.dc.contact_email }}</span>
            </div>
            {% endif %}
        </div>
        {% endif %}
        
        <!-- Contacts Preview -->
        {% if stat.dc.sales_name or stat.dc.pm_name or stat.dc.manager_name %}
        <div class="contacts-preview">
            <div class="contact-chips">
                {% if stat.dc.sales_name %}
                <span class="contact-chip">💼 {{ stat.dc.sales_name }}</span>
                {% endif %}
                {% if stat.dc.pm_name %}
                <span class="contact-chip">📊 {{ stat.dc.pm_name }}</span>
                {% endif %}
                {% if stat.dc.manager_name %}
                <span class="contact-chip">👔 {{ stat.dc.manager_name }}</span>
                {% endif %}
            </div>
        </div>
        {% endif %}
        
        <!-- Floors Section -->
        <div class="floors-section">
            <div class="floors-header">
                <div class="floors-title">
                    <span>🏗️</span>
                    <span>Floors ({{ stat.floor_count }})</span>
                </div>
                <a href="{{ url_for('datacenters.add_floor', dc_id=stat.dc.id) }}" 
                   class="btn btn-sm btn-primary">
                    <span style="margin-right: 5px;">➕</span> Add Floor
                </a>
            </div>
            
            {% if stat.dc.floors.count() > 0 %}
                {% for floor in stat.dc.floors %}
                <div class="floor-item">
                    <div class="floor-info">
                        <span class="floor-designation">{{ floor.provider_designation }}</span>
                        <span class="floor-actual">(Actual: {{ floor.actual_floor }})</span>
                        <div class="floor-stats">
                            <span class="floor-stat-item">
                                <span>🗄️</span>
                                <span>{{ floor.racks.count() }} racks</span>
                            </span>
                            <span class="floor-stat-item">
                                <span>📊</span>
                                <span>{{ floor.racks | sum(attribute='u_height', start=0) }}U capacity</span>
                            </span>
                        </div>
                    </div>
                    <div class="floor-actions">
                        <a href="{{ url_for('datacenters.add_rack', floor_id=floor.id) }}" 
                           class="btn-icon" title="Add Rack" style="font-size: 0.9rem;">
                            ➕
                        </a>
                        <a href="{{ url_for('datacenters.bulk_add_racks', floor_id=floor.id) }}" 
                           class="btn-icon" title="Bulk Add Racks" style="font-size: 0.9rem;">
                            📦
                        </a>
                        <a href="{{ url_for('datacenters.edit_floor', floor_id=floor.id) }}" 
                           class="btn-icon" title="Edit Floor" style="font-size: 0.9rem;">
                            ✏️
                        </a>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="no-floors">
                    No floors configured yet
                </div>
            {% endif %}
        </div>
        
        <!-- Utilization Bar -->
        {% if stat.total_u > 0 %}
        <div class="utilization-mini" style="padding: 0 20px 20px;">
            <div class="utilization-bar-mini">
                {% set util_class = 'utilization-low' if stat.utilization < 50 else ('utilization-medium' if stat.utilization < 80 else 'utilization-high') %}
                <div class="utilization-fill-mini {{ util_class }}" style="width: {{ stat.utilization }}%"></div>
            </div>
            <div class="utilization-label">
                <span>📈 Utilization:</span>
                <span class="utilization-percent">{{ stat.utilization }}%</span>
                <span>({{ stat.used_u }}/{{ stat.total_u }}U)</span>
            </div>
        </div>
        {% endif %}
    </div>
    {% endfor %}
</div>

{% else %}
<!-- ========== EMPTY STATE ========== -->
<div class="empty-state">
    <div class="empty-state-icon">🏢</div>
    <h3>No Data Centers Configured</h3>
    <p>Start by adding your first data center to begin managing your infrastructure</p>
    <a href="{{ url_for('datacenters.add_datacenter') }}" class="btn btn-primary mt-3">
        <span style="margin-right: 5px;">➕</span> Add Your First Data Center
    </a>
</div>
{% endif %}

{% endblock %}

{% block extra_js %}
<script>
// ========== SEARCH FUNCTIONALITY ==========
document.getElementById('searchInput')?.addEventListener('keyup', function() {
    const searchValue = this.value.toLowerCase();
    const cards = document.querySelectorAll('.dc-card');
    
    cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(searchValue) ? '' : 'none';
    });
});

// ========== FILTER CHIPS ==========
document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        // Remove active from all chips
        document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
        this.classList.add('active');
        
        const filter = this.dataset.filter;
        const cards = document.querySelectorAll('.dc-card');
        
        cards.forEach(card => {
            const utilization = parseFloat(card.dataset.utilization);
            
            if (filter === 'all') {
                card.style.display = '';
            } else if (filter === 'high-util') {
                card.style.display = utilization >= 80 ? '' : 'none';
            } else if (filter === 'low-util') {
                card.style.display = utilization < 50 ? '' : 'none';
            }
        });
    });
});

// ========== CONFIRM DIALOGS ==========
function confirmDeleteDC(code) {
    return confirm(`Are you sure you want to delete data center ${code}? This action cannot be undone.`);
}

function confirmDeleteFloor(designation) {
    return confirm(`Are you sure you want to delete floor ${designation}? This action cannot be undone.`);
}

// ========== TOOLTIPS ==========
document.querySelectorAll('[title]').forEach(element => {
    element.addEventListener('mouseenter', function() {
        // Could add custom tooltip implementation here if needed
    });
});
</script>
{% endblock %}