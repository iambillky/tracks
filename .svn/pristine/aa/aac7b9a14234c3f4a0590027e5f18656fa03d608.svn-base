<!--
File: templates/servers/add.html
Purpose: Tabbed form interface for adding new servers
Version: 2.0.6
Author: DCMS Team
Date: 2025-01-17

CHANGED v2.0.6: Fixed multiple bugs
- Fixed incomplete CSS declaration for nav-tabs margin-right
- Removed duplicate rack.classList.add('is-invalid') line
- Fixed connectionIndex variable initialization placement
- Corrected form field ID references to match actual form fields
- Fixed validation function to properly check for null elements

Features:
- Multiple network connections support
- Bulk IP assignment via textarea
- Real-time validation
- Colocation auto-detection
-->

{% extends "base.html" %}

{% block title %}Add Server{% endblock %}

{% block extra_css %}
<style>
    /* ========== FORM CONTAINER ========== */
    .form-container {
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .form-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 30px;
    }
    
    /* ========== TAB STYLES ========== */
    .nav-tabs {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 20px;
    }
    
    .nav-tabs .nav-link {
        background: transparent;
        border: 1px solid transparent;
        border-radius: 8px 8px 0 0;
        color: #94a3b8;
        padding: 12px 20px;
        margin-right: 5px; /* FIXED: Complete CSS declaration */
        transition: all 0.2s ease;
        cursor: pointer;
        text-decoration: none;
    }
    
    .nav-tabs .nav-link:hover:not(.disabled) {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1) rgba(255, 255, 255, 0.1) transparent;
        color: #e4e6eb;
    }
    
    .nav-tabs .nav-link.active {
        background: rgba(96, 165, 250, 0.1);
        border-color: rgba(96, 165, 250, 0.3) rgba(96, 165, 250, 0.3) transparent;
        color: #60a5fa;
        border-bottom-color: transparent;
    }
    
    .nav-tabs .nav-link.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        pointer-events: none;
    }
    
    /* Tab content styles */
    .tab-content {
        padding: 20px 0;
    }
    
    .tab-pane {
        display: none;
    }
    
    .tab-pane.show.active {
        display: block;
    }
    
    /* ========== FORM SECTIONS ========== */
    .form-section {
        margin-bottom: 35px;
    }
    
    .form-section-title {
        color: #60a5fa;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    /* ========== FORM GROUPS ========== */
    .form-group {
        margin-bottom: 25px;
    }
    
    .form-label {
        display: block;
        color: #e4e6eb;
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    
    .form-label .required {
        color: #ef4444;
        margin-left: 3px;
    }
    
    /* ========== FORM CONTROLS ========== */
    .form-control {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 10px 14px;
        color: #fff;
        font-size: 1rem;
        transition: all 0.2s ease;
    }
    
    .form-control:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.1);
        border-color: #60a5fa;
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
    }
    
    .form-control::placeholder {
        color: #6b7280;
    }
    
    select.form-control {
        cursor: pointer;
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 100px;
        font-family: 'Courier New', monospace;
    }
    
    /* ========== FORM ROW ========== */
    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }
    
    /* ========== VALIDATION STATES ========== */
    .is-invalid {
        border-color: #ef4444 !important;
    }
    
    .invalid-feedback {
        display: block;
        color: #ef4444;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    .valid-feedback {
        display: block;
        color: #10b981;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    /* ========== HELP TEXT ========== */
    .form-text {
        display: block;
        color: #8b92a5;
        font-size: 0.875rem;
        margin-top: 5px;
    }
    
    /* ========== CHECKBOXES ========== */
    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
    }
    
    .form-check-input {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }
    
    .form-check-label {
        color: #e4e6eb;
        cursor: pointer;
    }
    
    /* ========== NETWORK CONNECTION TABLE ========== */
    .connection-table {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
    }
    
    .connection-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr auto;
        gap: 10px;
        align-items: center;
        padding: 10px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 6px;
        margin-bottom: 10px;
    }
    
    /* ========== BUTTONS ========== */
    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
        color: white;
    }
    
    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(96, 165, 250, 0.3);
    }
    
    .btn-secondary {
        background: rgba(255, 255, 255, 0.1);
        color: #e4e6eb;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.15);
    }
    
    .btn-add {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: #10b981;
        padding: 8px 16px;
    }
    
    .btn-add:hover {
        background: rgba(16, 185, 129, 0.2);
    }
    
    .btn-remove {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #ef4444;
        padding: 6px 12px;
    }
    
    .btn-remove:hover {
        background: rgba(239, 68, 68, 0.2);
    }
    
    /* ========== ALERTS ========== */
    .alert {
        padding: 15px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        display: none;
    }
    
    .alert.show {
        display: block;
    }
    
    .alert-warning {
        background: rgba(251, 146, 60, 0.1);
        border: 1px solid rgba(251, 146, 60, 0.3);
        color: #fb923c;
    }
    
    .alert-info {
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.3);
        color: #60a5fa;
    }
    
    /* ========== FORM VALIDATION ERRORS (Flask) ========== */
    .form-errors {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
        color: #ef4444;
    }
    
    .form-errors ul {
        margin: 0;
        padding-left: 20px;
    }
</style>
{% endblock %}

{% block content %}
<div class="form-container">
    <!-- Header -->
    <div class="page-header">
        <h1>Add New Server</h1>
        <a href="{{ url_for('servers.index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Servers
        </a>
    </div>
    
    <!-- Display Flask form validation errors -->
    {% if form.errors %}
    <div class="form-errors">
        <strong>Please correct the following errors:</strong>
        <ul>
            {% for field, errors in form.errors.items() %}
                {% for error in errors %}
                    <li>{{ field.replace('_', ' ').title() }}: {{ error }}</li>
                {% endfor %}
            {% endfor %}
        </ul>
    </div>
    {% endif %}
    
    <!-- Form Card -->
    <form id="serverForm" method="POST" class="form-card" novalidate>
        {{ form.hidden_tag() }}
        
        <!-- Tab Navigation -->
        <ul class="nav nav-tabs" id="serverTabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" id="details-tab" data-toggle="tab" href="#details" role="tab" aria-controls="details" aria-selected="true">
                    <i class="fas fa-server"></i> Server Details
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="network-tab" data-toggle="tab" href="#network" role="tab" aria-controls="network" aria-selected="false">
                    <i class="fas fa-network-wired"></i> Network
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="management-tab" data-toggle="tab" href="#management" role="tab" aria-controls="management" aria-selected="false">
                    <i class="fas fa-cog"></i> Management
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" id="hardware-tab" data-toggle="tab" href="#hardware" role="tab" aria-controls="hardware" aria-selected="false">
                    <i class="fas fa-microchip"></i> Hardware (Phase 2)
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" id="software-tab" data-toggle="tab" href="#software" role="tab" aria-controls="software" aria-selected="false">
                    <i class="fas fa-code"></i> Software (Phase 2)
                </a>
            </li>
        </ul>
        
        <!-- Tab Content -->
        <div class="tab-content" id="serverTabContent">
            
            <!-- ========== TAB 1: SERVER DETAILS ========== -->
            <div class="tab-pane fade show active" id="details" role="tabpanel" aria-labelledby="details-tab">
                
                <!-- Identification -->
                <div class="form-section">
                    <h3 class="form-section-title">Identification</h3>
                    
                    <div class="alert alert-warning" id="coloAlert">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Colocation Server Detected!</strong>
                        This server ID indicates a colocation server. Please ensure:
                        <ul style="margin: 10px 0 0 20px;">
                            <li>Assign to the appropriate customer (required)</li>
                            <li>Use 66.x IP space for public IPs</li>
                            <li>Mark service type as "Colocation"</li>
                        </ul>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.server_id_input.id }}" class="form-label">
                                Server ID <span class="required">*</span>
                            </label>
                            {{ form.server_id_input(class="form-control", onkeyup="validateServerID()", required=True) }}
                            <div id="serverIdFeedback"></div>
                            <div class="invalid-feedback">Please provide a valid server ID</div>
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.server_name.id }}" class="form-label">
                                Server Name <span class="required">*</span>
                            </label>
                            {{ form.server_name(class="form-control", required=True) }}
                            <div class="invalid-feedback">Please provide a server name</div>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.hostname.id }}" class="form-label">
                                Hostname (FQDN)
                            </label>
                            {{ form.hostname(class="form-control") }}
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.whmcs_user_id.id }}" class="form-label">
                                WHMCS User ID
                            </label>
                            {{ form.whmcs_user_id(class="form-control") }}
                        </div>
                    </div>
                </div>
                
                <!-- Server Classification -->
                <div class="form-section">
                    <h3 class="form-section-title">Server Classification</h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.equipment_type.id }}" class="form-label">
                                Equipment Type <span class="required">*</span>
                            </label>
                            {{ form.equipment_type(class="form-control", required=True) }}
                            <div class="invalid-feedback">Please select an equipment type</div>
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.service_type.id }}" class="form-label">
                                Service Type <span class="required">*</span>
                            </label>
                            {{ form.service_type(class="form-control", required=True) }}
                            <div class="invalid-feedback">Please select a service type</div>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.manufacturer.id }}" class="form-label">
                                Manufacturer
                            </label>
                            {{ form.manufacturer(class="form-control") }}
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.model.id }}" class="form-label">
                                Model
                            </label>
                            {{ form.model(class="form-control") }}
                        </div>
                    </div>
                </div>
                
                <!-- Location -->
                <div class="form-section">
                    <h3 class="form-section-title">Location</h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.datacenter_id.id }}" class="form-label">
                                Data Center <span class="required">*</span>
                            </label>
                            {{ form.datacenter_id(class="form-control", onchange="loadRacks()", required=True) }}
                            <div class="invalid-feedback">Please select a data center</div>
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.rack_id.id }}" class="form-label">
                                Rack <span class="required">*</span>
                            </label>
                            {{ form.rack_id(class="form-control", onchange="loadPDUs(); checkRackSpace()", required=True) }}
                            <div class="invalid-feedback">Please select a rack</div>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.start_u.id }}" class="form-label">
                                Starting U Position <span class="required">*</span>
                            </label>
                            {{ form.start_u(class="form-control", onchange="checkRackSpace()", required=True) }}
                            <div id="rackSpaceInfo" style="margin-top: 5px;"></div>
                            <div class="invalid-feedback">Please enter a starting U position</div>
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.size_u.id }}" class="form-label">
                                Size (U) <span class="required">*</span>
                            </label>
                            {{ form.size_u(class="form-control", onchange="checkRackSpace()", required=True) }}
                            <div id="rackSpaceInfo2" style="margin-top: 5px;"></div>
                            <div class="invalid-feedback">Please enter the size in U</div>
                        </div>
                    </div>
                </div>
                
                <!-- Service Details -->
                <div class="form-section">
                    <h3 class="form-section-title">Service Details</h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.status.id }}" class="form-label">
                                Status
                            </label>
                            {{ form.status(class="form-control") }}
                        </div>
                        
                        <div class="form-group">
                            <div style="display: flex; flex-direction: column; gap: 10px;">
                                <div class="form-check">
                                    {{ form.is_infrastructure(class="form-check-input") }}
                                    <label class="form-check-label">Infrastructure Device</label>
                                </div>
                                <div class="form-check">
                                    {{ form.is_managed(class="form-check-input") }}
                                    <label class="form-check-label">Managed Device</label>
                                </div>
                                <div class="form-check">
                                    {{ form.is_available(class="form-check-input") }}
                                    <label class="form-check-label">Available for Use</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Customer Assignment (for Colocation) -->
                <div class="form-section" id="customerSection" style="display: none;">
                    <h3 class="form-section-title">Customer Assignment</h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.customer_id.id }}" class="form-label">
                                Customer <span class="required" id="customerRequired" style="display: none;">*</span>
                            </label>
                            {{ form.customer_id(class="form-control") }}
                            <small class="form-text">Required for colocation servers</small>
                            <div class="invalid-feedback">Please select a customer for this colocation server</div>
                        </div>
                    </div>
                </div>
                
                <!-- Notes -->
                <div class="form-section">
                    <h3 class="form-section-title">Notes</h3>
                    
                    <div class="form-group">
                        <label for="{{ form.notes.id }}" class="form-label">
                            Additional Notes
                        </label>
                        {{ form.notes(class="form-control", rows=4) }}
                    </div>
                </div>
            </div>
            
            <!-- ========== TAB 2: NETWORK ========== -->
            <div class="tab-pane fade" id="network" role="tabpanel" aria-labelledby="network-tab">
                
                <!-- IP Address Assignment -->
                <div class="form-section">
                    <h3 class="form-section-title">IP Address Assignment</h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.primary_public_ip.id }}" class="form-label">
                                Primary Public IP
                            </label>
                            {{ form.primary_public_ip(class="form-control", oninput="validateIP('primary_public_ip', 'publicIpWarning')", onblur="detectVLAN()") }}
                            <div id="publicIpWarning"></div>
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.primary_vlan_id.id }}" class="form-label">
                                Primary VLAN
                            </label>
                            {{ form.primary_vlan_id(class="form-control") }}
                            <small class="form-text">Auto-detected from IP if left blank</small>
                            <div id="vlanDetectionResult"></div>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">
                                Public IP Add-ons
                            </label>
                            <textarea id="publicAddons" class="form-control" rows="5" 
                                      placeholder="One IP per line:&#10;208.76.80.216&#10;208.76.80.217&#10;208.76.80.218"></textarea>
                            <small class="form-text">Enter additional public IPs (one per line)</small>
                        </div>
                        
                        <div class="form-group">
                            <label for="{{ form.primary_private_ip.id }}" class="form-label">
                                Primary Private IP
                            </label>
                            {{ form.primary_private_ip(class="form-control", onblur="checkIPAvailability('primary_private_ip')") }}
                            <div id="privateIpWarning"></div>
                            
                            <label class="form-label" style="margin-top: 15px;">
                                Private IP Add-ons
                            </label>
                            <textarea id="privateAddons" class="form-control" rows="3"
                                      placeholder="One IP per line:&#10;10.10.5.11&#10;10.10.5.12"></textarea>
                        </div>
                    </div>
                </div>
                
                <!-- Switch Connections -->
                <div class="form-section">
                    <h3 class="form-section-title">Switch Connections</h3>
                    
                    <div class="connection-table">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <span style="color: #94a3b8;">Configure network connections</span>
                            <button type="button" class="btn btn-add" onclick="addConnection()">
                                <i class="fas fa-plus"></i> Add Connection
                            </button>
                        </div>
                        
                        <!-- Connection headers -->
                        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr auto; gap: 10px; padding: 10px; color: #8b92a5; font-size: 0.9rem;">
                            <div>Switch</div>
                            <div>Port</div>
                            <div>Speed</div>
                            <div>Type</div>
                            <div></div>
                        </div>
                        
                        <!-- Connection rows will be added here -->
                        <div id="connectionList">
                            <!-- Default first connection -->
                            <div class="connection-row" data-index="0">
                                <select name="conn_switch_0" class="form-control" onchange="checkPortAvailability(0)">
                                    <option value="">-- Select Switch --</option>
                                </select>
                                <input type="number" name="conn_port_0" class="form-control" placeholder="Port #" min="1" max="52" onblur="checkPortAvailability(0)">
                                <select name="conn_speed_0" class="form-control">
                                    <option value="1G">1G</option>
                                    <option value="10G">10G</option>
                                    <option value="25G">25G</option>
                                    <option value="40G">40G</option>
                                    <option value="100G">100G</option>
                                </select>
                                <select name="conn_type_0" class="form-control">
                                    <option value="public">Public</option>
                                    <option value="private">Private</option>
                                    <option value="ipmi">IPMI</option>
                                </select>
                                <button type="button" class="btn-remove" onclick="removeConnection(0)" style="display: none;">Remove</button>
                                <div class="port-availability" id="port_status_0" style="grid-column: span 5; margin-top: 5px;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
        <!-- ========== TAB 3: MANAGEMENT ========== -->
        <div class="tab-pane fade" id="management" role="tabpanel" aria-labelledby="management-tab">
        
            <!-- IPMI Configuration -->
            <div class="form-section">
                <h3 class="form-section-title">IPMI Configuration</h3>
        
                <div class="alert alert-info"
                    style="display:block;background:rgba(96,165,250,0.1);border:1px solid rgba(96,165,250,0.3);color:#60a5fa;">
                    <i class="fas fa-info-circle"></i>
                    Leave IPMI fields empty if server does not have remote management
                </div>
        
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.ipmi_ip.id }}" class="form-label">IPMI IP Address</label>
                        {{ form.ipmi_ip(
                        class="form-control",
                        placeholder="10.10.100.50",
                        oninput="validateIP('ipmi_ip','ipmiIpWarning'); debounce(()=>checkIPAvailability('ipmi_ip','ipmiIpWarning'),400)()",
                        onblur="checkIPAvailability('{{ form.ipmi_ip.id }}','ipmiIpWarning')"
                        ) }}
                        <div id="ipmiIpWarning"></div>
                        <small class="form-text">Management network IP address</small>
                    </div>
        
                    <div class="form-group">
                        <label for="{{ form.ipmi_type.id }}" class="form-label">IPMI Type</label>
                        {{ form.ipmi_type(class="form-control") }}
                    </div>
                </div>
        
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.ipmi_username.id }}" class="form-label">IPMI Username</label>
                        {{ form.ipmi_username(class="form-control", placeholder="root or ADMIN") }}
                    </div>
        
                    <div class="form-group">
                        <label for="{{ form.ipmi_password.id }}" class="form-label">IPMI Password</label>
                        {{ form.ipmi_password(class="form-control", type="password") }}
                        <small class="form-text">Will be encrypted</small>
                    </div>
                </div>
        
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.ipmi_mac_address.id }}" class="form-label">IPMI MAC Address</label>
                        {{ form.ipmi_mac_address(class="form-control", placeholder="XX:XX:XX:XX:XX:XX") }}
                    </div>
        
                    <div class="form-group">
                        <label for="{{ form.ipmi_web_port.id }}" class="form-label">IPMI Web Port</label>
                        {{ form.ipmi_web_port(class="form-control", placeholder="443") }}
                    </div>
                </div>
        
                <div class="form-group">
                    <label for="{{ form.ipmi_notes.id }}" class="form-label">IPMI Notes</label>
                    {{ form.ipmi_notes(class="form-control", rows=2, placeholder="Special configuration notes, console redirection settings, etc.") }}
                </div>
            </div> <!-- /form-section: IPMI -->
        
            <!-- Power Configuration -->
            <div class="form-section">
                <h3 class="form-section-title">Power Configuration</h3>
        
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.pdu_1_id.id }}" class="form-label">Primary PDU</label>
                        {{ form.pdu_1_id(class="form-control") }}
                    </div>
                    <div class="form-group">
                        <label for="{{ form.pdu_1_outlet.id }}" class="form-label">Primary PDU Outlet</label>
                        {{ form.pdu_1_outlet(class="form-control") }}
                    </div>
                </div>
        
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.pdu_2_id.id }}" class="form-label">Redundant PDU</label>
                        {{ form.pdu_2_id(class="form-control") }}
                    </div>
                    <div class="form-group">
                        <label for="{{ form.pdu_2_outlet.id }}" class="form-label">Redundant PDU Outlet</label>
                        {{ form.pdu_2_outlet(class="form-control") }}
                    </div>
                </div>
        
                <div class="form-row">
                    <div class="form-group">
                        <label for="{{ form.power_draw_watts.id }}" class="form-label">Power Draw (Watts)</label>
                        {{ form.power_draw_watts(class="form-control") }}
                    </div>
                    <div class="form-group">
                        <label for="{{ form.power_supply_config.id }}" class="form-label">Power Supply Config</label>
                        {{ form.power_supply_config(class="form-control") }}
                    </div>
                </div>
            </div> <!-- /form-section: Power -->
        </div> <!-- /tab-pane -->

            
            <!-- ========== TAB 4: HARDWARE (Disabled) ========== -->
            <div class="tab-pane fade" id="hardware" role="tabpanel" aria-labelledby="hardware-tab">
                <div style="text-align: center; padding: 50px;">
                    <i class="fas fa-microchip" style="font-size: 3rem; color: #475569; margin-bottom: 20px;"></i>
                    <h3 style="color: #94a3b8;">Hardware Configuration</h3>
                    <p style="color: #64748b;">This feature will be available in Phase 2</p>
                </div>
            </div>
            
            <!-- ========== TAB 5: SOFTWARE (Disabled) ========== -->
            <div class="tab-pane fade" id="software" role="tabpanel" aria-labelledby="software-tab">
                <div style="text-align: center; padding: 50px;">
                    <i class="fas fa-code" style="font-size: 3rem; color: #475569; margin-bottom: 20px;"></i>
                    <h3 style="color: #94a3b8;">Software Configuration</h3>
                    <p style="color: #64748b;">This feature will be available in Phase 2</p>
                </div>
            </div>
        </div>
        
        <!-- Form Actions -->
        <div style="display: flex; justify-content: space-between; margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
            <a href="{{ url_for('servers.index') }}" class="btn btn-secondary">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Create Server
            </button>
        </div>
    </form>
</div>
{% endblock %}

{% block extra_js %}
<!-- Bootstrap Tab Dependencies -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
// FIXED: Connection counter for unique naming - moved to proper scope
let connectionIndex = 1;

// NEW: Small debounce helper for nicer UX on textarea validation
function debounce(fn, wait=400) {
  let t;
  return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), wait); };
}

// CHANGED v2.0.2: Enhanced validation with immediate feedback
// Validate Server ID format and check for colocation
function validateServerID() {
    const input = document.getElementById('{{ form.server_id_input.id }}');
    const value = input.value.toUpperCase();
    const feedback = document.getElementById('serverIdFeedback');
    const coloAlert = document.getElementById('coloAlert');
    const customerSection = document.getElementById('customerSection');
    const customerRequired = document.getElementById('customerRequired');
    const publicIpWarning = document.getElementById('publicIpWarning');
    
    if (!value) {
        feedback.innerHTML = '<div class="invalid-feedback">Server ID is required</div>';
        input.classList.add('is-invalid');
        coloAlert.classList.remove('show');
        return false;
    }
    
    // Check if colocation
    if (value.startsWith('COLO')) {
        // Show colocation alert and customer section
        coloAlert.classList.add('show');
        customerSection.style.display = 'block';
        customerRequired.style.display = 'inline';
        
        // Validate colocation format
        if (/^COLO(TCH)?\d+$/.test(value)) {
            feedback.innerHTML = '<div class="valid-feedback">✓ Valid colocation server ID</div>';
            input.classList.remove('is-invalid');
            
            // Add warning for IP
            if (publicIpWarning) {
                publicIpWarning.innerHTML = '<div style="color: #f59e0b; margin-top: 5px;">⚠️ Colocation servers must use 66.x IP space</div>';
            }
            return true;
        } else {
            feedback.innerHTML = '<div class="invalid-feedback">Format must be: ColoTCH##### or Colo#####</div>';
            input.classList.add('is-invalid');
            return false;
        }
    } else {
        // Hide colocation stuff
        coloAlert.classList.remove('show');
        customerSection.style.display = 'none';
        customerRequired.style.display = 'none';
        if (publicIpWarning) publicIpWarning.innerHTML = '';
        
        // Validate dedicated format
        if (/^[A-Z]{3}-[A-Z]{3}-[A-Z]\d+$/.test(value)) {
            feedback.innerHTML = '<div class="valid-feedback">✓ Valid server ID format</div>';
            input.classList.remove('is-invalid');
            return true;
        } else {
            feedback.innerHTML = '<div class="invalid-feedback">Format must be: DC-LOC-Type#### (e.g., TCH-LAX-D6611)</div>';
            input.classList.add('is-invalid');
            return false;
        }
    }
}

// CHANGED v2.0.2: Fixed to load racks immediately on datacenter change
// Load racks when datacenter changes
function loadRacks() {
    const dcSelect = document.getElementById('{{ form.datacenter_id.id }}');
    const rackSelect = document.getElementById('{{ form.rack_id.id }}');
    
    if (!dcSelect.value || dcSelect.value === '0') {
        rackSelect.innerHTML = '<option value="0">-- Select Data Center First --</option>';
        return;
    }
    
    fetch(`/servers/api/racks/${dcSelect.value}`)
        .then(response => response.json())
        .then(racks => {
            rackSelect.innerHTML = '<option value="0">-- Select Rack --</option>';
            racks.forEach(rack => {
                const option = new Option(rack.rack_id, rack.id);
                rackSelect.add(option);
            });
        })
        .catch(err => {
            console.error('Error loading racks:', err);
            rackSelect.innerHTML = '<option value="0">-- Error loading racks --</option>';
        });
}

// Load PDUs when rack changes
function loadPDUs() {
    const rackSelect = document.getElementById('{{ form.rack_id.id }}');
    const pdu1Select = document.getElementById('{{ form.pdu_1_id.id }}');
    const pdu2Select = document.getElementById('{{ form.pdu_2_id.id }}');
    
    if (!rackSelect.value || rackSelect.value === '0') {
        pdu1Select.innerHTML = '<option value="0">-- Select Rack First --</option>';
        pdu2Select.innerHTML = '<option value="0">-- Select Rack First --</option>';
        return;
    }
    
    fetch(`/servers/api/rack/${rackSelect.value}/pdus`)
        .then(response => response.json())
        .then(pdus => {
            const options = '<option value="0">-- No PDU --</option>' +
                pdus.map(pdu => `<option value="${pdu.id}">PDU ${pdu.identifier} (${pdu.available_outlets} outlets available)</option>`).join('');
            pdu1Select.innerHTML = options;
            pdu2Select.innerHTML = options;
        })
        .catch(err => {
            console.error('Error loading PDUs:', err);
            pdu1Select.innerHTML = '<option value="0">-- No PDU --</option>';
            pdu2Select.innerHTML = '<option value="0">-- No PDU --</option>';
        });
}

// Check rack space availability
function checkRackSpace() {
    const rackId = document.getElementById('{{ form.rack_id.id }}').value;
    const startU = document.getElementById('{{ form.start_u.id }}').value;
    const sizeU = document.getElementById('{{ form.size_u.id }}').value;
    const info = document.getElementById('rackSpaceInfo');
    
    if (!rackId || rackId === '0' || !startU || !sizeU) {
        info.innerHTML = '';
        return;
    }
    
    fetch(`/servers/api/rack/${rackId}/availability`)
        .then(response => response.json())
        .then(data => {
            const endU = parseInt(startU) + parseInt(sizeU) - 1;
            
            // Check if space is available
            let available = true;
            for (let u = startU; u <= endU; u++) {
                if (data.usage[u]) {
                    available = false;
                    // FIXED: Use the correct field names from the API response
                    const conflict = data.usage[u];
                    const deviceInfo = conflict.details || `${conflict.type}: ${conflict.device_id}`;
                    info.innerHTML = `<span style="color: #ef4444;">❌ Conflict with ${deviceInfo} at U${u}</span>`;
                    break;
                }
            }
            
            if (available) {
                info.innerHTML = `<span style="color: #10b981;">✓ Space available (U${startU}-U${endU})</span>`;
            }
        })
        .catch(err => {
            console.error('Error checking rack space:', err);
            info.innerHTML = '';
        });
}

// CHANGED v2.0.2: Implemented VLAN auto-detection
// CHANGED v2.0.7: Added IP availability check
// Auto-detect VLAN from IP
function detectVLAN() {
    const ipInput = document.getElementById('{{ form.primary_public_ip.id }}');
    const vlanSelect = document.getElementById('{{ form.primary_vlan_id.id }}');
    const vlanResult = document.getElementById('vlanDetectionResult');
    const ip = ipInput.value;
    
    if (!ip) {
        vlanResult.innerHTML = '';
        return;
    }
    
    // Check IP availability first
    checkIPAvailability('{{ form.primary_public_ip.id }}');
    
    // Check if colocation server with non-66.x IP
    const serverId = document.getElementById('{{ form.server_id_input.id }}').value.toUpperCase();
    if (serverId.startsWith('COLO') && !ip.startsWith('66.')) {
        // Warning already shown by checkIPAvailability
    }
    
    // Auto-detect VLAN from IP
    fetch(`/servers/api/detect-vlan?ip=${encodeURIComponent(ip)}`)
        .then(response => response.json())
        .then(data => {
            if (data.vlan_id) {
                vlanSelect.value = data.vlan_id;
                vlanResult.innerHTML = `<div style="color: #10b981;">✓ Auto-detected VLAN ${data.vlan_name}</div>`;
            }
        })
        .catch(err => {
            console.error('Error detecting VLAN:', err);
            vlanResult.innerHTML = '';
        });
}

// CHANGED v2.0.7: Added IP availability checking
// Check if IP address is available
function checkIPAvailability(fieldId) {
    const ipInput = document.getElementById(fieldId);
    const ip = ipInput.value.trim();
    
    // Determine which warning div to use based on field
    let warningDivId;
    if (fieldId === '{{ form.primary_public_ip.id }}') {
        warningDivId = 'publicIpWarning';
    } else if (fieldId === '{{ form.primary_private_ip.id }}') {
        warningDivId = 'privateIpWarning';
    } else if (fieldId === '{{ form.ipmi_ip.id }}') {
        warningDivId = 'ipmiIpWarning';
    } else {
        return;
    }
    
    const warningDiv = document.getElementById(warningDivId);
    
    // Clear if empty
    if (!ip) {
        warningDiv.innerHTML = '';
        ipInput.classList.remove('is-invalid');
        return;
    }
    
    // Call API to check availability
    fetch(`/servers/api/ip/check-availability?ip=${encodeURIComponent(ip)}`)
        .then(response => response.json())
        .then(data => {
            if (data.available) {
                warningDiv.innerHTML = `<span style="color: #10b981;">✓ IP ${ip} is available</span>`;
                ipInput.classList.remove('is-invalid');
            } else {
                warningDiv.innerHTML = `<span style="color: #ef4444;">❌ IP ${ip} is already assigned to ${data.assigned_to || data.device_info}</span>`;
                ipInput.classList.add('is-invalid');
            }
        })
        .catch(err => {
            console.error('Error checking IP availability:', err);
            warningDiv.innerHTML = `<span style="color: #f59e0b;">⚠ Unable to verify IP availability</span>`;
        });
}

function validateIP(fieldId, feedbackDivId) {
    const ipInput = document.getElementById(fieldId);
    const ip = ipInput.value.trim();
    const feedbackDiv = document.getElementById(feedbackDivId);
    
    if (!ip) {
        // Clear feedback if field is empty
        feedbackDiv.innerHTML = '';
        ipInput.classList.remove('is-invalid');
        return true; // Empty is valid (field is optional)
    }
    
    // IPv4 validation regex pattern (same as used in routes/servers.py)
    const ipPattern = /^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;
    
    if (!ipPattern.test(ip)) {
        feedbackDiv.innerHTML = '<div style="color: #ef4444;">❌ Invalid IP address format</div>';
        ipInput.classList.add('is-invalid');
        return false;
    } else {
        feedbackDiv.innerHTML = '<div style="color: #10b981;">✓ Valid IP format</div>';
        ipInput.classList.remove('is-invalid');
        
        // Check colocation IP requirement if this is primary public IP
        if (fieldId === '{{ form.primary_public_ip.id }}') {
            const serverId = document.getElementById('{{ form.server_id_input.id }}').value.toUpperCase();
            if (serverId.startsWith('COLO') && !ip.startsWith('66.')) {
                feedbackDiv.innerHTML = '<div style="color: #f59e0b;">⚠️ Colocation servers must use 66.x IP space</div>';
                ipInput.classList.add('is-invalid');
                return false;
            }
        }
        
        return true;
    }
}

// REPLACED: Validate add-on IPs in textareas (wired + hardened)
function validateAddOnIPs(textareaId) {
    const textarea = document.getElementById(textareaId);
    if (!textarea) return;

    const rawLines = textarea.value.split('\n');
    const ipPattern = /^(?:(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\.){3}(?:25[0-5]|2[0-4]\d|[01]?\d\d?)$/;

    // normalize: trim, drop empties
    const lines = rawLines.map(l => l.trim()).filter(Boolean);

    // prepare / ensure feedback node
    let feedbackDiv = document.getElementById(`${textareaId}Feedback`);
    if (!feedbackDiv) {
        feedbackDiv = document.createElement('div');
        feedbackDiv.id = `${textareaId}Feedback`;
        feedbackDiv.style.marginTop = '5px';
        textarea.parentElement.appendChild(feedbackDiv);
    }

    if (lines.length === 0) {
        feedbackDiv.innerHTML = '';
        textarea.classList.remove('is-invalid');
        return;
    }

    // quick local checks (format + duplicates) before hitting API
    const seen = new Set();
    const localErrors = [];
    const toCheck = [];

    for (const ip of lines) {
        if (!ipPattern.test(ip)) {
            localErrors.push(`${ip} — invalid IP format`);
            continue;
        }
        if (seen.has(ip)) {
            localErrors.push(`${ip} — duplicate in list`);
            continue;
        }
        seen.add(ip);
        toCheck.push(ip);
    }

    if (localErrors.length > 0) {
        feedbackDiv.innerHTML = `<div style="color:#ef4444;">❌ Issues found:<br>${localErrors.join('<br>')}</div>`;
        textarea.classList.add('is-invalid');
        // continue to check valid ones
    }

    if (toCheck.length === 0) {
        // nothing valid to verify remotely
        return;
    }

    // remote availability checks
    let done = 0;
    const conflicts = [];

    toCheck.forEach(ip => {
        fetch(`/servers/api/ip/check-availability?ip=${encodeURIComponent(ip)}`)
          .then(r => r.json())
          .then(data => {
              if (!data.available) {
                  conflicts.push(`${ip} — already assigned to ${data.device_info || data.assigned_to || 'another device'}`);
              }
          })
          .catch(() => {
              // count failures as warnings but still let the batch finish
              conflicts.push(`${ip} — unable to verify (network/API error)`);
          })
          .finally(() => {
              done++;
              if (done === toCheck.length) {
                  if (conflicts.length > 0 || localErrors.length > 0) {
                      const all = [...localErrors, ...conflicts];
                      feedbackDiv.innerHTML = `<div style="color:#ef4444;">❌ Issues found:<br>${all.join('<br>')}</div>`;
                      textarea.classList.add('is-invalid');
                  } else {
                      feedbackDiv.innerHTML = `<div style="color:#10b981;">✓ All ${toCheck.length} IPs are available</div>`;
                      textarea.classList.remove('is-invalid');
                  }
              }
          });
    });
}

// Add network connection row
function addConnection() {
    const connectionList = document.getElementById('connectionList');
    
    const newRow = document.createElement('div');
    newRow.className = 'connection-row';
    newRow.dataset.index = connectionIndex;
    
    newRow.innerHTML = `
        <select name="conn_switch_${connectionIndex}" class="form-control" onchange="checkPortAvailability(${connectionIndex})">
            <option value="">-- Select Switch --</option>
        </select>
        <input type="number" name="conn_port_${connectionIndex}" class="form-control" placeholder="Port #" min="1" max="52" onblur="checkPortAvailability(${connectionIndex})">
        <select name="conn_speed_${connectionIndex}" class="form-control">
            <option value="1G">1G</option>
            <option value="10G">10G</option>
            <option value="25G">25G</option>
            <option value="40G">40G</option>
            <option value="100G">100G</option>
        </select>
        <select name="conn_type_${connectionIndex}" class="form-control">
            <option value="public">Public</option>
            <option value="private">Private</option>
            <option value="ipmi">IPMI</option>
        </select>
        <button type="button" class="btn-remove" onclick="removeConnection(${connectionIndex})">Remove</button>
        <div class="port-availability" id="port_status_${connectionIndex}" style="grid-column: span 5; margin-top: 5px;"></div>
    `;
    
    connectionList.appendChild(newRow);
    loadSwitches(connectionIndex);
    connectionIndex++;
    
    // Show remove button on first row if we have multiple
    if (connectionList.children.length > 1) {
        connectionList.children[0].querySelector('.btn-remove').style.display = 'block';
    }
}

// Check if switch port is available
function checkPortAvailability(index) {
    const switchSelect = document.querySelector(`select[name="conn_switch_${index}"]`);
    const portInput = document.querySelector(`input[name="conn_port_${index}"]`);
    const statusDiv = document.getElementById(`port_status_${index}`);
    
    // Clear previous status
    if (statusDiv) {
        statusDiv.innerHTML = '';
    }
    
    // Check if both switch and port are selected
    if (!switchSelect || !portInput || !switchSelect.value || !portInput.value) {
        return;
    }
    
    const switchId = switchSelect.value;
    const portNumber = portInput.value;
    
    // Call API to check port availability
    fetch(`/servers/api/switch/${switchId}/port/${portNumber}/availability`)
        .then(response => response.json())
        .then(data => {
            if (!statusDiv) {
                // Create status div if it doesn't exist (for the first row)
                const row = document.querySelector(`[data-index="${index}"]`);
                if (row) {
                    const newStatusDiv = document.createElement('div');
                    newStatusDiv.className = 'port-availability';
                    newStatusDiv.id = `port_status_${index}`;
                    newStatusDiv.style.cssText = 'grid-column: span 5; margin-top: 5px;';
                    row.appendChild(newStatusDiv);
                }
            }
            
            const updateStatusDiv = document.getElementById(`port_status_${index}`);
            if (updateStatusDiv) {
                if (data.available) {
                    updateStatusDiv.innerHTML = `<span style="color: #10b981;">✓ Port ${portNumber} is available</span>`;
                    portInput.classList.remove('is-invalid');
                } else {
                    updateStatusDiv.innerHTML = `<span style="color: #ef4444;">❌ Port ${portNumber} is in use by ${data.device_info || data.used_by}</span>`;
                    portInput.classList.add('is-invalid');
                }
            }
        })
        .catch(err => {
            console.error('Error checking port availability:', err);
            if (statusDiv) {
                statusDiv.innerHTML = `<span style="color: #f59e0b;">⚠ Unable to verify port availability</span>`;
            }
        });
}

// Remove network connection row
function removeConnection(index) {
    const row = document.querySelector(`[data-index="${index}"]`);
    if (row) {
        row.remove();
    }
    
    // Hide remove button on first row if only one left
    const connectionList = document.getElementById('connectionList');
    if (connectionList.children.length === 1) {
        connectionList.children[0].querySelector('.btn-remove').style.display = 'none';
    }
}

// CHANGED v2.0.2: Fixed to properly populate switches on page load
// Load switches for connection dropdown
function loadSwitches(index = 0) {
    const switchSelect = document.querySelector(`select[name="conn_switch_${index}"]`);
    if (!switchSelect) return;
    
    fetch('/servers/api/switches')
        .then(response => response.json())
        .then(switches => {
            switchSelect.innerHTML = '<option value="">-- Select Switch --</option>';
            switches.forEach(sw => {
                const option = new Option(
                    `${sw.identifier} - ${sw.hostname} (${sw.network_type})`, 
                    sw.id
                );
                switchSelect.add(option);
            });
        })
        .catch(err => {
            console.error('Error loading switches:', err);
            switchSelect.innerHTML = '<option value="">-- Error loading switches --</option>';
        });
}

// CHANGED v2.0.5: Fixed form validation to check actual values
// CHANGED v2.0.6: Fixed to properly check for element existence
// Validate entire form before submission
function validateForm() {
    let isValid = true;
    let errors = [];
    
    // Clear previous error states
    document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
    
    // Validate Server ID
    const serverId = document.getElementById('{{ form.server_id_input.id }}');
    if (serverId && (!serverId.value || serverId.value.trim() === '')) {
        errors.push('Server ID is required');
        serverId.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate Server Name
    const serverName = document.getElementById('{{ form.server_name.id }}');
    if (serverName && (!serverName.value || serverName.value.trim() === '')) {
        errors.push('Server Name is required');
        serverName.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate Equipment Type - check for empty or default option
    const equipType = document.getElementById('{{ form.equipment_type.id }}');
    if (equipType && (!equipType.value || equipType.value === '' || equipType.value === '-- Select --')) {
        errors.push('Equipment Type is required');
        equipType.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate Service Type - check for empty or default option
    const serviceType = document.getElementById('{{ form.service_type.id }}');
    if (serviceType && (!serviceType.value || serviceType.value === '' || serviceType.value === '-- Select --')) {
        errors.push('Service Type is required');
        serviceType.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate Data Center - check for 0 or empty
    const datacenter = document.getElementById('{{ form.datacenter_id.id }}');
    if (datacenter && (!datacenter.value || datacenter.value === '0' || datacenter.value === '')) {
        errors.push('Data Center is required');
        datacenter.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate Rack - check for 0 or empty
    const rack = document.getElementById('{{ form.rack_id.id }}');
    if (rack && (!rack.value || rack.value === '0' || rack.value === '')) {
        errors.push('Rack is required');
        rack.classList.add('is-invalid'); // FIXED: Removed duplicate line
        isValid = false;
    }
    
    // Validate U Position - must be a number
    const startU = document.getElementById('{{ form.start_u.id }}');
    if (startU && (!startU.value || startU.value === '' || isNaN(startU.value) || parseInt(startU.value) < 1)) {
        errors.push('Starting U Position is required (must be 1 or higher)');
        startU.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate Size - must be a number
    const sizeU = document.getElementById('{{ form.size_u.id }}');
    if (sizeU && (!sizeU.value || sizeU.value === '' || isNaN(sizeU.value) || parseInt(sizeU.value) < 1)) {
        errors.push('Size (U) is required (must be 1 or higher)');
        sizeU.classList.add('is-invalid');
        isValid = false;
    }
    
    // Validate colocation customer
    if (serverId) {
        const serverIdValue = serverId.value.toUpperCase();
        if (serverIdValue.startsWith('COLO')) {
            const customerId = document.getElementById('{{ form.customer_id.id }}');
            if (customerId && (!customerId.value || customerId.value === '0')) {
                errors.push('Customer is required for colocation servers');
                customerId.classList.add('is-invalid');
                isValid = false;
            }
        }
    }
    
    // Debug: Log form values to console
    console.log('Form Validation Debug:');
    console.log('Server ID:', serverId ? serverId.value : 'Element not found');
    console.log('Server Name:', serverName ? serverName.value : 'Element not found');
    console.log('Equipment Type:', equipType ? equipType.value : 'Element not found');
    console.log('Service Type:', serviceType ? serviceType.value : 'Element not found');
    console.log('Data Center:', datacenter ? datacenter.value : 'Element not found');
    console.log('Rack:', rack ? rack.value : 'Element not found');
    console.log('Start U:', startU ? startU.value : 'Element not found');
    console.log('Size U:', sizeU ? sizeU.value : 'Element not found');
    console.log('Validation result:', isValid);
    
    // Show errors if any
    if (!isValid) {
        // Create or update error display
        let errorDiv = document.querySelector('.form-errors');
        if (!errorDiv) {
            errorDiv = document.createElement('div');
            errorDiv.className = 'form-errors';
            document.getElementById('serverForm').insertBefore(errorDiv, document.getElementById('serverForm').firstChild);
        }
        
        errorDiv.innerHTML = '<strong>Please correct the following errors:</strong><ul>' + 
            errors.map(e => `<li>${e}</li>`).join('') + '</ul>';
        
        // Scroll to top to show errors
        window.scrollTo({ top: 0, behavior: 'smooth' });
        
        return false;
    }
    
    return true;
}

// Check PDU outlet availability
function checkPDUOutlet(pduFieldId, outletFieldId, resultDivId) {
    const pduSelect = document.getElementById(pduFieldId);
    const outletInput = document.getElementById(outletFieldId);
    
    if (!pduSelect || !outletInput) return;
    
    const pduId = pduSelect.value;
    const outlet = outletInput.value;
    
    // Clear previous result
    let resultDiv = document.getElementById(resultDivId);
    if (!resultDiv) {
        // Create result div if it doesn't exist
        resultDiv = document.createElement('div');
        resultDiv.id = resultDivId;
        resultDiv.style.marginTop = '5px';
        outletInput.parentElement.appendChild(resultDiv);
    }
    
    if (!pduId || pduId === '0' || !outlet) {
        resultDiv.innerHTML = '';
        outletInput.classList.remove('is-invalid');
        return;
    }
    
    // Check outlet availability
    fetch(`/servers/api/pdu/${pduId}/outlet/${outlet}/availability`)
        .then(response => response.json())
        .then(data => {
            if (data.error) {
                resultDiv.innerHTML = `<span style="color: #f59e0b;">⚠ ${data.error}</span>`;
                outletInput.classList.add('is-invalid');
            } else if (data.available) {
                resultDiv.innerHTML = `<span style="color: #10b981;">✓ Outlet ${outlet} is available</span>`;
                outletInput.classList.remove('is-invalid');
            } else {
                resultDiv.innerHTML = `<span style="color: #ef4444;">❌ Outlet ${outlet} is in use by ${data.device_info}</span>`;
                outletInput.classList.add('is-invalid');
            }
        })
        .catch(err => {
            console.error('Error checking PDU outlet:', err);
            resultDiv.innerHTML = `<span style="color: #f59e0b;">⚠ Unable to verify outlet availability</span>`;
        });
}

// Validate PDU redundancy
function validatePDURedundancy() {
    const pdu1 = document.getElementById('{{ form.pdu_1_id.id }}');
    const outlet1 = document.getElementById('{{ form.pdu_1_outlet.id }}');
    const pdu2 = document.getElementById('{{ form.pdu_2_id.id }}');
    const outlet2 = document.getElementById('{{ form.pdu_2_outlet.id }}');
    
    if (!pdu1 || !pdu2) return;
    
    // Clear previous warnings
    let warningDiv = document.getElementById('pduRedundancyWarning');
    if (!warningDiv) {
        warningDiv = document.createElement('div');
        warningDiv.id = 'pduRedundancyWarning';
        warningDiv.className = 'alert alert-warning';
        warningDiv.style.marginTop = '15px';
        warningDiv.style.display = 'none';
        // Insert after the PDU section
        const powerSection = pdu2.closest('.form-section');
        if (powerSection) {
            powerSection.appendChild(warningDiv);
        }
    }
    
    if (pdu1.value && pdu2.value && pdu1.value === pdu2.value) {
        // Same PDU for primary and redundant
        if (outlet1.value && outlet2.value && outlet1.value === outlet2.value) {
            warningDiv.innerHTML = '<i class="fas fa-exclamation-triangle"></i> <strong>Error:</strong> Cannot use the same outlet for primary and redundant power!';
            warningDiv.style.display = 'block';
            warningDiv.className = 'alert alert-danger';
            outlet2.classList.add('is-invalid');
        } else {
            warningDiv.innerHTML = '<i class="fas fa-exclamation-triangle"></i> <strong>Warning:</strong> Primary and redundant power are on the same PDU - no true redundancy!';
            warningDiv.style.display = 'block';
            warningDiv.className = 'alert alert-warning';
            outlet2.classList.remove('is-invalid');
        }
    } else {
        warningDiv.style.display = 'none';
        outlet2.classList.remove('is-invalid');
    }
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    // Load initial switches for first connection
    loadSwitches(0);
    
    // Check if editing and server is colocation
    validateServerID();
    
    // Initialize Bootstrap tabs
    // Enable tab navigation with fallback for non-Bootstrap environments
    const tabLinks = document.querySelectorAll('#serverTabs .nav-link');
    const tabPanes = document.querySelectorAll('.tab-pane');
    
    tabLinks.forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            
            // Skip if disabled
            if (this.classList.contains('disabled')) {
                return;
            }
            
            // Remove active from all tabs and panes
            tabLinks.forEach(l => l.classList.remove('active'));
            tabPanes.forEach(p => {
                p.classList.remove('show', 'active');
            });
            
            // Add active to clicked tab
            this.classList.add('active');
            
            // Show corresponding pane
            const targetId = this.getAttribute('href').substring(1);
            const targetPane = document.getElementById(targetId);
            if (targetPane) {
                targetPane.classList.add('show', 'active');
            }
        });
    });

    // NEW: Wire up add-on IP text areas to validation (input + blur)
    const publicTA  = document.getElementById('publicAddons');
    const privateTA = document.getElementById('privateAddons');

    if (publicTA) {
      publicTA.addEventListener('input', debounce(() => validateAddOnIPs('publicAddons')));
      publicTA.addEventListener('blur',  () => validateAddOnIPs('publicAddons'));
    }
    if (privateTA) {
      privateTA.addEventListener('input', debounce(() => validateAddOnIPs('privateAddons')));
      privateTA.addEventListener('blur',  () => validateAddOnIPs('privateAddons'));
    }
    
    // Add PDU validation event listeners
    const pdu1Select = document.getElementById('{{ form.pdu_1_id.id }}');
    const pdu1Outlet = document.getElementById('{{ form.pdu_1_outlet.id }}');
    const pdu2Select = document.getElementById('{{ form.pdu_2_id.id }}');
    const pdu2Outlet = document.getElementById('{{ form.pdu_2_outlet.id }}');
    
    if (pdu1Select) {
        pdu1Select.addEventListener('change', function() {
            checkPDUOutlet('{{ form.pdu_1_id.id }}', '{{ form.pdu_1_outlet.id }}', 'pdu1OutletStatus');
            validatePDURedundancy();
        });
    }
    
    if (pdu1Outlet) {
        pdu1Outlet.addEventListener('blur', function() {
            checkPDUOutlet('{{ form.pdu_1_id.id }}', '{{ form.pdu_1_outlet.id }}', 'pdu1OutletStatus');
            validatePDURedundancy();
        });
    }
    
    if (pdu2Select) {
        pdu2Select.addEventListener('change', function() {
            checkPDUOutlet('{{ form.pdu_2_id.id }}', '{{ form.pdu_2_outlet.id }}', 'pdu2OutletStatus');
            validatePDURedundancy();
        });
    }
    
    if (pdu2Outlet) {
        pdu2Outlet.addEventListener('blur', function() {
            checkPDUOutlet('{{ form.pdu_2_id.id }}', '{{ form.pdu_2_outlet.id }}', 'pdu2OutletStatus');
            validatePDURedundancy();
        });
    }
});

// Form submission handler to include dynamic connections
document.getElementById('serverForm').addEventListener('submit', function(e) {
    // Validate form first
    if (!validateForm()) {
        e.preventDefault();
        return false;
    }

    // NEW: run add-on validations and block submit if invalid
    validateAddOnIPs('publicAddons');
    validateAddOnIPs('privateAddons');

    const publicTA  = document.getElementById('publicAddons');
    const privateTA = document.getElementById('privateAddons');

    if ((publicTA && publicTA.classList.contains('is-invalid')) ||
        (privateTA && privateTA.classList.contains('is-invalid'))) {
        e.preventDefault();
        (publicTA?.classList.contains('is-invalid') ? publicTA : privateTA)
          .scrollIntoView({behavior:'smooth', block:'center'});
        return false;
    }
    
    // If validation passed, prepare dynamic data
    
    // Collect network connections
    const connections = [];
    document.querySelectorAll('.connection-row').forEach(row => {
        const index = row.dataset.index;
        const switchId = document.querySelector(`select[name="conn_switch_${index}"]`).value;
        const port = document.querySelector(`input[name="conn_port_${index}"]`).value;
        const speed = document.querySelector(`select[name="conn_speed_${index}"]`).value;
        const type = document.querySelector(`select[name="conn_type_${index}"]`).value;
        
        if (switchId && port) {
            connections.push({ switchId, port, speed, type });
        }
    });
    
    // Add connections as hidden field
    if (connections.length > 0) {
        const connectionsInput = document.createElement('input');
        connectionsInput.type = 'hidden';
        connectionsInput.name = 'network_connections';
        connectionsInput.value = JSON.stringify(connections);
        this.appendChild(connectionsInput);
    }
    
    // Collect add-on IPs
    const publicAddons = document.getElementById('publicAddons').value.trim();
    const privateAddons = document.getElementById('privateAddons').value.trim();
    
    if (publicAddons) {
        const publicInput = document.createElement('input');
        publicInput.type = 'hidden';
        publicInput.name = 'public_addon_ips';
        publicInput.value = publicAddons;
        this.appendChild(publicInput);
    }
    
    if (privateAddons) {
        const privateInput = document.createElement('input');
        privateInput.type = 'hidden';
        privateInput.name = 'private_addon_ips';
        privateInput.value = privateAddons;
        this.appendChild(privateInput);
    }
    
    // Form will submit naturally if validation passed
});

// Remove invalid class on input
document.querySelectorAll('.form-control').forEach(input => {
    input.addEventListener('input', function() {
        this.classList.remove('is-invalid');
    });
});
</script>
{% endblock %}