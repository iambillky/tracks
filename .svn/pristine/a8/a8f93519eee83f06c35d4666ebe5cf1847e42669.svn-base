"""
File: forms/datacenter_forms.py (PDUForm section)
Purpose: Updated PDU form with IPAM-aware IP address validation
Version: 1.3.0
Author: DCMS Team

Revision History:
- v1.1.0: Added model field for tracking APC model numbers
- v1.2.0: Added switch connectivity fields for network management
- v1.3.0: CHANGED: Integrated IPAM validation for IP addresses
         Added custom validator to check IP availability in IPAM
         Added VLAN field for management network tracking

This is the complete datacenter_forms.py file with PDUForm updated for IPAM
"""

from flask_wtf import FlaskForm
from wtforms import StringField, IntegerField, FloatField, TextAreaField, SelectField
from wtforms.validators import DataRequired, Length, Email, Optional, NumberRange, Regexp, ValidationError, IPAddress

# ========== CUSTOM VALIDATORS FOR IPAM ==========

def validate_ip_available_or_assigned_to_pdu(form, field):
    """
    CHANGED v1.3.0: Custom validator for PDU IP addresses
    Checks if IP is available in IPAM or already assigned to this PDU
    """
    if field.data:
        from models.ipam import IPAddress as IPAddressModel
        
        # Check if IP exists in IPAM
        existing_ip = IPAddressModel.query.filter_by(ip_address=field.data).first()
        
        if existing_ip:
            # If we're editing a PDU (form has pdu_id), allow the same IP
            if hasattr(form, 'pdu_id') and form.pdu_id and form.pdu_id.data:
                # Check if this IP is assigned to this PDU
                if existing_ip.assigned_to_type == 'pdu' and existing_ip.assigned_to_id == int(form.pdu_id.data):
                    return  # IP is already assigned to this PDU - OK
            
            # Check if IP is assigned to something else
            if existing_ip.is_assigned:
                raise ValidationError(f'IP {field.data} is already assigned to {existing_ip.assigned_device_name}')

# ========== FORM DEFINITIONS ==========

class DataCenterForm(FlaskForm):
    """
    Form for adding/editing data centers
    Validates DC code is exactly 3 characters
    Includes fields for multiple contact types (sales, PM, manager)
    """
    # Basic Information
    code = StringField('DC Code', 
                      validators=[DataRequired(), Length(min=3, max=3)],
                      render_kw={'style': 'text-transform: uppercase;'})
    name = StringField('DC Name', 
                      validators=[DataRequired(), Length(max=100)])
    address = TextAreaField('Address', 
                          validators=[Optional()],
                          render_kw={'rows': 3})
    
    # Primary Contact Information
    contact_phone = StringField('Contact Phone', 
                               validators=[Optional(), Length(max=20)])
    contact_email = StringField('Contact Email', 
                               validators=[Optional(), Email()])
    
    # Sales Contact
    sales_name = StringField('Sales Contact Name', 
                            validators=[Optional(), Length(max=100)])
    sales_email = StringField('Sales Contact Email', 
                             validators=[Optional(), Email()])
    sales_phone = StringField('Sales Contact Phone', 
                              validators=[Optional(), Length(max=20)])
    sales_title = StringField('Sales Contact Title',
                             validators=[Optional(), Length(max=100)])
    
    # Project Manager Contact
    pm_name = StringField('PM Contact Name', 
                         validators=[Optional(), Length(max=100)])
    pm_email = StringField('PM Contact Email', 
                          validators=[Optional(), Email()])
    pm_phone = StringField('PM Contact Phone', 
                          validators=[Optional(), Length(max=20)])
    pm_title = StringField('PM Contact Title',
                          validators=[Optional(), Length(max=100)])
    
    # Manager Contact
    manager_name = StringField('Manager Contact Name', 
                               validators=[Optional(), Length(max=100)])
    manager_email = StringField('Manager Contact Email', 
                                validators=[Optional(), Email()])
    manager_phone = StringField('Manager Contact Phone', 
                                validators=[Optional(), Length(max=20)])
    manager_title = StringField('Manager Contact Title',
                                validators=[Optional(), Length(max=100)])
    
    # Notes
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3})


class FloorForm(FlaskForm):
    """
    Form for adding/editing floors within a data center
    Maps provider designations to actual floor numbers
    """
    provider_designation = StringField('Provider Designation', 
                                      validators=[DataRequired(), Length(max=10)])
    actual_floor = SelectField('Actual Floor',
                              choices=[
                                  ('Basement', 'Basement'),
                                  ('Ground Floor', 'Ground Floor'),
                                  ('1st Floor', '1st Floor'),
                                  ('2nd Floor', '2nd Floor'),
                                  ('3rd Floor', '3rd Floor'),
                                  ('4th Floor', '4th Floor'),
                                  ('5th Floor', '5th Floor'),
                                  ('6th Floor', '6th Floor'),
                                  ('7th Floor', '7th Floor'),
                                  ('8th Floor', '8th Floor'),
                                  ('9th Floor', '9th Floor'),
                                  ('10th Floor', '10th Floor'),
                              ],
                              validators=[DataRequired()])
    description = StringField('Description', 
                            validators=[Optional(), Length(max=100)])


class RackForm(FlaskForm):
    """
    Form for adding/editing racks
    Validates rack specifications within reasonable limits
    Includes 4-digit rack access code field
    """
    row_number = StringField('Row/Grid Number', 
                           validators=[DataRequired(), Length(max=10)])
    cabinet_number = StringField('Cabinet Number', 
                               validators=[DataRequired(), Length(max=10)])
    u_height = IntegerField('Total U Height', 
                          validators=[DataRequired(), NumberRange(min=1, max=60)],
                          default=42)
    power_capacity = FloatField('Power Capacity (Amps)', 
                              validators=[Optional(), NumberRange(min=0)])
    rack_code = StringField('Rack Access Code', 
                          validators=[Optional(), 
                                    Regexp('^[0-9]{4}$', message='Must be exactly 4 digits')],
                          render_kw={'maxlength': '4'})
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3})


class PDUForm(FlaskForm):
    """
    Form for adding/editing PDUs with IPAM integration
    Validates electrical specifications for rack PDUs
    Includes model field for tracking APC model numbers
    Includes switch connectivity for managed PDUs
    IPAM INTEGRATION: Validates IP addresses against IPAM database
    
    Version 1.3.0 - Added IPAM integration for IP validation
    """
    
    # ========== HIDDEN FIELD FOR EDITING ==========
    pdu_id = IntegerField('PDU ID', 
                         validators=[Optional()],
                         render_kw={'type': 'hidden'})
    
    # ========== PDU IDENTIFICATION ==========
    identifier = StringField('PDU Identifier', 
                           validators=[DataRequired(), Length(max=50)],
                           render_kw={'placeholder': 'APC 1'})
    model = StringField('Model Number', 
                       validators=[Optional(), Length(max=50)],
                       render_kw={'placeholder': 'AP7932, AP8941, etc.'})
    circuit_id = StringField('Circuit ID', 
                           validators=[Optional(), Length(max=50)],
                           render_kw={'placeholder': 'Circuit identifier'})
    
    # ========== ELECTRICAL SPECIFICATIONS ==========
    capacity_amps = FloatField('Capacity (Amps)', 
                             validators=[DataRequired(), NumberRange(min=0, max=100)])
    voltage = SelectField('Voltage',
                         choices=[
                             (120, '120V'),
                             (208, '208V'),
                             (240, '240V'),
                         ],
                         coerce=int,
                         validators=[DataRequired()])
    phase = SelectField('Phase',
                       choices=[
                           ('Single', 'Single Phase'),
                           ('Three', 'Three Phase'),
                       ],
                       validators=[DataRequired()])
    
    # ========== OUTLET CONFIGURATION ==========
    total_outlets = IntegerField('Total Outlets', 
                                validators=[DataRequired(), NumberRange(min=1, max=48)],
                                default=24)
    
    # ========== NETWORK MANAGEMENT - UPDATED v1.3.0 ==========
    # CHANGED: Added IPAM validation
    ip_address = StringField('Management IP', 
                           validators=[
                               Optional(), 
                               IPAddress(ipv4=True, ipv6=False, message='Invalid IPv4 address'),
                               validate_ip_available_or_assigned_to_pdu  # IPAM check
                           ],
                           render_kw={'placeholder': '10.10.x.x (optional)'})
    
    # NEW v1.3.0: VLAN field for management network
    vlan_id = IntegerField('Management VLAN',
                          validators=[Optional(), NumberRange(min=1, max=4094)],
                          render_kw={'placeholder': 'VLAN ID (optional)'})
    
    # v1.2.0: Switch connectivity for managed PDUs
    connected_switch_id = SelectField('Connected Switch',
                                     coerce=int,
                                     validators=[Optional()])
    
    connected_switch_port = IntegerField('Switch Port Number',
                                        validators=[Optional(), NumberRange(min=1, max=96)])
    
    # ========== ADDITIONAL ==========
    notes = TextAreaField('Notes', 
                         validators=[Optional()],
                         render_kw={'rows': 3})
    
    def validate(self, **kwargs):
        """
        Custom validation for PDU form
        Ensures network connectivity is properly configured
        CHANGED v1.3.0: Enhanced validation for IPAM integration
        """
        if not super().validate(**kwargs):
            return False
        
        # If switch is selected, port must be specified
        if self.connected_switch_id.data and self.connected_switch_id.data != 0:
            if not self.connected_switch_port.data:
                self.connected_switch_port.errors.append('Port number required when switch is selected')
                return False
        
        # If port is specified, switch must be selected
        if self.connected_switch_port.data:
            if not self.connected_switch_id.data or self.connected_switch_id.data == 0:
                self.connected_switch_id.errors.append('Switch must be selected when port is specified')
                return False
        
        # v1.3.0: Enhanced IP validation for management network
        if self.ip_address.data:
            # Suggest VLAN based on IP pattern
            if self.ip_address.data.startswith('10.10.') and not self.vlan_id.data:
                # Extract suggested VLAN from third octet
                try:
                    parts = self.ip_address.data.split('.')
                    if len(parts) >= 3:
                        third_octet = int(parts[2])
                        # Suggest VLAN (e.g., 10.10.5.x suggests VLAN 105)
                        suggested_vlan = 100 + third_octet
                        # Just a suggestion, not enforced
                except:
                    pass
        
        return True