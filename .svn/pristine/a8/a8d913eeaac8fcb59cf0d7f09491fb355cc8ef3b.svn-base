{% extends "base.html" %}

{% block title %}DCMS - {{ module }}{% endblock %}
{% block page_title %}{{ module }}{% endblock %}

{% block content %}
<div class="card">
    <div style="text-align: center; padding: 4rem 2rem;">
        <div style="font-size: 5rem; margin-bottom: 1rem;">{{ emoji }}</div>
        <h2 style="color: #60a5fa; margin-bottom: 1rem;">{{ module }} Module</h2>
        <p class="text-muted" style="font-size: 1.125rem;">This module is under development</p>
        <p class="text-muted">Coming soon...</p>
        
        <div style="margin-top: 2rem;">
            <a href="/" class="btn">← Back to Dashboard</a>
        </div>
    </div>
</div>

<div class="card">
    <h3>Module Features (Planned)</h3>
    <ul style="color: #94a3b8; line-height: 2;">
        <li>• Complete CRUD operations</li>
        <li>• Search and filtering</li>
        <li>• Import/Export functionality</li>
        <li>• Detailed reporting</li>
        <li>• API integration</li>
    </ul>
</div>
{% endblock %}