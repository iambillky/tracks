@network_devices_bp.route('/edit/<int:device_id>', methods=['GET', 'POST'])
def edit_device(device_id):
    """
    Edit network device
    Version: 1.4.0 - Added port connection preservation when changing switch models
    """
    from models.switch_model import SwitchModel
    from models.switch_port import SwitchPort
    from datetime import datetime
    
    device = NetworkDevice.query.get_or_404(device_id)
    form = NetworkDeviceForm(obj=device)
    
    # Store original values for comparison
    original_rack_id = device.rack_id
    original_start_u = device.start_u
    original_size_u = device.size_u
    original_pdu_1_id = device.pdu_1_id
    original_pdu_2_id = device.pdu_2_id
    original_switch_model_id = device.switch_model_id
    
    # Populate rack choices
    racks = Rack.query.order_by(Rack.rack_id).all()
    form.rack_id.choices = [(rack.id, f"{rack.rack_id} ({rack.u_available}U available)") 
                            for rack in racks]
    
    # Populate switch model choices
    switch_models = SwitchModel.query.order_by(
        SwitchModel.manufacturer,
        SwitchModel.model_number
    ).all()
    
    form.switch_model_id.choices = [(0, '-- No Model Selected --')] + [
        (model.id, model.display_name) for model in switch_models
    ]
    
    # Populate PDU choices
    pdus = PDU.query.join(Rack).order_by(Rack.rack_id, PDU.identifier).all()
    pdu_choices = [(0, '-- No PDU --')] + [
        (pdu.id, f"{pdu.rack.rack_id} - {pdu.identifier} ({pdu.available_outlets} outlets free)")
        for pdu in pdus
    ]
    form.pdu_1_id.choices = pdu_choices
    form.pdu_2_id.choices = pdu_choices
    
    if form.validate_on_submit():
        # Check if hostname changed and already exists
        if form.hostname.data.upper() != device.hostname:
            existing = NetworkDevice.query.filter_by(hostname=form.hostname.data.upper()).first()
            if existing:
                flash(f'Device with hostname {form.hostname.data.upper()} already exists!', 'error')
                return render_template('network_devices/edit_device.html', form=form, device=device)
        
        # Check rack space if position changed
        if (form.rack_id.data != original_rack_id or 
            form.start_u.data != original_start_u or 
            form.size_u.data != original_size_u):
            
            rack = Rack.query.get(form.rack_id.data)
            if not validate_rack_space(rack, form.start_u.data, form.size_u.data, exclude_device_id=device_id):
                flash(f'Rack space U{form.start_u.data}-U{form.start_u.data + form.size_u.data - 1} is not available!', 'error')
                return render_template('network_devices/edit_device.html', form=form, device=device)
        
        # Update rack usage if changed
        if form.rack_id.data != original_rack_id or form.size_u.data != original_size_u:
            old_rack = Rack.query.get(original_rack_id)
            new_rack = Rack.query.get(form.rack_id.data)
            old_rack.u_used -= original_size_u
            new_rack.u_used += form.size_u.data
        
        # Update PDU usage if changed
        if form.pdu_1_id.data != original_pdu_1_id:
            if original_pdu_1_id:
                old_pdu = PDU.query.get(original_pdu_1_id)
                old_pdu.used_outlets -= 1
            if form.pdu_1_id.data and form.pdu_1_id.data != 0:
                new_pdu = PDU.query.get(form.pdu_1_id.data)
                new_pdu.used_outlets += 1
        
        if form.pdu_2_id.data != original_pdu_2_id:
            if original_pdu_2_id:
                old_pdu = PDU.query.get(original_pdu_2_id)
                old_pdu.used_outlets -= 1
            if form.pdu_2_id.data and form.pdu_2_id.data != 0:
                new_pdu = PDU.query.get(form.pdu_2_id.data)
                new_pdu.used_outlets += 1
        
        # Update device fields
        device.hostname = form.hostname.data.upper()
        device.identifier = form.identifier.data.upper()
        device.device_type = form.device_type.data
        device.device_role = form.device_role.data
        device.network_type = form.network_type.data
        device.manufacturer = form.manufacturer.data
        device.model = form.model.data
        device.serial_number = form.serial_number.data
        device.software_version = form.software_version.data
        device.rack_id = form.rack_id.data
        device.start_u = form.start_u.data
        device.size_u = form.size_u.data
        device.management_ip = form.management_ip.data
        device.port_count = form.port_count.data
        device.pdu_1_id = form.pdu_1_id.data if form.pdu_1_id.data != 0 else None
        device.pdu_1_outlet = form.pdu_1_outlet.data
        device.pdu_2_id = form.pdu_2_id.data if form.pdu_2_id.data != 0 else None
        device.pdu_2_outlet = form.pdu_2_outlet.data
        device.power_consumption = form.power_consumption.data
        device.status = form.status.data
        device.notes = form.notes.data
        device.switch_model_id = form.switch_model_id.data if form.switch_model_id.data != 0 else None
        
        # CHANGED v1.4.0: Handle switch model change - PRESERVE connections when possible
        if device.device_type in ['Switch', 'Core'] and device.switch_model_id != original_switch_model_id:
            # Get existing ports with their connections
            existing_ports = SwitchPort.query.filter_by(switch_id=device.id).all()
            
            # Create a map of existing connections by port number
            connection_map = {}
            for port in existing_ports:
                if port.connected_device_type or port.description or port.vlan_mode or port.access_vlan:
                    connection_map[port.port_number] = {
                        'connected_device_type': port.connected_device_type,
                        'connected_device_id': port.connected_device_id,
                        'connected_port': port.connected_port,
                        'description': port.description,
                        'vlan_mode': port.vlan_mode,
                        'access_vlan': port.access_vlan,
                        'native_vlan': port.native_vlan,
                        'allowed_vlans': port.allowed_vlans,
                        'lag_group': port.lag_group,
                        'lag_mode': port.lag_mode,
                        'status': port.status,
                        'notes': port.notes
                    }
            
            # Warn user about connections that will be preserved/lost
            if connection_map:
                flash(f'⚠️ Switch model change: Attempting to preserve {len(connection_map)} port connections', 'warning')
            
            # Delete old ports
            for port in existing_ports:
                db.session.delete(port)
            db.session.flush()  # Flush but don't commit yet
            
            # Create new ports if model selected
            if device.switch_model_id:
                switch_model = SwitchModel.query.get(device.switch_model_id)
                
                if switch_model:
                    port_config = switch_model.get_port_configuration()
                    new_port_numbers = set()
                    preserved_count = 0
                    lost_connections = []
                    
                    for port_spec in port_config['ports']:
                        port = SwitchPort(
                            switch_id=device.id,
                            port_number=port_spec['number'],
                            port_name=port_spec['name'],
                            port_type='access' if port_spec['type'] == 'copper' else 'uplink',
                            port_speed=str(port_spec['speed']),
                            status='active'
                        )
                        
                        # Restore connections if this port number had connections
                        if port_spec['number'] in connection_map:
                            old_connection = connection_map[port_spec['number']]
                            port.connected_device_type = old_connection['connected_device_type']
                            port.connected_device_id = old_connection['connected_device_id']
                            port.connected_port = old_connection['connected_port']
                            port.description = old_connection['description']
                            port.vlan_mode = old_connection['vlan_mode']
                            port.access_vlan = old_connection['access_vlan']
                            port.native_vlan = old_connection['native_vlan']
                            port.allowed_vlans = old_connection['allowed_vlans']
                            port.lag_group = old_connection['lag_group']
                            port.lag_mode = old_connection['lag_mode']
                            port.status = old_connection['status']
                            port.notes = old_connection['notes']
                            preserved_count += 1
                        
                        new_port_numbers.add(port_spec['number'])
                        db.session.add(port)
                    
                    # Check for lost connections (ports that existed before but not in new model)
                    for old_port_num, old_connection in connection_map.items():
                        if old_port_num not in new_port_numbers and old_connection['connected_device_type']:
                            # Build a description of what was connected
                            device_desc = "Unknown"
                            if old_connection['connected_device_type'] == 'network_device':
                                connected_device = NetworkDevice.query.get(old_connection['connected_device_id'])
                                if connected_device:
                                    device_desc = f"Switch {connected_device.identifier}"
                            elif old_connection['connected_device_type'] == 'pdu':
                                connected_pdu = PDU.query.get(old_connection['connected_device_id'])
                                if connected_pdu:
                                    device_desc = f"PDU {connected_pdu.identifier}"
                            
                            lost_connections.append(f"Port {old_port_num} → {device_desc}")
                    
                    # Report results
                    flash(f'✅ Created {len(port_config["ports"])} ports for {device.identifier}', 'info')
                    
                    if preserved_count > 0:
                        flash(f'✅ Preserved {preserved_count} port connection(s)', 'success')
                    
                    if lost_connections:
                        flash(f'⚠️ Lost connections (ports no longer exist): {", ".join(lost_connections)}', 'warning')
                        # Log these for audit trail in device notes
                        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M')
                        audit_note = f"[{timestamp}] Model change from {original_switch_model_id} to {device.switch_model_id} lost: {', '.join(lost_connections)}"
                        
                        if device.notes:
                            device.notes += f"\n\n{audit_note}"
                        else:
                            device.notes = audit_note
            else:
                # No model selected - just delete all ports
                flash(f'⚠️ Removed all ports from {device.identifier} (no model selected)', 'warning')
        
        db.session.commit()
        flash(f'Network device {device.identifier} updated!', 'success')
        return redirect(url_for('network_devices.index'))
    
    return render_template('network_devices/edit_device.html', form=form, device=device)

# ========== DELETE OPERATIONS ==========

@network_devices_bp.route('/delete/<int:device_id>', methods=['POST'])
def delete_device(device_id):
    """Delete network device and its ports"""
    from models.switch_port import SwitchPort
    
    device = NetworkDevice.query.get_or_404(device_id)
    
    # Delete all associated ports first
    SwitchPort.query.filter_by(switch_id=device.id).delete()
    
    # Update rack usage
    rack = Rack.query.get(device.rack_id)
    rack.u_used -= device.size_u
    
    # Update PDU outlet usage
    if device.pdu_1_id:
        pdu1 = PDU.query.get(device.pdu_1_id)
        pdu1.used_outlets -= 1
    if device.pdu_2_id:
        pdu2 = PDU.query.get(device.pdu_2_id)
        pdu2.used_outlets -= 1
    
    db.session.delete(device)
    db.session.commit()
    
    flash(f'Network device {device.identifier} deleted!', 'success')
    return redirect(url_for('network_devices.index'))