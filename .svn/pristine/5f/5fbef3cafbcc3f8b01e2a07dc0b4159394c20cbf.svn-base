"""
File: routes/network_devices.py
Purpose: Route handlers for network device management
Version: 1.3.1
Author: iambilky / DCMS Team

Revision History:
- v1.0.0: Initial creation with CRUD operations for network devices
- v1.1.0: Added device_detail route for read-only device view
- v1.2.0: Added switch_detail route for port management view
- v1.3.0: Added switch model selection and automatic port creation
- v1.3.1: Fixed validate_rack_space to use u_height instead of u_capacity
"""

from flask import Blueprint, render_template, request, redirect, url_for, flash, jsonify
from models.network_device import db, NetworkDevice, DEVICE_TYPES, DEVICE_ROLES, NETWORK_TYPES, DEVICE_STATUS
from models.datacenter import Rack, PDU
from forms.network_device_forms import NetworkDeviceForm
from sqlalchemy import and_

# ========== BLUEPRINT INITIALIZATION ==========

network_devices_bp = Blueprint('network_devices', __name__, url_prefix='/network-devices')

# ========== UTILITY FUNCTIONS ==========

def validate_rack_space(rack, start_u, size_u, exclude_device_id=None):
    """
    Validate if rack space is available
    Returns True if space is available, False otherwise
    """
    if not rack:
        return False
    
    # Check if U positions are within rack capacity
    # CHANGED: Fixed attribute name from u_capacity to u_height
    if start_u < 1 or (start_u + size_u - 1) > rack.u_height:
        return False
    
    # Check for overlapping devices
    devices_in_rack = NetworkDevice.query.filter_by(rack_id=rack.id).all()
    
    for device in devices_in_rack:
        # Skip the device being edited
        if exclude_device_id and device.id == exclude_device_id:
            continue
            
        # Check for overlap
        device_end = device.start_u + device.size_u - 1
        requested_end = start_u + size_u - 1
        
        if not (requested_end < device.start_u or start_u > device_end):
            return False
    
    return True

# ========== MAIN VIEWS ==========

@network_devices_bp.route('/')
def index():
    """
    Main network device view
    Shows all network devices organized by type and location
    """
    # Get filter parameters
    network_type = request.args.get('network_type', 'all')
    device_type = request.args.get('device_type', 'all')
    rack_id = request.args.get('rack', 'all')
    
    # Build query
    query = NetworkDevice.query
    
    if network_type != 'all':
        query = query.filter_by(network_type=network_type)
    if device_type != 'all':
        query = query.filter_by(device_type=device_type)
    if rack_id != 'all':
        query = query.filter_by(rack_id=int(rack_id))
    
    # Get devices
    devices = query.order_by(NetworkDevice.identifier).all()
    
    # Get all racks for filter dropdown
    racks = Rack.query.order_by(Rack.rack_id).all()
    
    # Calculate summary statistics
    total_devices = NetworkDevice.query.count()
    private_count = NetworkDevice.query.filter_by(network_type='private').count()
    public_count = NetworkDevice.query.filter_by(network_type='public').count()
    active_count = NetworkDevice.query.filter_by(status='active').count()
    
    # Group devices by rack for visualization
    devices_by_rack = {}
    for device in devices:
        if device.rack.rack_id not in devices_by_rack:
            devices_by_rack[device.rack.rack_id] = []
        devices_by_rack[device.rack.rack_id].append(device)
    
    return render_template('network_devices/index.html',
                         devices=devices,
                         devices_by_rack=devices_by_rack,
                         racks=racks,
                         total_devices=total_devices,
                         private_count=private_count,
                         public_count=public_count,
                         active_count=active_count,
                         current_filters={
                             'network_type': network_type,
                             'device_type': device_type,
                             'rack': rack_id
                         })

@network_devices_bp.route('/device/<int:device_id>')
def device_detail(device_id):
    """
    Display detailed read-only view of a network device
    Shows device information, location, power, and network details
    Version: 1.0.0 - Initial implementation keeping it simple
    """
    device = NetworkDevice.query.get_or_404(device_id)
    
    return render_template('network_devices/device_detail.html', device=device)

@network_devices_bp.route('/switch/<int:device_id>')
def switch_detail(device_id):
    """
    Display detailed switch port view showing what's connected to each port
    Works with auto-populated ports from SwitchPort model
    Version: 2.0.0 - Updated to work with auto-populated ports
    """
    from models.switch_port import SwitchPort
    
    device = NetworkDevice.query.get_or_404(device_id)
    
    # Check if this is actually a switch
    if device.device_type not in ['Switch', 'Core']:
        flash('This device is not a switch', 'error')
        return redirect(url_for('network_devices.device_detail', device_id=device_id))
    
    # Get all ports from the SwitchPort table (auto-populated)
    ports = SwitchPort.query.filter_by(switch_id=device_id).order_by(SwitchPort.port_number).all()
    
    # If no ports exist, something is wrong (since we auto-create them)
    if not ports:
        flash('No ports found for this switch. This may indicate a configuration issue.', 'warning')
        # You could trigger port creation here if needed
        total_ports = device.port_count or 48
    else:
        total_ports = len(ports)
    
    # Determine port split for display (half and half)
    port_split = total_ports // 2
    
    # Separate uplink ports from regular ports
    uplinks = []
    connected_devices = []
    
    # Process each port for visualization
    port_data = []
    for port in ports:
        # Determine status class for CSS
        status_class = 'available'
        if port.status == 'disabled':
            status_class = 'disabled'
        elif port.port_type in ['uplink', 'trunk']:
            status_class = 'uplink' if port.connected_device_type == 'network_device' else 'trunk'
            if port.connected_device_type:
                uplinks.append(port)
        elif port.connected_device_type:
            status_class = 'occupied'
            connected_devices.append(port)
        
        # Build URL for connected device (if applicable)
        device_url = None
        if port.connected_device_type == 'network_device' and port.connected_device_id:
            device_url = url_for('network_devices.switch_detail', device_id=port.connected_device_id)
        elif port.connected_device_type == 'pdu' and port.connected_device_id:
            device_url = url_for('pdus.outlet_view', pdu_id=port.connected_device_id)
        
        port_info = {
            'number': port.port_number,
            'name': port.port_name,
            'status_class': status_class,
            'device': port.connected_device_name,
            'device_full_name': f"{port.connected_device_type}: {port.connected_device_name}" if port.connected_device_name else None,
            'device_url': device_url,
            'vlan': port.access_vlan or port.native_vlan,
            'link_status': 'up' if port.link_status else 'down',
            'port_type': port.port_type,
            'status': port.status
        }
        port_data.append(port_info)
    
    # Split ports into two halves for display
    first_half = port_data[:port_split]
    second_half = port_data[port_split:]
    
    # Count used ports in each half
    first_half_used = sum(1 for p in first_half if p['device'])
    second_half_used = sum(1 for p in second_half if p['device'])
    
    # Calculate statistics
    total_used = len([p for p in port_data if p['device']])
    total_available = len([p for p in port_data if not p['device'] and p['status'] != 'disabled'])
    total_disabled = len([p for p in port_data if p['status'] == 'disabled'])
    
    return render_template('network_devices/switch_detail.html',
                         device=device,
                         total_ports=total_ports,
                         port_split=port_split,
                         first_half=first_half,
                         second_half=second_half,
                         first_half_used=first_half_used,
                         second_half_used=second_half_used,
                         uplinks=uplinks,
                         connected_devices=connected_devices,
                         total_used=total_used,
                         total_available=total_available,
                         total_disabled=total_disabled)

# ========== CREATE OPERATIONS ==========

@network_devices_bp.route('/add', methods=['GET', 'POST'])
def add_device():
    """
    Add new network device with equipment library support
    When a switch model is selected, automatically creates all ports
    Version: 1.3.0 - Added switch model selection
    """
    from models.switch_model import SwitchModel
    from models.switch_port import SwitchPort
    
    form = NetworkDeviceForm()
    
    # Populate rack choices
    racks = Rack.query.order_by(Rack.rack_id).all()
    form.rack_id.choices = [(0, '-- Select Rack --')] + [
        (rack.id, f"{rack.rack_id} ({rack.u_available}U available)") 
        for rack in racks
    ]
    
    # CHANGED: Populate switch model choices from equipment library
    switch_models = SwitchModel.query.order_by(
        SwitchModel.manufacturer, 
        SwitchModel.model_number
    ).all()
    
    form.switch_model_id.choices = [(0, '-- Select Model (for Switches) --')] + [
        (model.id, model.display_name) for model in switch_models
    ]
    
    # Populate PDU choices
    pdus = PDU.query.join(Rack).order_by(Rack.rack_id, PDU.identifier).all()
    pdu_choices = [(0, '-- No PDU --')] + [
        (pdu.id, f"{pdu.rack.rack_id} - {pdu.identifier} ({pdu.available_outlets} outlets free)")
        for pdu in pdus
    ]
    form.pdu_1_id.choices = pdu_choices
    form.pdu_2_id.choices = pdu_choices
    
    if form.validate_on_submit():
        # Check if hostname already exists
        existing = NetworkDevice.query.filter_by(hostname=form.hostname.data.upper()).first()
        if existing:
            flash(f'Device with hostname {form.hostname.data.upper()} already exists!', 'error')
            return render_template('network_devices/add_device.html', form=form)
        
        # Check if rack space is available
        rack = Rack.query.get(form.rack_id.data)
        if not validate_rack_space(rack, form.start_u.data, form.size_u.data):
            flash(f'Rack space U{form.start_u.data}-U{form.start_u.data + form.size_u.data - 1} is not available!', 'error')
            return render_template('network_devices/add_device.html', form=form)
        
        # Create device
        device = NetworkDevice()
        device.hostname = form.hostname.data.upper()
        device.identifier = form.identifier.data.upper()
        device.device_type = form.device_type.data
        device.device_role = form.device_role.data
        device.network_type = form.network_type.data
        device.manufacturer = form.manufacturer.data
        device.model = form.model.data
        device.serial_number = form.serial_number.data
        device.software_version = form.software_version.data
        device.rack_id = form.rack_id.data
        device.start_u = form.start_u.data
        device.size_u = form.size_u.data
        device.management_ip = form.management_ip.data
        device.port_count = form.port_count.data
        device.pdu_1_id = form.pdu_1_id.data if form.pdu_1_id.data != 0 else None
        device.pdu_1_outlet = form.pdu_1_outlet.data
        device.pdu_2_id = form.pdu_2_id.data if form.pdu_2_id.data != 0 else None
        device.pdu_2_outlet = form.pdu_2_outlet.data
        device.power_consumption = form.power_consumption.data
        device.status = form.status.data
        device.notes = form.notes.data
        device.switch_model_id = form.switch_model_id.data if form.switch_model_id.data != 0 else None
        
        # Update rack usage
        rack.u_used += device.size_u
        
        if device.pdu_1_id:
            pdu1 = PDU.query.get(device.pdu_1_id)
            pdu1.used_outlets += 1
        
        if device.pdu_2_id:
            pdu2 = PDU.query.get(device.pdu_2_id)
            pdu2.used_outlets += 1
        
        db.session.add(device)
        db.session.commit()  # Commit to get device.id
        
        # CHANGED: Auto-create ports if this is a switch with a model selected
        if device.device_type in ['Switch', 'Core'] and device.switch_model_id:
            switch_model = SwitchModel.query.get(device.switch_model_id)
            
            if switch_model:
                print(f"Creating ports for {device.identifier} using model {switch_model.model_number}")
                
                # Get port configuration from model
                port_config = switch_model.get_port_configuration()
                
                for port_spec in port_config['ports']:
                    port = SwitchPort(
                        switch_id=device.id,
                        port_number=port_spec['number'],
                        port_name=port_spec['name'],
                        port_type='access' if port_spec['type'] == 'copper' else 'uplink',
                        port_speed=str(port_spec['speed']),
                        status='active'
                    )
                    db.session.add(port)
                
                db.session.commit()
                flash(f'Created {len(port_config["ports"])} ports for {device.identifier}', 'info')
        
        flash(f'Network device {device.identifier} added successfully!', 'success')
        return redirect(url_for('network_devices.index'))
    
    return render_template('network_devices/add_device.html', form=form)

